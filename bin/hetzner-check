#!/usr/bin/env bash
set -euo pipefail

APP_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$APP_ROOT"

if [[ -f .env ]]; then
  set -a
  # shellcheck disable=SC1091
  source .env
  set +a
fi

fail() {
  printf 'Fehler: %s\n' "$1" >&2
  exit 1
}

require_file() {
  local path="$1"
  [[ -f "$path" ]] || fail "Datei fehlt: $path"
}

require_value() {
  local name="$1"
  [[ -n "${!name:-}" ]] || fail "Umgebungsvariable fehlt oder ist leer: $name"
}

extract_secret_names() {
  ruby <<'RUBY'
require "yaml"
require "erb"

config_path = File.expand_path("config/deploy.hetzner.yml", Dir.pwd)
raw = ERB.new(File.read(config_path)).result
config = YAML.safe_load(raw, aliases: true)
Array(config.dig("env", "secret")).each { |name| puts name }
RUBY
}

printf 'Prüfe lokale Hetzner-Voraussetzungen in %s\n' "$APP_ROOT"

require_file "config/master.key"
require_file ".kamal/secrets.hetzner"
require_file "$HOME/.ssh/stgt-live-hetzner-github"
require_value "APP_HOST"

expected_host="stuttgart-live.schopp3r.de"
if [[ "${APP_HOST}" != "${expected_host}" ]]; then
  fail "APP_HOST ist '${APP_HOST}', erwartet wird '${expected_host}'"
fi

while IFS= read -r secret_name; do
  [[ -n "$secret_name" ]] || continue
  if ! grep -Eq "^${secret_name}=" ".kamal/secrets.hetzner"; then
    fail "Secret fehlt in .kamal/secrets.hetzner: ${secret_name}"
  fi
done < <(extract_secret_names)

printf 'APP_HOST: %s\n' "$APP_HOST"
printf 'Kamal-Secrets: vollständig\n'
printf 'SSH-Key: %s\n' "$HOME/.ssh/stgt-live-hetzner-github"
printf 'Status: OK\n'
