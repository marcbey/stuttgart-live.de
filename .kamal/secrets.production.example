# Copy to .kamal/secrets.production and fill values.
# Usage: bin/kamal deploy -d production

# ECR login password (refresh before each deploy if needed)
KAMAL_REGISTRY_PASSWORD=$(aws ecr get-login-password --region eu-central-1 --profile stgt-live-admin)

# Rails master key (do not commit real secrets)
RAILS_MASTER_KEY=$(cat config/master.key)

# RDS password (must match TF_VAR_db_password used for Terraform apply)
DB_PASSWORD=replace-me

# Importer configuration
XMP_DUMP_URL=replace-me
EVENT_DETAIL_API=replace-me
API_KEY=replace-me
PARTNER_SHOP_ID=replace-me
TICKET_LINK_EVENT_BASE_URL=replace-me

# Easyticket basic auth
EASYTICKET_USER=replace-me
EASYTICKET_PASS=replace-me

# Event feed configuration (if used)
FEED_URL=replace-me
FEED_USER=replace-me
FEED_PASS=replace-me
EVENTIM_USER=replace-me
EVENTIM_PASS=replace-me
