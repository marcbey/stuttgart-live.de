# Copy to .kamal/secrets.production and fill values.
# Usage: bin/kamal deploy -d production

# ECR login password (refresh before each deploy if needed)
KAMAL_REGISTRY_PASSWORD=$(aws ecr get-login-password --region eu-central-1 --profile stgt-live-admin)

# Rails master key (do not commit real secrets)
RAILS_MASTER_KEY=$(cat config/master.key)

# RDS password for both Kamal deploys and local Terraform runs via script/terraform_prod
DB_PASSWORD=replace-me

# Easyticket
EASYTICKET_EVENTS_API=replace-me
EASYTICKET_EVENT_DETAIL_API=replace-me
EASYTICKET_PARTNER_SHOP_ID=replace-me
EASYTICKET_TICKET_LINK_EVENT_BASE_URL=replace-me

# Eventim
EVENTIM_FEED_URL=replace-me
EVENTIM_USER=replace-me
EVENTIM_PASS=replace-me

# Reservix
RESERVIX_API_KEY=replace-me
RESERVIX_EVENTS_API=replace-me
