# Diese Datei wird von Kamal beim Deploy ausgewertet.
# Lokal dürfen die Werte aus `.env` bzw. `config/master.key` kommen.
# In GitHub Actions sollten dieselben Namen als Environment-Secrets gesetzt sein.
#
# Damit bleiben zwei Ebenen bewusst getrennt:
# - App-Konfiguration: Werte, die die Anwendung zur Laufzeit benötigt
# - Deploy-Secrets: Werte für Registry, SSH und Deployment-Kontext

KAMAL_REGISTRY_PULL_PASSWORD=$(test -f .env && grep -m 1 '^KAMAL_REGISTRY_PULL_PASSWORD=' .env | cut -d= -f2-)
RAILS_MASTER_KEY=$(test -f config/master.key && tr -d '\r\n' < config/master.key)
DB_PASSWORD=$(test -f .env && grep -m 1 '^DB_PASSWORD=' .env | cut -d= -f2-)
GOOGLE_ANALYTICS_ID=$(test -f .env && grep -m 1 '^GOOGLE_ANALYTICS_ID=' .env | cut -d= -f2-)
MAILCHIMP_API_KEY=$(test -f .env && grep -m 1 '^MAILCHIMP_API_KEY=' .env | cut -d= -f2-)
MAILCHIMP_LIST_ID=$(test -f .env && grep -m 1 '^MAILCHIMP_LIST_ID=' .env | cut -d= -f2-)
MAILCHIMP_SERVER_PREFIX=$(test -f .env && grep -m 1 '^MAILCHIMP_SERVER_PREFIX=' .env | cut -d= -f2-)
SMTP_ADDRESS=$(test -f .env && grep -m 1 '^SMTP_ADDRESS=' .env | cut -d= -f2-)
SMTP_PORT=$(test -f .env && grep -m 1 '^SMTP_PORT=' .env | cut -d= -f2-)
SMTP_USERNAME=$(test -f .env && grep -m 1 '^SMTP_USERNAME=' .env | cut -d= -f2-)
SMTP_PASSWORD=$(test -f .env && grep -m 1 '^SMTP_PASSWORD=' .env | cut -d= -f2-)
SMTP_DOMAIN=$(test -f .env && grep -m 1 '^SMTP_DOMAIN=' .env | cut -d= -f2-)
SMTP_AUTHENTICATION=$(test -f .env && grep -m 1 '^SMTP_AUTHENTICATION=' .env | cut -d= -f2-)
SMTP_ENABLE_STARTTLS_AUTO=$(test -f .env && grep -m 1 '^SMTP_ENABLE_STARTTLS_AUTO=' .env | cut -d= -f2-)
MAILER_FROM=$(test -f .env && grep -m 1 '^MAILER_FROM=' .env | cut -d= -f2-)

# Easyticket
EASYTICKET_EVENTS_API=$(test -f .env && grep -m 1 '^EASYTICKET_EVENTS_API=' .env | cut -d= -f2-)
EASYTICKET_EVENT_DETAIL_API=$(test -f .env && grep -m 1 '^EASYTICKET_EVENT_DETAIL_API=' .env | cut -d= -f2-)
EASYTICKET_PARTNER_SHOP_ID=$(test -f .env && grep -m 1 '^EASYTICKET_PARTNER_SHOP_ID=' .env | cut -d= -f2-)
EASYTICKET_TICKET_LINK_EVENT_BASE_URL=$(test -f .env && grep -m 1 '^EASYTICKET_TICKET_LINK_EVENT_BASE_URL=' .env | cut -d= -f2-)

# Eventim
EVENTIM_FEED_URL=$(test -f .env && grep -m 1 '^EVENTIM_FEED_URL=' .env | cut -d= -f2-)
EVENTIM_USER=$(test -f .env && grep -m 1 '^EVENTIM_USER=' .env | cut -d= -f2-)
EVENTIM_PASS=$(test -f .env && grep -m 1 '^EVENTIM_PASS=' .env | cut -d= -f2-)

# Reservix
RESERVIX_API_KEY=$(test -f .env && grep -m 1 '^RESERVIX_API_KEY=' .env | cut -d= -f2-)
RESERVIX_EVENTS_API=$(test -f .env && grep -m 1 '^RESERVIX_EVENTS_API=' .env | cut -d= -f2-)
