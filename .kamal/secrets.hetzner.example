# Diese Datei wird von Kamal beim Deploy ausgewertet.
# Lokal dürfen die Werte aus `.env` bzw. `config/master.key` kommen.
# In GitHub Actions sollten dieselben Namen als Environment-Secrets gesetzt sein.
#
# Damit bleiben zwei Ebenen bewusst getrennt:
# - App-Konfiguration: Werte, die die Anwendung zur Laufzeit benötigt
# - Deploy-Secrets: Werte für Registry, SSH und Deployment-Kontext

KAMAL_REGISTRY_PULL_PASSWORD=${KAMAL_REGISTRY_PULL_PASSWORD:-$(test -f .env && grep -m 1 '^KAMAL_REGISTRY_PULL_PASSWORD=' .env | cut -d= -f2-)}
RAILS_MASTER_KEY=${RAILS_MASTER_KEY:-$(test -f config/master.key && tr -d '\r\n' < config/master.key)}
DB_PASSWORD=${DB_PASSWORD:-$(test -f .env && grep -m 1 '^DB_PASSWORD=' .env | cut -d= -f2-)}

# Easyticket
EASYTICKET_EVENTS_API=${EASYTICKET_EVENTS_API:-$(test -f .env && grep -m 1 '^EASYTICKET_EVENTS_API=' .env | cut -d= -f2-)}
EASYTICKET_EVENT_DETAIL_API=${EASYTICKET_EVENT_DETAIL_API:-$(test -f .env && grep -m 1 '^EASYTICKET_EVENT_DETAIL_API=' .env | cut -d= -f2-)}
EASYTICKET_PARTNER_SHOP_ID=${EASYTICKET_PARTNER_SHOP_ID:-$(test -f .env && grep -m 1 '^EASYTICKET_PARTNER_SHOP_ID=' .env | cut -d= -f2-)}
EASYTICKET_TICKET_LINK_EVENT_BASE_URL=${EASYTICKET_TICKET_LINK_EVENT_BASE_URL:-$(test -f .env && grep -m 1 '^EASYTICKET_TICKET_LINK_EVENT_BASE_URL=' .env | cut -d= -f2-)}

# Eventim
EVENTIM_FEED_URL=${EVENTIM_FEED_URL:-$(test -f .env && grep -m 1 '^EVENTIM_FEED_URL=' .env | cut -d= -f2-)}
EVENTIM_USER=${EVENTIM_USER:-$(test -f .env && grep -m 1 '^EVENTIM_USER=' .env | cut -d= -f2-)}
EVENTIM_PASS=${EVENTIM_PASS:-$(test -f .env && grep -m 1 '^EVENTIM_PASS=' .env | cut -d= -f2-)}

# Reservix
RESERVIX_API_KEY=${RESERVIX_API_KEY:-$(test -f .env && grep -m 1 '^RESERVIX_API_KEY=' .env | cut -d= -f2-)}
RESERVIX_EVENTS_API=${RESERVIX_EVENTS_API:-$(test -f .env && grep -m 1 '^RESERVIX_EVENTS_API=' .env | cut -d= -f2-)}
