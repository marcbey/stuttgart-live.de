#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
TF_DIR="${TF_DIR:-$ROOT_DIR/infra/terraform/aws/environments/prod}"
KAMAL_SECRETS_FILE="${KAMAL_SECRETS_FILE:-$ROOT_DIR/.kamal/secrets.production}"

if [[ ! -d "$TF_DIR" ]]; then
  echo "Terraform directory not found: $TF_DIR" >&2
  exit 1
fi

read_secret_value() {
  local key="$1"
  local file="$2"
  local line value

  line="$(rg -m 1 "^${key}=" "$file" || true)"
  if [[ -z "$line" ]]; then
    return 1
  fi

  value="${line#*=}"

  VALUE_TO_EVAL="$value" bash -lc 'eval "printf \"%s\\n\" \"$VALUE_TO_EVAL\""' 
}

if [[ -z "${TF_VAR_db_password:-}" ]]; then
  if [[ ! -f "$KAMAL_SECRETS_FILE" ]]; then
    echo "Missing $KAMAL_SECRETS_FILE and TF_VAR_db_password is not set." >&2
    exit 1
  fi

  if secret_value="$(read_secret_value "DB_PASSWORD" "$KAMAL_SECRETS_FILE")"; then
    export TF_VAR_db_password="$secret_value"
  elif secret_value="$(read_secret_value "STUTTGART_LIVE_DE_DATABASE_PASSWORD" "$KAMAL_SECRETS_FILE")"; then
    export TF_VAR_db_password="$secret_value"
  else
    echo "DB_PASSWORD is not set in $KAMAL_SECRETS_FILE." >&2
    exit 1
  fi
fi

exec terraform -chdir="$TF_DIR" "$@"
