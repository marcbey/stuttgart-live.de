#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
REPOSITORY="marcbey/stuttgart-live.de"
ENVIRONMENT="production"
DOTENV_FILE="$ROOT_DIR/.env"
MASTER_KEY_FILE="$ROOT_DIR/config/master.key"
SSH_PRIVATE_KEY_FILE="$HOME/.ssh/stgt-live-hetzner-github"
DRY_RUN=false

# Dieses Skript setzt nur GitHub-Environment-Secrets.
# Terraform verwaltet dafür bewusst nur Environment und Variablen, nicht die Secret-Werte.
usage() {
  cat <<'EOF'
Setzt GitHub-Environment-Secrets für den Production-Deploy.

Nutzung:
  script/github_set_production_secrets [optionen]

Optionen:
  --repo OWNER/REPO        GitHub-Repository (Default: marcbey/stuttgart-live.de)
  --env NAME               GitHub-Environment (Default: production)
  --dotenv PATH            Pfad zur .env-Datei
  --master-key PATH        Pfad zu config/master.key
  --ssh-key PATH           Pfad zum privaten Deploy-SSH-Key
  --dry-run                Nur anzeigen, welche Secrets gesetzt würden
  -h, --help               Diese Hilfe anzeigen
EOF
}

while [[ $# -gt 0 ]]; do
  case "$1" in
    --repo)
      REPOSITORY="$2"
      shift 2
      ;;
    --env)
      ENVIRONMENT="$2"
      shift 2
      ;;
    --dotenv)
      DOTENV_FILE="$2"
      shift 2
      ;;
    --master-key)
      MASTER_KEY_FILE="$2"
      shift 2
      ;;
    --ssh-key)
      SSH_PRIVATE_KEY_FILE="$2"
      shift 2
      ;;
    --dry-run)
      DRY_RUN=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unbekannte Option: $1" >&2
      usage >&2
      exit 1
      ;;
  esac
done

if ! command -v gh >/dev/null 2>&1; then
  echo "gh CLI ist erforderlich." >&2
  exit 1
fi

read_dotenv_value() {
  local key="$1"
  # Ruby parst die `.env` robuster als eine reine grep/cut-Kette
  # und entfernt optionale einfache oder doppelte Quotes.
  ruby - "$DOTENV_FILE" "$key" <<'RUBY'
dotenv_file, key = ARGV
abort "dotenv fehlt: #{dotenv_file}" unless File.exist?(dotenv_file)

value = ""

File.readlines(dotenv_file, chomp: true).each do |line|
  stripped = line.strip
  next if stripped.empty? || stripped.start_with?("#")

  normalized = line.sub(/\Aexport\s+/, "")
  current_key, current_value = normalized.split("=", 2)
  next unless current_key == key
  next if current_value.nil?

  if current_value.length >= 2
    quoted_with_double = current_value.start_with?("\"") && current_value.end_with?("\"")
    quoted_with_single = current_value.start_with?("'") && current_value.end_with?("'")
    current_value = current_value[1..-2] if quoted_with_double || quoted_with_single
  end

  value = current_value
  break
end

abort "Schluessel fehlt in .env: #{key}" if value.empty?
print value
RUBY
}

read_file_value() {
  local path="$1"

  if [[ ! -f "$path" ]]; then
    echo "Datei fehlt: $path" >&2
    exit 1
  fi

  cat "$path"
}

set_secret() {
  local name="$1"
  local value="$2"

  if [[ "$DRY_RUN" == "true" ]]; then
    printf 'DRY RUN: würde Secret %s in %s/%s setzen\n' "$name" "$REPOSITORY" "$ENVIRONMENT"
    return
  fi

  printf '%s' "$value" | gh secret set "$name" --repo "$REPOSITORY" --env "$ENVIRONMENT"
  printf 'Secret gesetzt: %s\n' "$name"
}

set_secret "DB_PASSWORD" "$(read_dotenv_value "DB_PASSWORD")"

# Der Host-Pull-Token ist verpflichtend und soll nur Leserechte auf GHCR haben.
set_secret "KAMAL_REGISTRY_PULL_PASSWORD" "$(read_dotenv_value "KAMAL_REGISTRY_PULL_PASSWORD")"

set_secret "RAILS_MASTER_KEY" "$(tr -d '\r\n' < "$MASTER_KEY_FILE")"
set_secret "KAMAL_SSH_PRIVATE_KEY" "$(read_file_value "$SSH_PRIVATE_KEY_FILE")"
