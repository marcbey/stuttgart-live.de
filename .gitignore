# Legacy snapshot (kept outside current app codebase)
/legacy/

# Environment and secrets
/.env
/.env.*
!/.env.example
/config/master.key
/config/credentials/*.key
/META.md

# OS / Editor
.DS_Store
*.swp
*.swo
/.idea/
/.vscode/
/.ruby-lsp/

# Ruby / Bundler
/.bundle/
/vendor/bundle
.byebug_history

# JavaScript dependencies and logs
/node_modules
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Rails runtime and generated files
/log/*
!/log/.keep
/.workflow-support/
/tmp/*
!/tmp/.keep
!/tmp/pids/
!/tmp/pids/.keep
/tmp/pids/*.pid
!/tmp/storage/
/tmp/storage/*
!/tmp/storage/*/
/tmp/storage/**/*
!/tmp/storage/.keep
/storage/*
!/storage/.keep
/public/assets
/public/packs
/public/packs-test
/public/system

# JS/CSS build outputs
/app/assets/builds/*
!/app/assets/builds/.keep

# Coverage
/coverage/

# Terraform
**/.terraform/*
*.tfstate
*.tfstate.*
crash.log
crash.*.log
*.auto.tfvars
*.auto.tfvars.json
terraform.tfvars
backend.hcl

# Kamal environment-specific secrets
/.kamal/secrets.*
!/.kamal/*.example
skills-lock.json
.agents
!.agents/
.agents/*
!.agents/skills/
!.agents/skills/**
test/locust/__pycache__/*
.playwright-mcp/**
openwebninja-*.png
