<% content_for :title, "Stuttgart Live - Kontakt" %>

<section class="info-page-shell">
  <div class="info-page-hero">
    <p class="news-kicker">Kontakt</p>
    <h1>Kontakt</h1>
    <p>
      Direkte Ansprechpartner für Bestellungen, Presse und Veranstaltungsnews.
    </p>
  </div>

  <div class="info-page-grid">
    <section class="info-page-card">
      <h2>Bestell-Hotline</h2>
      <dl class="info-page-list">
        <div>
          <dt>Telefon</dt>
          <dd><a href="tel:+4971155066077">0711 – 550 660 77</a></dd>
        </div>
        <div>
          <dt>Mailorder</dt>
          <dd><a href="mailto:info@stuttgart-live.de">info@stuttgart-live.de</a></dd>
        </div>
      </dl>
    </section>

    <section class="info-page-card">
      <h2>Pressekontakt</h2>
      <dl class="info-page-list">
        <div>
          <dt>Ansprechpartner</dt>
          <dd>Arnulf Woock</dd>
        </div>
        <div>
          <dt>Adresse</dt>
          <dd>Charlottenplatz 17, 70173 Stuttgart</dd>
        </div>
        <div>
          <dt>Fon</dt>
          <dd><a href="tel:+497111635320">+49 (0) 711 16 353 20</a></dd>
        </div>
        <div>
          <dt>Mail</dt>
          <dd><a href="mailto:arnulfwoock@russ-live.de">arnulfwoock@russ-live.de</a></dd>
        </div>
      </dl>
    </section>

    <section class="info-page-card info-page-card-wide">
      <h2>Veranstaltungsnews</h2>
      <p>
        Bitte schicken Sie Ihre Veranstaltungs- und Pressenews an
        <a href="mailto:news@stuttgart-live.de">news@stuttgart-live.de</a>.
      </p>
    </section>

    <section class="info-page-card info-page-card-wide">
      <h2>Folge uns online</h2>
      <div class="info-page-links">
        <%= link_to "Facebook", "https://www.facebook.com/stuttgartlive", target: "_blank", rel: "noopener" %>
        <%= link_to "Instagram", "https://www.instagram.com/stuttgartlive/", target: "_blank", rel: "noopener" %>
        <%= link_to "TikTok", "https://www.tiktok.com/@stuttgartlive", target: "_blank", rel: "noopener" %>
      </div>
    </section>
  </div>
</section>
