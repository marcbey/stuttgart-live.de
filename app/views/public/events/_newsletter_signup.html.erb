<section class="newsletter-signup-section" aria-labelledby="newsletter-signup-title">
  <div class="newsletter-signup-glow" aria-hidden="true"></div>
  <div class="newsletter-signup-motion" aria-hidden="true">
    <span class="newsletter-signup-particle newsletter-signup-particle-1"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-2"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-3"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-4"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-5"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-6"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-7"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-8"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-9"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-10"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-11"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-12"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-13"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-14"></span>
    <span class="newsletter-signup-particle newsletter-signup-particle-15"></span>
  </div>
  <div class="newsletter-signup-inner">
    <div class="newsletter-signup-copy">
      <h2 id="newsletter-signup-title">Nichts verpassen</h2>
      <p class="newsletter-signup-lead">Neue Konzerte, Highlights und Vorverkäufe landen direkt in deinem Postfach.</p>

      <ul class="newsletter-signup-highlights" aria-label="Vorteile des Newsletters">
        <li>Frische Konzerttipps aus Stuttgart</li>
        <li>Highlights und redaktionelle Empfehlungen</li>
        <li>Schnell, kompakt und ohne Feed-Chaos</li>
      </ul>
    </div>

    <div class="newsletter-signup-panel">
      <p class="newsletter-signup-panel-kicker">Direkt in deine Inbox</p>

      <%= render "public/newsletter_subscribers/signup",
                 subscriber: NewsletterSubscriber.new,
                 signup: newsletter_signup_config("events_index", return_to: request.fullpath) %>

      <p class="newsletter-signup-note">Nur die wichtigsten Updates. Kein täglicher Spam.</p>
    </div>
  </div>
</section>
