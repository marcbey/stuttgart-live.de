<% signup = local_assigns[:signup] || newsletter_signup_config("events_index", return_to: request.fullpath) %>
<% subscriber = local_assigns[:subscriber] || NewsletterSubscriber.new %>
<% section_id = local_assigns[:section_id] %>

<section class="newsletter-signup-section" <%= %(id="#{section_id}") if section_id.present? %> aria-labelledby="newsletter-signup-title">
  <div class="slider-window-bar newsletter-signup-window-bar" aria-hidden="true">
    <span></span><span></span><span></span>
  </div>
  <div class="newsletter-signup-inner">
    <div class="newsletter-signup-copy">
      <div class="newsletter-signup-copy-intro">
        <h2 id="newsletter-signup-title">Nichts verpassen</h2>
      </div>

      <ul class="newsletter-signup-highlights" aria-label="Vorteile des Newsletters">
        <li>Stuttgarts beste Konzerttipps</li>
        <li>Highlights. Redaktionell sortiert.</li>
        <li>Kurz. Direkt. Ohne Feed-Chaos.</li>
      </ul>
    </div>

    <div class="newsletter-signup-panel">
      <div class="newsletter-signup-panel-content">
        <p class="newsletter-signup-lead">Konzerte, Highlights und Vorverkäufe. Direkt im Postfach.</p>

        <%= render "public/newsletter_subscribers/signup",
                   subscriber: subscriber,
                   signup: signup %>

        <p class="newsletter-signup-note">Nur die wichtigsten Updates. Kein täglicher Spam.</p>
      </div>
    </div>
  </div>
</section>
