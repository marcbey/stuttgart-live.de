<section class="public-filter-row public-filter-row-home">
  <div class="public-filter-row-main">
    <%= form_with url: events_path, method: :get, local: true, class: "public-search-filter" do %>
      <%= hidden_field_tag :event_date, browse_state.event_date_param %>
      <div class="public-search-field">
        <%= text_field_tag :q,
                           browse_state.query,
                           class: "form-input public-search-input",
                           placeholder: "Suche nach Künstlern und Events",
                           aria: { label: "Events durchsuchen" },
                           oninput: "this.nextElementSibling.classList.toggle('public-search-clear-visible', this.value.length > 0)" %>
        <%= button_tag "×",
                       type: "button",
                       class: "public-search-clear #{'public-search-clear-visible' if browse_state.query.present?}",
                       aria: { label: "Suche löschen" },
                       onclick: "this.previousElementSibling.value=''; this.classList.remove('public-search-clear-visible'); this.form.requestSubmit();" %>
        <%= button_tag "⌕",
                       type: "submit",
                       class: "public-search-icon",
                       aria: { label: "Suche ausführen" } %>
      </div>
    <% end %>
  </div>
</section>
