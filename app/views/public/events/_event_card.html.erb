<% card_slot = local_assigns.fetch(:card_slot, :grid_default) %>
<% desktop_image_url = event.image_url_for(slot: card_slot, breakpoint: :desktop) %>
<% mobile_image_url = event.image_url_for(slot: :grid_default, breakpoint: :mobile) || desktop_image_url %>

<article class="event-card">
  <%= link_to event_path(event.slug), class: "event-card-link" do %>
    <div class="event-card-image-wrap">
      <% if desktop_image_url.present? %>
        <picture>
          <% if mobile_image_url.present? %>
            <source media="(max-width: 699px)" srcset="<%= mobile_image_url %>">
          <% end %>
          <%= image_tag desktop_image_url, alt: "#{event.artist_name} - #{event.title}", loading: "lazy", class: "event-card-image" %>
        </picture>
      <% else %>
        <div class="event-card-image event-card-placeholder"></div>
      <% end %>
      <div class="event-card-overlay"></div>
      <% if event.badge_text.present? %>
        <span class="event-card-badge"><%= event.badge_text %></span>
      <% end %>
      <div class="event-card-copy">
        <h2><%= event.artist_name %></h2>
        <p class="event-card-title"><%= event.title %></p>
        <p class="event-card-meta">
          <span><%= l(event.start_at.to_date, format: "%d.%m.%Y") %></span>
          <span><%= event.venue %></span>
        </p>
        <% if event.primary_genre.present? %>
          <p class="event-card-genre"><%= event.primary_genre.name %></p>
        <% end %>
      </div>
    </div>
  <% end %>
</article>
