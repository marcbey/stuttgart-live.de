<% card_slot = local_assigns.fetch(:card_slot, :grid_default) %>
<% tile_variant = local_assigns.fetch(:tile_variant, Event::GRID_VARIANT_BY_SLOT[card_slot.to_sym] || EventImage::GRID_VARIANT_1X1) %>
<% public_filter = local_assigns.fetch(:public_filter, params[:filter].to_s.presence || "sks") %>
<% public_event_date = local_assigns.fetch(:public_event_date, params[:event_date].to_s.presence) %>
<% desktop_image = event.image_for(slot: card_slot, breakpoint: :desktop) %>
<% mobile_image = event.image_for(slot: :grid_default, breakpoint: :mobile) || desktop_image %>
<% desktop_image_source = event_image_source(desktop_image) %>
<% mobile_image_source = event_image_source(mobile_image) %>
<% image_alt_text = event_image_alt(desktop_image, event) %>
<% source_label = event_source_label(event.primary_source.presence || event.primary_offer&.source).presence %>
<% has_top_overlay = source_label.present? || authenticated? %>
<% image_style = event_card_image_style(desktop_image) %>

<article id="<%= dom_id(event, :card) %>" class="event-card event-card-grid-<%= tile_variant.tr("x", "-") %>">
  <div class="event-card-image-wrap">
    <%= link_to event_path(event.slug, filter: public_filter, event_date: public_event_date), class: "event-card-link" do %>
      <% if desktop_image_source.present? %>
        <picture>
          <% if mobile_image_source.present? %>
            <source media="(max-width: 699px)" srcset="<%= mobile_image_source %>">
          <% end %>
          <%= image_tag desktop_image_source, alt: image_alt_text, loading: "lazy", class: "event-card-image", style: image_style %>
        </picture>
      <% else %>
        <div class="event-card-image event-card-placeholder"></div>
      <% end %>
      <div class="event-card-overlay"></div>
      <% if event.badge_text.present? %>
        <span class="event-card-badge <%= "event-card-badge-with-top-overlay" if has_top_overlay %>"><%= event.badge_text %></span>
      <% end %>
      <div class="event-card-copy">
        <h2><%= event.artist_name %></h2>
        <p class="event-card-title"><%= event.title %></p>
        <p class="event-card-meta">
          <span><%= l(event.start_at.to_date, format: "%d.%m.%Y") %></span>
          <span><%= event.venue %></span>
        </p>
        <% if event.primary_genre.present? %>
          <p class="event-card-genre"><%= event.primary_genre.name %></p>
        <% end %>
      </div>
    <% end %>

    <% if has_top_overlay %>
      <div class="event-card-top-left-overlay">
        <% if source_label.present? %>
          <span class="event-card-source-chip"><%= source_label %></span>
        <% end %>

        <% if authenticated? %>
          <%= link_to "Backend",
                      backend_events_path(status: event.status, event_id: event.id),
                      class: "event-card-admin-link",
                      data: { turbo: false } %>
        <% end %>
      </div>
    <% end %>

    <% if authenticated? %>
      <div class="event-card-status-overlay">
        <%= form_with url: status_event_path(event.slug),
                      method: :patch,
                      class: "event-card-status-form",
                      data: { controller: "public-card-status" } do |form| %>
          <%= hidden_field_tag :card_slot, card_slot %>
          <%= hidden_field_tag :page, params[:page].presence || 1 %>
          <%= hidden_field_tag :filter, public_filter %>
          <%= hidden_field_tag :event_date, public_event_date %>
          <%= form.select :status,
                          options_for_select(public_event_status_options, event.status),
                          {},
                          class: "event-card-status-select",
                          data: {
                            public_card_status_target: "select",
                            action: "change->public-card-status#change"
                          } %>
          <noscript>
            <%= form.submit "Ok", class: "event-card-status-submit" %>
          </noscript>
        <% end %>
      </div>
    <% end %>
  </div>
</article>
