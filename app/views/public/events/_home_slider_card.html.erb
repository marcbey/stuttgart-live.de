<% public_filter = local_assigns.fetch(:public_filter, params[:filter].to_s.presence || "sks") %>
<% public_query = local_assigns.fetch(:public_query, params[:q].to_s.presence) %>
<% public_event_date = local_assigns.fetch(:public_event_date, params[:event_date].to_s.presence) %>
<% primary_offer = event.preferred_ticket_offer %>
<% desktop_image = event.image_for(slot: :grid_default, breakpoint: :desktop) %>
<% mobile_image = desktop_image.is_a?(EventImage) ? desktop_image : (event.image_for(slot: :grid_default, breakpoint: :mobile) || desktop_image) %>
<% desktop_image_source = event_image_source(desktop_image) %>
<% mobile_image_source = event_image_source(mobile_image) %>
<% image_alt_text = event_image_alt(desktop_image, event) %>
<% image_style = event_card_image_style(desktop_image) %>

<article class="home-slider-card">
  <%= link_to event_path(event.slug, filter: public_filter, event_date: public_event_date, q: public_query), class: "home-slider-card-thumb" do %>
    <% if desktop_image_source.present? %>
      <picture>
        <% if mobile_image_source.present? %>
          <source media="(max-width: 699px)" srcset="<%= mobile_image_source %>">
        <% end %>
        <%= image_tag desktop_image_source, alt: image_alt_text, loading: "lazy", class: "home-slider-card-image", style: image_style %>
      </picture>
    <% else %>
      <div class="home-slider-card-image event-card-placeholder"></div>
    <% end %>
  <% end %>

  <div class="home-slider-card-copy">
    <%= link_to event.artist_name, event_path(event.slug, filter: public_filter, event_date: public_event_date, q: public_query), class: "home-slider-card-name" %>
    <% if event.title.present? %>
      <p class="home-slider-card-title"><%= event.title %></p>
    <% end %>
    <p class="home-slider-card-meta">
      <span><%= l(event.start_at.to_date, format: "%d.%m.%Y") %></span>
      <% if event.venue.present? %>
        <span><%= event.venue %></span>
      <% end %>
    </p>
  </div>
</article>
