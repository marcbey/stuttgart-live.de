<% browse_state = local_assigns.fetch(:browse_state) %>
<% strict_proxy = local_assigns.fetch(:strict_proxy, false) %>
<% desktop_image = event.image_for(slot: :grid_default, breakpoint: :desktop) %>
<% mobile_image = desktop_image.is_a?(EventImage) ? desktop_image : (event.image_for(slot: :grid_default, breakpoint: :mobile) || desktop_image) %>
<% desktop_image_source = event_image_source(desktop_image, strict_proxy: strict_proxy) %>
<% mobile_image_source = event_image_source(mobile_image, strict_proxy: strict_proxy) %>
<% image_alt_text = event_image_alt(desktop_image, event) %>
<% image_style = event_card_image_style(desktop_image) %>
<% effective_series_ids = local_assigns[:effective_series_ids] %>
<% primary_offer = event.public_ticket_offer %>
<% sold_out = event.public_sold_out? %>

<article class="home-slider-card">
  <div class="home-slider-card-media">
    <%= render "public/events/saved_event_button", event: event %>
    <%= link_to public_event_detail_path(event, browse_state), class: "home-slider-card-thumb" do %>
      <% if desktop_image_source.present? %>
        <picture>
          <% if mobile_image_source.present? %>
            <source media="(max-width: 699px)" srcset="<%= mobile_image_source %>">
          <% end %>
          <%= image_tag desktop_image_source, alt: image_alt_text, loading: "lazy", class: "home-slider-card-image", style: image_style %>
        </picture>
      <% else %>
        <div class="home-slider-card-image event-card-placeholder"></div>
      <% end %>
      <% unless sold_out %>
        <span class="home-slider-card-ticket-overlay" aria-hidden="true">
          <span class="home-slider-card-ticket-arrow">↓</span>
          <span class="home-slider-card-ticket-label">TICKETS</span>
        </span>
      <% end %>
      <% if sold_out %>
        <%= render "sold_out_corner_ribbon" %>
      <% end %>
      <% if event.badge_text.present? %>
        <span class="event-card-badge event-card-badge-home-slider"><%= event.badge_text %></span>
      <% end %>
    <% end %>

    <% if authenticated? %>
      <div class="event-card-admin-controls home-slider-card-admin-controls">
        <%= link_to "Edit",
                    backend_events_path(status: event.status, event_id: event.id),
                    class: "event-card-admin-link event-card-admin-link-attention",
                    data: { turbo: false } %>

        <% if event.primary_source.present? %>
          <span class="status-badge event-card-admin-link"><%= event_source_label(event.primary_source) %></span>
        <% end %>
      </div>
    <% end %>
    <% if public_event_series_effective?(event, effective_series_ids: effective_series_ids) %>
      <%= render "event_series_corner_badge" %>
    <% end %>
  </div>

  <div class="home-slider-card-copy">
    <div class="event-listing-body">
      <p class="event-listing-date">
        <span class="event-listing-date-value"><%= l(event.start_at.to_date, format: "%d.%m.%Y") %></span>
        <% if event.venue.present? %>
          <span class="event-listing-venue"><%= event.venue %></span>
        <% end %>
      </p>
      <div class="event-listing-link">
        <strong><%= event.artist_name %></strong>
        <% if event.title.present? %>
          <span><%= event.title %></span>
        <% end %>
      </div>
    </div>
    <% if (display_price = public_event_ticket_price(event, primary_offer)).present? %>
      <p class="home-slider-card-price event-listing-price"><%= display_price %></p>
    <% end %>
  </div>
</article>
