<% browse_state = local_assigns.fetch(:browse_state) %>
<% desktop_image = event.image_for(slot: :grid_default, breakpoint: :desktop) %>
<% mobile_image = desktop_image.is_a?(EventImage) ? desktop_image : (event.image_for(slot: :grid_default, breakpoint: :mobile) || desktop_image) %>
<% desktop_image_source = event_image_source(desktop_image) %>
<% mobile_image_source = event_image_source(mobile_image) %>
<% image_alt_text = event_image_alt(desktop_image, event) %>
<% image_style = event_card_image_style(desktop_image) %>
<% card_variant = local_assigns[:card_variant] %>
<% effective_series_ids = local_assigns[:effective_series_ids] %>
<% show_series_badge = local_assigns.fetch(:show_series_badge, true) %>
<% primary_offer = event.public_ticket_offer %>
<% card_dom_id = local_assigns[:card_dom_id] %>
<% article_attributes = { class: ["genre-lane-card", ("genre-lane-card--#{card_variant}" if card_variant.present?)].compact.join(" ") } %>
<% article_attributes[:id] = card_dom_id if card_dom_id.present? %>
<% sold_out = event.public_sold_out? %>

<article <%= tag.attributes(article_attributes) %>>
  <%= render "public/events/saved_event_button", event: event %>
  <%= link_to public_event_detail_path(event, browse_state), class: ["genre-lane-card-link", ("genre-lane-card-link--#{card_variant}" if card_variant.present?)].compact.join(" ") do %>
    <div class="<%= ["genre-lane-card-media", ("genre-lane-card-media--#{card_variant}" if card_variant.present?)].compact.join(" ") %>">
      <% if desktop_image_source.present? %>
        <picture>
          <% if mobile_image_source.present? %>
            <source media="(max-width: 699px)" srcset="<%= mobile_image_source %>">
          <% end %>
          <%= image_tag desktop_image_source, alt: image_alt_text, loading: "lazy", class: "genre-lane-card-image", style: image_style %>
        </picture>
      <% else %>
        <div class="genre-lane-card-image event-card-placeholder"></div>
      <% end %>
      <% unless sold_out %>
        <span class="genre-lane-card-ticket-overlay" aria-hidden="true">
          <span class="genre-lane-card-ticket-arrow">↓</span>
          <span class="genre-lane-card-ticket-label">TICKETS</span>
        </span>
      <% end %>
      <% if sold_out %>
        <%= render "sold_out_corner_ribbon" %>
      <% end %>
      <% if show_series_badge && public_event_series_effective?(event, effective_series_ids: effective_series_ids) %>
        <%= render "event_series_corner_badge" %>
      <% end %>
    </div>

    <div class="<%= ["genre-lane-card-copy", ("genre-lane-card-copy--#{card_variant}" if card_variant.present?)].compact.join(" ") %>">
      <% if event.badge_text.present? %>
        <span class="event-card-badge event-card-badge-genre-lane"><%= event.badge_text %></span>
      <% end %>
      <div class="event-listing-body">
        <p class="event-listing-date">
          <span class="event-listing-date-value"><%= l(event.start_at.to_date, format: "%d.%m.%Y") %></span>
          <% if event.venue.present? %>
            <span class="event-listing-venue"><%= event.venue %></span>
          <% end %>
        </p>
        <div class="event-listing-link">
          <strong class="genre-lane-card-name"><%= event.artist_name %></strong>
          <% if event.title.present? %>
            <span><%= event.title %></span>
          <% end %>
        </div>
      </div>
      <% if (display_price = public_event_ticket_price(event, primary_offer)).present? %>
        <p class="genre-lane-card-price event-listing-price"><%= display_price %></p>
      <% end %>
    </div>
  <% end %>
  <% if authenticated? %>
    <div class="event-card-admin-controls genre-lane-card-admin-controls">
      <%= link_to "Edit",
                  backend_events_path(status: event.status, event_id: event.id),
                  class: "event-card-admin-link event-card-admin-link-attention",
                  data: { turbo: false } %>

      <% if event.primary_source.present? %>
        <span class="status-badge event-card-admin-link"><%= event_source_label(event.primary_source) %></span>
      <% end %>
    </div>
  <% end %>
</article>
