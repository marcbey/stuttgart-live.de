<header class="<%= presenter.header_classes %>">
  <div class="event-detail-header-panel">
    <div class="event-detail-header-copy">
      <div class="event-detail-header-intro">
        <% if presenter.show_distinct_title? %>
          <p class="event-detail-title"><%= presenter.title_line %></p>
        <% end %>
        <h1><%= presenter.display_headline %></h1>
        <% if presenter.support_text.present? %>
          <p class="event-detail-support-line">Support: <%= presenter.support_text %></p>
        <% end %>
        <% if presenter.hero_meta_line.present? %>
          <p class="event-detail-meta-line"><%= presenter.hero_meta_line %></p>
        <% end %>
        <% if presenter.hero_time_line.present? %>
          <p class="event-detail-time-line"><%= presenter.hero_time_line %></p>
        <% end %>
        <% if authenticated? %>
          <% visibility_badges = presenter.visibility_badges %>
          <% if visibility_badges.any? %>
            <div class="event-detail-badges-row">
              <% visibility_badges.each do |badge| %>
                <span class="status-badge <%= badge[:css_class] %>"><%= badge[:label] %></span>
              <% end %>
            </div>
          <% end %>
        <% end %>
      </div>

      <% if presenter.genre_tags.any? %>
        <div class="event-detail-tags" aria-label="Genres">
          <% presenter.genre_tags.each do |genre| %>
            <span class="event-detail-tag"><%= genre %></span>
          <% end %>
        </div>
      <% end %>

    </div>

    <%= render "show_ticket_cta", presenter: presenter %>
  </div>

  <% if presenter.has_hero_gallery? %>
    <% hero_slides = presenter.hero_gallery_slides %>
    <% hero_stage_style_parts = [] %>
    <% if presenter.hero_stage_aspect_ratio.present? %>
      <% hero_stage_style_parts << "--event-detail-image-stage-ratio: #{presenter.hero_stage_aspect_ratio}" %>
    <% end %>
    <% if presenter.hero_stage_max_width.present? %>
      <% hero_stage_style_parts << "--event-detail-image-stage-max-width: #{presenter.hero_stage_max_width}" %>
    <% end %>
    <% hero_stage_style = hero_stage_style_parts.join("; ").presence %>
    <div class="event-detail-image-wrap">
      <% if presenter.hero_gallery_rotates? %>
        <div class="event-detail-image-figure event-detail-image-figure-rotator"
             <%= %(style="#{hero_stage_style}") if hero_stage_style.present? %>
             data-controller="hero-rotator lightbox"
             data-hero-rotator-delay-value="3000"
             data-hero-rotator-interval-value="5000">
          <div class="event-detail-image-stage-shell highlights-slider-viewport">
            <div class="event-detail-image-stage"
                 data-hero-rotator-target="stage">
              <% hero_slides.each_with_index do |slide, index| %>
                <button type="button"
                        class="event-detail-image-slide"
                        data-hero-rotator-target="slide"
                        data-lightbox-target="item"
                        data-action="click->lightbox#open"
                        data-lightbox-src-value="<%= slide.lightbox_source %>"
                        data-lightbox-alt-value="<%= slide.alt_text %>"
                        data-lightbox-caption-value="<%= slide.caption %>"
                        data-hero-rotator-caption="<%= slide.caption %>"
                        data-hero-rotator-credit="<%= slide.credit %>"
                        aria-label="<%= "Bild #{index + 1} von #{hero_slides.size} vergrößern" %>"
                        <%= "hidden" if index.positive? %>>
                  <span class="event-detail-image-stage-glow" aria-hidden="true"></span>
                  <span class="event-detail-image-backdrop" aria-hidden="true">
                    <%= image_tag slide.desktop_source, alt: "", class: "event-detail-image-backdrop-image" %>
                  </span>
                  <picture class="event-detail-image-picture">
                    <% if slide.mobile_source.present? && slide.mobile_source != slide.desktop_source %>
                      <source media="(max-width: 699px)" srcset="<%= slide.mobile_source %>">
                    <% end %>
                    <%= image_tag slide.desktop_source, alt: slide.alt_text, class: "event-detail-image" %>
                  </picture>
                </button>
              <% end %>
            </div>

            <button type="button"
                    class="highlights-slider-arrow highlights-slider-arrow-overlay highlights-slider-arrow-prev"
                    data-hero-rotator-target="previousButton"
                    data-action="hero-rotator#previous"
                    aria-label="Zurück">
              ‹
            </button>
            <button type="button"
                    class="highlights-slider-arrow highlights-slider-arrow-overlay highlights-slider-arrow-next"
                    data-hero-rotator-target="nextButton"
                    data-action="hero-rotator#next"
                    aria-label="Weiter">
              ›
            </button>
            <% if presenter.show_ticket_panel? && presenter.ticket_badge_text.present? %>
              <p class="event-detail-image-badge"><%= presenter.ticket_badge_text %></p>
            <% end %>
          </div>

          <div class="event-detail-image-meta">
            <div class="event-detail-image-dots" aria-label="Bildauswahl">
              <% hero_slides.each_with_index do |_slide, index| %>
                <button type="button"
                        class="event-detail-image-dot"
                        data-hero-rotator-target="dot"
                        data-hero-rotator-index-param="<%= index %>"
                        data-action="hero-rotator#select"
                        aria-label="<%= "Bild #{index + 1} anzeigen" %>"
                        aria-current="<%= index.zero? %>">
                </button>
              <% end %>
            </div>
            <p class="event-detail-image-caption" data-hero-rotator-target="caption" hidden></p>
            <p class="event-detail-image-credit" data-hero-rotator-target="credit" hidden></p>
          </div>

          <div class="event-lightbox"
               data-lightbox-target="dialog"
               data-action="click->lightbox#backdropClose"
               role="dialog"
               aria-modal="true"
               aria-label="Bildansicht"
               tabindex="-1"
               hidden>
            <button type="button"
                    class="event-lightbox-nav event-lightbox-nav-prev highlights-slider-arrow highlights-slider-arrow-overlay highlights-slider-arrow-prev"
                    data-lightbox-target="previousButton"
                    data-action="click->lightbox#previous"
                    aria-label="Vorheriges Bild">‹</button>
            <button type="button"
                    class="event-lightbox-nav event-lightbox-nav-next highlights-slider-arrow highlights-slider-arrow-overlay highlights-slider-arrow-next"
                    data-lightbox-target="nextButton"
                    data-action="click->lightbox#next"
                    aria-label="Nächstes Bild">›</button>
            <button type="button" class="event-lightbox-close" data-lightbox-target="closeButton" data-action="click->lightbox#close" aria-label="Lightbox schließen">×</button>
            <div class="event-lightbox-inner">
              <img src="" alt="" class="event-lightbox-image" data-lightbox-target="image">
              <p class="event-lightbox-caption" data-lightbox-target="caption" hidden></p>
            </div>
          </div>
        </div>
      <% else %>
        <% slide = hero_slides.first %>
        <div class="event-detail-image-figure"<%= %( style="#{hero_stage_style}") if hero_stage_style.present? %>>
          <div class="event-detail-image-stage-shell">
            <div class="event-detail-image-stage event-detail-image-stage-static">
              <span class="event-detail-image-stage-glow" aria-hidden="true"></span>
              <span class="event-detail-image-backdrop" aria-hidden="true">
                <%= image_tag slide.desktop_source, alt: "", class: "event-detail-image-backdrop-image" %>
              </span>
              <picture class="event-detail-image-picture">
                <% if slide.mobile_source.present? && slide.mobile_source != slide.desktop_source %>
                  <source media="(max-width: 699px)" srcset="<%= slide.mobile_source %>">
                <% end %>
                <%= image_tag slide.desktop_source, alt: slide.alt_text, class: "event-detail-image" %>
              </picture>
            </div>
            <% if presenter.show_ticket_panel? && presenter.ticket_badge_text.present? %>
              <p class="event-detail-image-badge"><%= presenter.ticket_badge_text %></p>
            <% end %>
          </div>
          <% if presenter.hero_image_credit.present? %>
            <p class="event-detail-image-credit"><%= presenter.hero_image_credit %></p>
          <% end %>
        </div>
      <% end %>
    </div>
  <% end %>
</header>
