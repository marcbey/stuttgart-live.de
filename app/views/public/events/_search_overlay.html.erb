<% if query.present? %>
  <% if events.any? %>
    <div class="public-search-overlay-summary">
      <p class="public-search-overlay-eyebrow">Live-Suche</p>
      <p class="public-search-overlay-count"><%= events.size %> passende zukünftige Events</p>
    </div>

    <ul class="public-search-overlay-list" role="list">
      <% events.each do |event| %>
        <li>
          <%= render "search_overlay_event", event: event, browse_state: browse_state %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="public-search-overlay-empty">
      <h2>Keine Treffer</h2>
      <p>Für „<%= query %>“ wurden aktuell keine zukünftigen Events gefunden.</p>
    </div>
  <% end %>
<% else %>
  <% if events.any? %>
    <div class="public-search-overlay-summary">
      <h2>Unsere Highlights</h2>
    </div>

    <ul class="public-search-overlay-list" role="list">
      <% events.each do |event| %>
        <li>
          <%= render "search_overlay_event", event: event, browse_state: browse_state %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="public-search-overlay-empty">
      <h2>Unsere Highlights</h2>
      <p>Aktuell sind keine hervorgehobenen Events verfügbar.</p>
    </div>
  <% end %>
<% end %>
