<% container_id = local_assigns[:container_id] %>
<% container_class = local_assigns.fetch(:container_class, "flyer-grid") %>
<% offset = local_assigns.fetch(:offset, 0) %>
<% card_dom_id_prefix = local_assigns[:card_dom_id_prefix] %>
<% wrap = local_assigns.fetch(:wrap, true) %>

<% if wrap && container_id.present? %>
  <div id="<%= container_id %>" class="<%= container_class %>">
<% elsif wrap %>
  <div class="<%= container_class %>">
<% end %>
  <% events.each_with_index do |event, index| %>
    <% absolute_index = offset + index %>
    <% tile_variant = effective_public_grid_variant_for(event, absolute_index) %>
    <% card_slot = card_slot_for_grid_variant(tile_variant) %>
    <%= render "event_card",
               event: event,
               browse_state: browse_state,
               tile_variant: tile_variant,
               card_slot: card_slot,
               card_dom_id: (card_dom_id_prefix.present? ? dom_id(event, card_dom_id_prefix) : nil) %>
  <% end %>
<% if wrap %>
  </div>
<% end %>
