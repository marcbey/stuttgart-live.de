<section class="partner-strip-section" aria-label="Partner">
  <div class="partner-strip"
       data-controller="partner-strip"
       data-partner-strip-interval-value="3200"
       data-partner-strip-mobile-max-width-value="699">
    <a href="https://www.russ-live.de" target="_blank" rel="noopener" class="partner-strip-logo partner-strip-logo-russlive" aria-label="Russ Live" data-partner-strip-target="logo">
      <%= image_tag "russ-live-logo.svg", alt: "Russ Live", class: "partner-strip-image partner-strip-image-russlive" %>
    </a>
    <a href="https://www.russ-klassik.de" target="_blank" rel="noopener" class="partner-strip-logo partner-strip-logo-russklassik" aria-label="Russ Klassik" data-partner-strip-target="logo">
      <%= image_tag "russ-klassik-logo.svg", alt: "Russ Klassik", class: "partner-strip-image partner-strip-image-russklassik" %>
    </a>
    <a href="https://www.easyticket.de" target="_blank" rel="noopener" class="partner-strip-logo partner-strip-logo-easyticket" aria-label="Easy Ticket" data-partner-strip-target="logo">
      <%= image_tag "easyticket-logo.svg", alt: "Easy Ticket", class: "partner-strip-image partner-strip-image-easyticket" %>
    </a>
    <a href="https://www.eventim.de" target="_blank" rel="noopener" class="partner-strip-logo partner-strip-logo-eventim" aria-label="eventim" data-partner-strip-target="logo">
      <%= image_tag "eventim-logo.svg", alt: "eventim", class: "partner-strip-image partner-strip-image-eventim" %>
    </a>
    <a href="https://www.reservix.de" target="_blank" rel="noopener" class="partner-strip-logo partner-strip-logo-reservix" aria-label="Reservix" data-partner-strip-target="logo">
      <%= image_tag "reservix-logo.svg", alt: "Reservix", class: "partner-strip-image partner-strip-image-reservix" %>
    </a>
    <a href="https://www.musiccircus.de" target="_blank" rel="noopener" class="partner-strip-logo partner-strip-logo-musiccircus" aria-label="MusicCircus" data-partner-strip-target="logo">
      <%= image_tag "musiccircus-logo.svg", alt: "MusicCircus", class: "partner-strip-image partner-strip-image-musiccircus" %>
    </a>
  </div>
</section>
