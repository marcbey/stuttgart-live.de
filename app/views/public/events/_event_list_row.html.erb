<% public_filter = local_assigns.fetch(:public_filter, params[:filter].to_s.presence || "sks") %>
<% public_view = local_assigns.fetch(:public_view, params[:view].to_s.presence || "grid") %>
<% public_event_date = local_assigns.fetch(:public_event_date, params[:event_date].to_s.presence) %>
<% public_query = local_assigns.fetch(:public_query, params[:q].to_s.presence) %>
<% primary_offer = event.preferred_ticket_offer %>
<% thumbnail_image = event.image_for(slot: :grid_default, breakpoint: :mobile) || event.image_for(slot: :grid_default, breakpoint: :desktop) %>
<% thumbnail_source = event_image_source(thumbnail_image) %>

<article class="event-listing-card">
  <% if thumbnail_source.present? %>
    <%= link_to event_path(event.slug, filter: public_filter, view: (public_view == "list" ? public_view : nil), event_date: public_event_date, q: public_query), class: "event-listing-thumb-link" do %>
      <%= image_tag thumbnail_source, alt: event_image_alt(thumbnail_image, event), loading: "lazy", class: "event-listing-thumb-image" %>
    <% end %>
  <% end %>

  <div class="event-listing-body">
    <%= link_to event_path(event.slug, filter: public_filter, view: (public_view == "list" ? public_view : nil), event_date: public_event_date, q: public_query), class: "event-listing-link" do %>
      <strong><%= event.artist_name %></strong>
      <% if event.title.present? %>
        <span> - <%= event.title %></span>
      <% end %>
    <% end %>

    <p class="event-listing-meta">
      <span class="event-listing-date"><%= l(event.start_at.to_date, format: "%d.%m.%Y") %></span>
      <% if event.venue.present? %>
        <span class="event-listing-meta-separator">·</span>
        <span class="event-listing-location"><%= event.venue %></span>
      <% end %>
    </p>

    <% if primary_offer.present? %>
      <div class="event-listing-ticket">
        <%= link_to "Tickets",
                    primary_offer.resolved_ticket_url,
                    target: "_blank",
                    rel: "noopener",
                    class: "button event-listing-ticket-button",
                    data: { turbo: false } %>
      </div>
    <% end %>
  </div>
</article>
