<% public_filter = local_assigns.fetch(:public_filter, params[:filter].to_s.presence || "sks") %>
<% public_view = local_assigns.fetch(:public_view, params[:view].to_s.presence || "grid") %>
<% public_event_date = local_assigns.fetch(:public_event_date, params[:event_date].to_s.presence) %>
<% public_query = local_assigns.fetch(:public_query, params[:q].to_s.presence) %>
<% primary_offer = event.preferred_ticket_offer %>

<tr class="event-listing-row">
  <td class="event-listing-date">
    <%= l(event.start_at.to_date, format: "%d.%m.%Y") %>
  </td>
  <td class="event-listing-main">
    <%= link_to event_path(event.slug, filter: public_filter, view: (public_view == "list" ? public_view : nil), event_date: public_event_date, q: public_query), class: "event-listing-link" do %>
      <strong><%= event.artist_name %></strong>
      <span><%= event.title %></span>
    <% end %>
  </td>
  <td class="event-listing-location">
    <%= [event.venue, event.city].compact.join(", ") %>
  </td>
  <td class="event-listing-ticket">
    <% if primary_offer.present? %>
      <%= link_to "Tickets",
                  primary_offer.resolved_ticket_url,
                  target: "_blank",
                  rel: "noopener",
                  class: "button event-listing-ticket-button",
                  data: { turbo: false } %>
    <% end %>
  </td>
</tr>
