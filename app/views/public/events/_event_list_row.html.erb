<% browse_state = local_assigns.fetch(:browse_state) %>
<% primary_offer = event.preferred_ticket_offer %>
<% thumbnail_image = event.image_for(slot: :grid_default, breakpoint: :mobile) || event.image_for(slot: :grid_default, breakpoint: :desktop) %>
<% thumbnail_source = event_image_source(thumbnail_image) %>
<% event_url = public_event_detail_path(event, browse_state) %>

<article class="event-listing-card">
  <%= link_to event_url, class: "event-listing-row-link", aria: { label: "#{event.artist_name} anzeigen" } do %>
    <span class="sr-only"><%= [event.artist_name, event.title].compact.join(" - ") %></span>
  <% end %>

  <% if thumbnail_source.present? %>
    <div class="event-listing-thumb-link">
      <%= image_tag thumbnail_source, alt: event_image_alt(thumbnail_image, event), loading: "lazy", class: "event-listing-thumb-image" %>
    </div>
  <% end %>

  <p class="event-listing-date"><%= l(event.start_at.to_date, format: "%d.%m.%Y") %></p>

  <div class="event-listing-body">
    <div class="event-listing-link">
      <strong><%= event.artist_name %></strong>
      <% if event.title.present? %>
        <span> - <%= event.title %></span>
      <% end %>
    </div>

    <% if event.venue.present? %>
      <p class="event-listing-location"><%= event.venue %></p>
    <% end %>

    <% if primary_offer.present? %>
      <div class="event-listing-ticket">
        <%= link_to "Tickets",
                    primary_offer.resolved_ticket_url,
                    target: "_blank",
                    rel: "noopener",
                    class: "button event-listing-ticket-button",
                    data: { turbo: false } %>
      </div>
    <% end %>
  </div>
</article>
