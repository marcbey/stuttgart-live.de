<% featured = local_assigns.fetch(:featured, false) %>
<% track_class = featured ? "home-featured-track" : "home-slider-track" %>
<% effective_series_ids = local_assigns[:effective_series_ids] || effective_public_event_series_ids(events) %>
<% strict_proxy = local_assigns.fetch(:strict_proxy, false) %>
<% section_cache_key = public_events_section_cache_key(
  section: "highlight",
  browse_state: browse_state,
  events: events,
  context: [ title, local_assigns[:title_url], featured, list_aria_label ],
  strict_proxy: strict_proxy
) %>

<% section_classes = [featured ? "home-featured-section" : "home-slider-section"] %>
<% section_classes << "home-slider-section--turquoise-title" if title.to_s.casecmp("Alle Veranstaltungen").zero? %>
<% nav_content = capture do %>
  <button type="button"
          class="slider-view-toggle"
          data-section-view-target="button"
          data-action="click->section-view#toggle"
          title="Listenansicht"
          aria-label="<%= list_aria_label %>"
          aria-pressed="false">
    <span class="slider-view-toggle-label" data-section-view-target="label">Listenansicht</span>
    <span class="slider-view-icon slider-view-icon-list public-view-icon public-view-icon-list" aria-hidden="true">
      <span></span><span></span><span></span>
    </span>
    <span class="slider-view-icon slider-view-icon-grid public-view-icon public-view-icon-grid" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </span>
  </button>
<% end %>

<% cache section_cache_key do %>
  <section class="<%= section_classes.join(" ") %>"
           data-controller="highlights-slider section-view"
           <% if featured %>data-highlights-slider-autoplay-value="true" data-highlights-slider-interval-value="5000"<% end %>>
    <%= render "home_slider_header",
               title: title,
               title_url: local_assigns[:title_url],
               variant: :highlights,
               nav_content: nav_content,
               header_class: ("lane-header--turquoise-title" if title.to_s.casecmp("Alle Veranstaltungen").zero?) %>
    <div data-section-view-target="slider">
      <div class="highlights-slider-viewport">
        <button type="button"
                class="highlights-slider-arrow highlights-slider-arrow-overlay highlights-slider-arrow-prev"
                data-highlights-slider-target="previousButton"
                data-action="click->highlights-slider#previous"
                aria-label="Zurück">
          ‹
        </button>
        <div class="<%= track_class %>" data-highlights-slider-target="track">
          <% events.each_with_index do |event, index| %>
            <% if featured %>
              <% tile_variant = effective_public_grid_variant_for(event, index) %>
              <% card_slot = card_slot_for_grid_variant(tile_variant) %>
              <%= render "home_feature_card",
                         event: event,
                         browse_state: browse_state,
                         effective_series_ids: effective_series_ids,
                         strict_proxy: strict_proxy,
                         tile_variant: tile_variant,
                         card_slot: card_slot %>
            <% else %>
              <%= render "home_slider_card",
                         event: event,
                         browse_state: browse_state,
                         effective_series_ids: effective_series_ids,
                         strict_proxy: strict_proxy %>
            <% end %>
          <% end %>
        </div>
        <button type="button"
                class="highlights-slider-arrow highlights-slider-arrow-overlay highlights-slider-arrow-next"
                data-highlights-slider-target="nextButton"
                data-action="click->highlights-slider#next"
                aria-label="Weiter">
          ›
        </button>
      </div>
    </div>
    <div class="section-slider-list" data-section-view-target="list" hidden>
      <%= render "event_rows",
                 events: events,
                 browse_state: browse_state,
                 effective_series_ids: effective_series_ids,
                 strict_proxy: strict_proxy %>
    </div>
  </section>
<% end %>
