<% content_for :title, "Stuttgart Live - #{@lane.title}" %>
<% content_for :page_newsletter do %>
  <%= render "newsletter_signup", browse_state: @browse_state %>
<% end %>

<section class="public-shell">
  <div class="lane-page-topbar">
    <p class="event-detail-back">
      <%= link_to "← Zurück",
                  public_events_index_path(@browse_state),
                  data: { controller: "history-back-link", action: "click->history-back-link#navigate" } %>
    </p>
  </div>

  <% if @lane.key == "highlights" %>
    <section class="home-slider-section lane-page-section search-results-section">
      <%= render "home_slider_header",
                 title: @lane.title,
                 variant: @lane.header_variant %>
      <% if @lane_events.any? %>
        <%= render "event_cards",
                   events: @lane_events,
                   browse_state: @browse_state,
                   effective_series_ids: @lane_effective_series_ids,
                   container_id: "lane-event-grid",
                   container_class: "lane-page-grid lane-page-grid--highlights" %>
      <% else %>
        <div class="search-results-empty">
          <h2>Aktuell nichts in dieser Lane</h2>
          <p>Für „<%= @lane.title %>“ haben wir aktuell keine zukünftigen Events.</p>
        </div>
      <% end %>
    </section>
  <% elsif @lane.key == "russ_live" %>
    <% nav_content = capture do %>
      <button type="button"
              class="slider-view-toggle"
              data-section-view-target="button"
              data-action="click->section-view#toggle"
              title="Listenansicht"
              aria-label="Listenansicht für <%= @lane.title %>"
              aria-pressed="false">
        <span class="slider-view-toggle-label" data-section-view-target="label">Listenansicht</span>
        <span class="slider-view-icon slider-view-icon-list public-view-icon public-view-icon-list" aria-hidden="true">
          <span></span><span></span><span></span>
        </span>
        <span class="slider-view-icon slider-view-icon-grid public-view-icon public-view-icon-grid" aria-hidden="true">
          <span></span><span></span><span></span><span></span>
        </span>
      </button>
    <% end %>

    <section class="home-slider-section lane-page-section search-results-section"
             data-controller="section-view"
             data-section-view-mobile-list-default-value="true">
      <%= render "home_slider_header",
                 title: @lane.title,
                 variant: @lane.header_variant,
                 nav_content: nav_content %>
      <% if @lane_events.any? %>
        <div data-section-view-target="slider">
          <%= render "event_cards",
                     events: @lane_events,
                     browse_state: @browse_state,
                     effective_series_ids: @lane_effective_series_ids,
                     container_id: "russ-live-grid",
                     container_class: "lane-page-grid russ-live-grid" %>
        </div>
        <div class="section-slider-list genre-lane-list" data-section-view-target="list" hidden>
          <%= render "event_rows",
                     events: @lane_events,
                     browse_state: @browse_state,
                     effective_series_ids: @lane_effective_series_ids,
                     row_dom_id_prefix: :russ_live_row,
                     show_sold_out_ribbon: true %>
        </div>
      <% else %>
        <div class="search-results-empty">
          <h2>Aktuell keine RUSS Live Events</h2>
          <p>Für „<%= @lane.title %>“ haben wir aktuell keine zukünftigen Events.</p>
        </div>
      <% end %>
    </section>
  <% else %>
    <%= render "lane_page_section",
               lane: @lane,
               events: @lane_events,
               effective_series_ids: @lane_effective_series_ids,
               browse_state: @browse_state %>
  <% end %>
</section>
