<% event_image = event.event_image %>
<% uses_promotion_banner_image = event.promotion_banner_image.attached? %>
<% event_image_source = uses_promotion_banner_image ? optimized_event_promotion_banner_image_source(event) : event_image_source(event_image) %>
<% event_image_style = uses_promotion_banner_image ? event_promotion_banner_image_style(event, frame_ratio: 16.0 / 9.0) : event_cropped_image_style(event_image, frame_ratio: 16.0 / 9.0) %>
<% event_image_credit = uses_promotion_banner_image ? event.promotion_banner_image_copyright : event_image&.sub_text %>
<% image_alt = uses_promotion_banner_image ? "#{event.artist_name} - #{event.title}" : event_image_alt(event_image, event) %>

<article class="promotion-banner promotion-banner-event promotion-banner-poster">
  <% if authenticated? %>
    <div class="promotion-banner-admin-controls">
      <%= link_to "Bearbeiten",
                  backend_events_path(status: event.status, event_id: event.id),
                  class: "event-card-admin-link event-card-admin-link-attention",
                  data: { turbo: false } %>
    </div>
  <% end %>

  <%= link_to public_event_detail_path(event, browse_state), class: "promotion-banner-link" do %>
    <div class="promotion-banner-media">
      <%= image_tag event_image_source,
                    alt: image_alt,
                    class: "promotion-banner-image",
                    style: event_image_style %>
      <% if event_image_credit.present? %>
        <p class="promotion-banner-credit"><%= event_image_credit %></p>
      <% end %>
    </div>

    <div class="promotion-banner-copy">
      <p class="promotion-banner-kicker"><%= event.promotion_banner_kicker_text_value %></p>
      <h2><%= event.artist_name %></h2>
      <% if event.title.present? && event.title != event.artist_name %>
        <p class="promotion-banner-event-title"><%= event.title %></p>
      <% end %>
      <span class="promotion-banner-cta"><%= event.promotion_banner_cta_text_value %></span>
    </div>
  <% end %>
</article>
