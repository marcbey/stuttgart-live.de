<% event_image = event.event_image %>
<% uses_promotion_banner_image = event.promotion_banner_image.attached? %>
<% event_image_source = uses_promotion_banner_image ? optimized_event_promotion_banner_image_source(event, strict_proxy: true) : event_image_source(event_image, strict_proxy: true) %>
<% event_image_style = uses_promotion_banner_image ? event_promotion_banner_image_style(event, frame_ratio: 16.0 / 9.0) : event_cropped_image_style(event_image, frame_ratio: 16.0 / 9.0) %>
<% event_image_credit = uses_promotion_banner_image ? event.promotion_banner_image_copyright : event_image&.sub_text %>
<% image_alt = uses_promotion_banner_image ? "#{event.artist_name} - #{event.title}" : event_image_alt(event_image, event) %>

<%= render "public/events/promotion_banner_component",
           article_classes: "promotion-banner promotion-banner-event promotion-banner-poster",
           article_style: "--promotion-banner-background: #{event.promotion_banner_background_color_value}",
           admin_link_path: (authenticated? ? backend_events_path(status: event.status, event_id: event.id) : nil),
           admin_link_label: "Edit",
           href: public_event_detail_path(event, browse_state),
           link_classes: "promotion-banner-link promotion-banner-link-#{event.promotion_banner_text_color_scheme}",
           link_style: "background: var(--promotion-banner-background)",
           image_source: event_image_source,
           image_alt: image_alt,
           image_style: event_image_style,
           image_loading: "eager",
           image_fetchpriority: "high",
           image_decoding: "async",
           credit: event_image_credit,
           kicker_text: event.promotion_banner_kicker_text_value,
           heading: event.artist_name,
           subheading: (event.title if event.title.present? && event.title != event.artist_name),
           cta_text: event.promotion_banner_cta_text_value %>
