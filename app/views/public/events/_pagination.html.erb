<div id="events-pagination">
  <% if next_page.present? %>
    <% browse_state = local_assigns.fetch(:browse_state) %>
    <div class="pagination-sentinel"
         data-controller="infinite-scroll"
         data-infinite-scroll-url-value="<%= public_events_index_path(browse_state, page: next_page, format: :turbo_stream) %>">
      <span>lade mehr events...</span>
    </div>
  <% end %>
</div>
