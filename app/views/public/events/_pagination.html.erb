<div id="events-pagination">
  <% if next_page.present? %>
    <% public_filter = local_assigns.fetch(:public_filter, "sks") %>
    <% public_event_date = local_assigns.fetch(:public_event_date, params[:event_date].to_s.presence) %>
    <div class="pagination-sentinel"
      data-controller="infinite-scroll"
      data-infinite-scroll-url-value="<%= events_path(page: next_page, filter: public_filter, event_date: public_event_date, format: :turbo_stream) %>">
      <span>lade mehr events...</span>
    </div>
  <% else %>
    <div class="pagination-end">keine weiteren veranstaltungen</div>
  <% end %>
</div>
