<div id="events-pagination">
  <% if next_page.present? %>
    <% public_filter = local_assigns.fetch(:public_filter, "sks") %>
    <% public_view = local_assigns.fetch(:public_view, params[:view].to_s.presence || "grid") %>
    <% public_query = local_assigns.fetch(:public_query, params[:q].to_s.presence) %>
    <% public_event_date = local_assigns.fetch(:public_event_date, params[:event_date].to_s.presence) %>
    <div class="pagination-sentinel"
      data-controller="infinite-scroll"
      data-infinite-scroll-url-value="<%= events_path(page: next_page, filter: public_filter, view: (public_view == "list" ? public_view : nil), q: public_query, event_date: public_event_date, format: :turbo_stream) %>">
      <span>lade mehr events...</span>
    </div>
  <% end %>
</div>
