<% presenter = public_event_show_presenter(@event, primary_offer: @primary_offer, browse_state: @browse_state) %>
<%= render "show_meta", presenter: presenter %>

<article class="event-detail">
  <div class="event-detail-topbar">
    <p class="event-detail-back"><%= link_to "← alle events", presenter.back_path %></p>
    <% if authenticated? %>
      <div class="event-detail-topbar-actions">
        <%= link_to "Edit",
                    backend_events_path(status: @event.status, event_id: @event.id),
                    class: "button button-secondary button-compact event-detail-edit-link",
                    data: { turbo: false } %>
      </div>
    <% end %>
  </div>

  <%= render "show_hero", presenter: presenter %>

  <div class="event-detail-body">
    <div class="event-detail-main">
      <% if presenter.primary_description.present? %>
        <% description_columns = event_detail_text_columns(presenter.primary_description) %>
        <section class="event-detail-panel event-detail-copy event-detail-copy-primary">
          <h2>Beschreibung</h2>
          <div class="event-detail-copy-body">
            <div class="event-detail-copy-grid">
              <div class="event-detail-copy-column">
                <%= simple_format(description_columns.left) %>
              </div>
              <% if description_columns.right.present? %>
                <div class="event-detail-copy-column">
                  <%= simple_format(description_columns.right) %>
                </div>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>

      <% if presenter.venue_info.present? %>
        <section class="event-detail-panel event-detail-copy">
          <h2>Venue</h2>
          <div class="event-detail-copy-body">
            <% if presenter.venue_info.logo_source.present? %>
              <p>
                <%= image_tag presenter.venue_info.logo_source,
                              alt: presenter.venue_info.name,
                              style: "max-width: 14rem; max-height: 5rem; object-fit: contain;" %>
              </p>
            <% end %>

            <% if presenter.venue_info.address.present? %>
              <div>
                <p><strong>Adresse:</strong></p>
                <%= simple_format(presenter.venue_info.address) %>
              </div>
            <% end %>

            <% if presenter.venue_info.external_url.present? %>
              <p>
                <strong>Website:</strong><br>
                <%= link_to presenter.venue_info.external_url,
                            presenter.venue_info.external_url,
                            target: "_blank",
                            rel: "noopener" %>
              </p>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if presenter.artist_description.present? %>
        <% artist_columns = event_detail_text_columns(presenter.artist_description) %>
        <section class="event-detail-panel event-detail-copy">
          <h2>Über den Act</h2>
          <div class="event-detail-copy-body">
            <div class="event-detail-copy-grid">
              <div class="event-detail-copy-column">
                <%= simple_format(artist_columns.left) %>
              </div>
              <% if artist_columns.right.present? %>
                <div class="event-detail-copy-column">
                  <%= simple_format(artist_columns.right) %>
                </div>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>

      <% if presenter.venue_description.present? %>
        <% venue_columns = event_detail_text_columns(presenter.venue_description) %>
        <section class="event-detail-panel event-detail-copy">
          <h2>Über die Venue</h2>
          <div class="event-detail-copy-body">
            <div class="event-detail-copy-grid">
              <div class="event-detail-copy-column">
                <%= simple_format(venue_columns.left) %>
              </div>
              <% if venue_columns.right.present? %>
                <div class="event-detail-copy-column">
                  <%= simple_format(venue_columns.right) %>
                </div>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>

      <% if presenter.support_text.present? %>
        <% support_columns = event_detail_text_columns(presenter.support_text) %>
        <section class="event-detail-panel event-detail-copy">
          <h2>Support</h2>
          <div class="event-detail-copy-body">
            <div class="event-detail-copy-grid">
              <div class="event-detail-copy-column">
                <%= simple_format(support_columns.left) %>
              </div>
              <% if support_columns.right.present? %>
                <div class="event-detail-copy-column">
                  <%= simple_format(support_columns.right) %>
                </div>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>

      <% if @event.editor_notes.present? %>
        <% editor_note_columns = event_detail_text_columns(@event.editor_notes) %>
        <section class="event-detail-panel event-detail-copy">
          <h2>Redaktionsnotiz</h2>
          <div class="event-detail-copy-body">
            <div class="event-detail-copy-grid">
              <div class="event-detail-copy-column">
                <%= simple_format(editor_note_columns.left) %>
              </div>
              <% if editor_note_columns.right.present? %>
                <div class="event-detail-copy-column">
                  <%= simple_format(editor_note_columns.right) %>
                </div>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>

      <% if presenter.has_media_block? %>
        <%= render "show_media", presenter: presenter %>
      <% end %>
    </div>
  </div>

  <% if @event.show_public_organizer_notes? %>
    <section class="event-detail-panel event-detail-copy event-detail-notes-panel">
      <div class="event-detail-notes">
        <div class="event-detail-notes-copy">
          <h2>Veranstalterhinweise</h2>
          <div class="event-detail-notes-body">
            <%= formatted_organizer_notes_with_link(@event.public_organizer_notes, event: @event) %>
          </div>
        </div>
        <div class="event-detail-organizer-sidebar">
          <div class="event-detail-organizer-brand">
            <h3 class="event-detail-organizer-sidebar-heading">Veranstalter:</h3>
            <%= image_tag "russ-live-logo.svg", alt: "Russ Live", class: "event-detail-organizer-logo" %>
          </div>
          <% if presenter.has_presenters? %>
            <%= render "organizer_presenters_strip", presenters: presenter.presenters %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

  <% if @event_series_lane.present? %>
    <%= render "genre_lane_section",
               title: @event_series_lane.title,
               events: @event_series_lane.events,
               effective_series_ids: [@event_series_lane.series.id],
               show_series_badge: false,
               browse_state: @browse_state,
               kicker: "Event-Reihe",
               tone_class: "genre-lane-section--tone-4",
               list_aria_label: "Listenansicht für #{@event_series_lane.title}" %>
  <% end %>

  <% if @related_genre_lane.present? %>
    <%= render "genre_lane_section",
               group: @related_genre_lane.group,
               events: @related_genre_lane.events,
               effective_series_ids: @related_genre_lane.effective_series_ids,
               show_series_badge: false,
               browse_state: @browse_state,
               title: "Mehr aus diesem Genre",
               summary: @related_genre_lane.group.name,
               list_aria_label: "Listenansicht für #{@related_genre_lane.group.name}" %>
  <% end %>
</article>
