<% presenter = public_event_show_presenter(@event, primary_offer: @primary_offer, browse_state: @browse_state) %>
<%= render "show_meta", presenter: presenter %>
<% content_for :page_newsletter do %>
  <%= render "newsletter_signup", browse_state: @browse_state %>
<% end %>
<% content_for :page_partner_strip do %>
  <%= render "partner_strip" %>
<% end %>

<article class="event-detail"<%= %( style="--event-detail-right-column-width: #{presenter.hero_stage_max_width || "46rem"};") %>>
  <div class="event-detail-topbar">
    <p class="event-detail-back">
      <%= link_to "← Zurück",
                  presenter.back_path,
                  data: { controller: "history-back-link", action: "click->history-back-link#navigate" } %>
    </p>
    <div class="event-detail-topbar-actions">
      <% unless presenter.has_hero_gallery? %>
        <%= render "public/events/saved_event_button",
                   event: @event,
                   button_class: "saved-event-button-detail" %>
      <% end %>
      <% if authenticated? %>
        <%= link_to "Edit",
                    backend_events_path(status: @event.status, event_id: @event.id),
                    class: "button button-secondary button-compact event-detail-edit-link public-edit-link public-backend-shortcut",
                    data: { turbo: false } %>
      <% end %>
    </div>
  </div>

  <%= render "show_hero", presenter: presenter %>

  <div class="event-detail-content">
    <div class="event-detail-main">
      <% if presenter.primary_description.present? %>
        <section class="event-detail-copy-block event-detail-copy-block-primary">
          <h2>Beschreibung</h2>
          <div class="event-detail-copy-flow">
            <%= simple_format(presenter.primary_description) %>
          </div>
          <% if presenter.external_links.any? %>
            <div class="event-detail-links" aria-label="Externe Links">
              <% presenter.external_links.each do |link| %>
                <%= link_to link.label, link.url, target: "_blank", rel: "noopener", title: link.url %>
              <% end %>
            </div>
          <% end %>
        </section>
      <% elsif presenter.external_links.any? %>
        <section class="event-detail-copy-block event-detail-copy-block-links" aria-label="Externe Links">
          <div class="event-detail-links">
            <% presenter.external_links.each do |link| %>
              <%= link_to link.label, link.url, target: "_blank", rel: "noopener", title: link.url %>
            <% end %>
          </div>
        </section>
      <% end %>

      <% if presenter.artist_description.present? %>
        <section class="event-detail-copy-block">
          <h2>Über den Act</h2>
          <div class="event-detail-copy-flow">
            <%= simple_format(presenter.artist_description) %>
          </div>
        </section>
      <% end %>

      <% if presenter.show_venue_section? %>
        <section class="event-detail-copy-block event-detail-venue-block">
          <div class="event-detail-venue-layout">
            <h2>Über die Venue</h2>
            <% if presenter.venue_description.present? %>
              <div class="event-detail-copy-flow event-detail-venue-description">
                <%= simple_format(presenter.venue_description) %>
              </div>
            <% end %>

            <div class="event-detail-venue-main">
              <% if presenter.venue_info&.external_url.present? %>
                <div class="event-detail-venue-actions">
                  <%= link_to "Homepage Venue",
                              presenter.venue_info.external_url,
                              target: "_blank",
                              rel: "noopener",
                              class: "event-detail-venue-button" %>
                </div>
              <% end %>

              <% if presenter.venue_info.present? && (presenter.venue_info.address.present? || presenter.venue_info.map_url.present? || presenter.venue_info.logo_source.present?) %>
                <div class="event-detail-venue-meta">
                  <% if presenter.venue_info.address.present? || presenter.venue_info.logo_source.present? %>
                    <div class="event-detail-venue-meta-header">
                      <% if presenter.venue_info.address.present? %>
                        <div class="event-detail-venue-address">
                          <p class="event-detail-venue-label">Adresse:</p>
                          <p><%= presenter.venue_info.address %></p>
                        </div>
                      <% end %>

                      <% if presenter.venue_info.logo_source.present? %>
                        <div class="event-detail-venue-brand">
                          <%= image_tag presenter.venue_info.logo_source,
                                        alt: presenter.venue_info.name,
                                        class: "event-detail-venue-logo" %>
                        </div>
                      <% end %>
                    </div>
                  <% end %>

                  <% if presenter.venue_info.map_url.present? %>
                    <%= link_to presenter.venue_info.map_url,
                                target: "_blank",
                                rel: "noopener",
                                class: "event-detail-venue-map-link" do %>
                      <%= image_tag "venue-pin.svg", alt: "", class: "event-detail-venue-map-pin", "aria-hidden": "true" %>
                      <span>Auf Google Maps öffnen</span>
                    <% end %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>
        </section>
      <% end %>

      <% if @event.editor_notes.present? %>
        <section class="event-detail-copy-block">
          <h2>Redaktionsnotiz</h2>
          <div class="event-detail-copy-flow">
            <%= simple_format(@event.editor_notes) %>
          </div>
        </section>
      <% end %>

    </div>

    <% if @event_series_lane.present? || @related_genre_lane.present? %>
      <aside class="event-detail-sidebar" aria-label="Weitere Event-Empfehlungen">
        <% if @event_series_lane.present? %>
          <section class="event-detail-related-list event-detail-series-terms" aria-label="Weitere Termine">
            <div class="event-detail-related-list-heading">
              <h2>Weitere Termine</h2>
            </div>
            <%= render "event_rows",
                       events: @event_series_lane.events,
                       browse_state: @browse_state,
                       wrap: true,
                       effective_series_ids: [@event_series_lane.series.id] %>
            <%= link_to "Alle anzeigen",
                        public_event_series_terms_path(@event, @browse_state),
                        class: "button event-detail-series-terms-button" %>
          </section>
        <% end %>

        <% if @related_genre_lane.present? %>
          <section class="event-detail-related-list" aria-label="Das könnte dir auch gefallen">
            <div class="event-detail-related-list-heading">
              <h2>Das könnte dir auch gefallen</h2>
            </div>
            <%= render "event_rows",
                       events: @related_genre_lane.events.first(10),
                       browse_state: @browse_state,
                       wrap: true,
                       effective_series_ids: @related_genre_lane.effective_series_ids %>
          </section>
        <% end %>
      </aside>
    <% end %>
  </div>

  <% if presenter.has_media_block? %>
    <%= render "show_media", presenter: presenter %>
  <% end %>

  <% if @event.show_public_organizer_notes? %>
    <section class="event-detail-panel event-detail-copy event-detail-notes-panel">
      <div class="event-detail-notes">
        <div class="event-detail-notes-copy">
          <h2>Veranstalterhinweise</h2>
          <div class="event-detail-notes-body">
            <%= formatted_organizer_notes_with_link(@event.public_organizer_notes, event: @event) %>
          </div>
        </div>
        <div class="event-detail-organizer-sidebar">
          <div class="event-detail-organizer-brand">
            <h3 class="event-detail-organizer-sidebar-heading">Veranstalter:</h3>
            <%= image_tag "russ-live-logo.svg", alt: "Russ Live", class: "event-detail-organizer-logo" %>
          </div>
          <% if presenter.has_presenters? %>
            <%= render "organizer_presenters_strip", presenters: presenter.presenters %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>

</article>
