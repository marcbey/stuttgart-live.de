<% content_for :title, "Stuttgart Live - Konzerte" %>

<section class="public-shell">
  <header class="hero-header">
    <h1>Konzerte in Stuttgart</h1>
    <p>Chronologisch kuratiert, direkt mit Ticket-CTA.</p>
    <div class="public-filter-row">
      <div class="public-filter-row-main">
        <div class="public-filter-toggle">
          <%= link_to "Alle Events",
                      events_path(filter: "all", view: (@public_view == "list" ? @public_view : nil), event_date: @public_event_date&.iso8601, q: @public_query),
                      class: "status-chip #{'status-chip-active' if @public_filter == 'all'}" %>
          <%= link_to "Nur SKS",
                      events_path(filter: "sks", view: (@public_view == "list" ? @public_view : nil), event_date: @public_event_date&.iso8601, q: @public_query),
                      class: "status-chip #{'status-chip-active' if @public_filter == 'sks'}" %>
        </div>

        <div class="public-filter-toggle public-view-toggle" aria-label="Darstellung umschalten">
          <%= link_to events_path(filter: @public_filter, view: "grid", event_date: @public_event_date&.iso8601, q: @public_query),
                      class: "status-chip public-view-chip #{'status-chip-active' if @public_view == 'grid'}",
                      title: "Grid-Ansicht",
                      aria: { label: "Grid-Ansicht" } do %>
            <span class="public-view-icon public-view-icon-grid" aria-hidden="true">
              <span></span><span></span><span></span><span></span>
            </span>
          <% end %>
          <%= link_to events_path(filter: @public_filter, view: "list", event_date: @public_event_date&.iso8601, q: @public_query),
                      class: "status-chip public-view-chip #{'status-chip-active' if @public_view == 'list'}",
                      title: "Listen-Ansicht",
                      aria: { label: "Listen-Ansicht" } do %>
            <span class="public-view-icon public-view-icon-list" aria-hidden="true">
              <span></span><span></span><span></span>
            </span>
          <% end %>
        </div>

        <%= form_with url: events_path, method: :get, local: true, class: "public-search-filter" do %>
          <%= hidden_field_tag :filter, @public_filter %>
          <%= hidden_field_tag :view, (@public_view == "list" ? @public_view : nil) %>
          <%= hidden_field_tag :event_date, @public_event_date&.iso8601 %>
          <%= text_field_tag :q,
                             @public_query,
                             class: "form-input public-search-input",
                             placeholder: "Suche",
                             aria: { label: "Events durchsuchen" } %>
        <% end %>
      </div>

      <%= form_with url: events_path, method: :get, local: true, class: "public-date-filter" do %>
        <%= hidden_field_tag :filter, @public_filter %>
        <%= hidden_field_tag :view, (@public_view == "list" ? @public_view : nil) %>
        <%= hidden_field_tag :q, @public_query %>
        <div class="public-date-input-wrap">
          <%= date_field_tag :event_date,
                             @public_event_date&.iso8601,
                             class: "form-input public-date-input",
                             aria: { label: "Tag auswählen" },
                             onchange: "this.form.requestSubmit();" %>
          <%= button_tag "×",
                         type: "button",
                         class: "public-date-clear #{'public-date-clear-visible' if @public_event_date.present?}",
                         aria: { label: "Datumsfilter zurücksetzen" },
                         onclick: "this.form.querySelector('[name=event_date]').value=''; this.form.requestSubmit();" %>
        </div>
      <% end %>
    </div>
  </header>

  <% if @public_view == "list" %>
    <div class="event-listing-table-wrap">
      <table class="event-listing-table">
        <thead>
          <tr>
            <th>Datum</th>
            <th>Artist / Titel</th>
            <th>Location</th>
          </tr>
        </thead>
        <tbody id="event-list-body">
          <% @events.each do |event| %>
            <%= render "event_list_row",
                       event: event,
                       public_filter: @public_filter,
                       public_view: @public_view,
                       public_query: @public_query,
                       public_event_date: @public_event_date&.iso8601 %>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div id="event-grid" class="flyer-grid">
      <% @events.each_with_index do |event, index| %>
        <% absolute_index = ((@page - 1) * Public::EventsController::PER_PAGE) + index %>
        <% tile_variant = effective_public_grid_variant_for(event, absolute_index) %>
        <% card_slot = card_slot_for_grid_variant(tile_variant) %>
        <%= render "event_card",
                   event: event,
                   tile_variant: tile_variant,
                   card_slot: card_slot,
                   public_filter: @public_filter,
                   public_query: @public_query,
                   public_event_date: @public_event_date&.iso8601 %>
      <% end %>
    </div>
  <% end %>

  <%= render "pagination", next_page: @next_page, public_filter: @public_filter, public_view: @public_view, public_query: @public_query, public_event_date: @public_event_date&.iso8601 %>
</section>
