<% content_for :title, "Stuttgart Live - Konzerte" %>

<section class="public-shell">
  <div class="public-filter-row public-filter-row-home">
    <div class="public-filter-row-main">
      <div class="public-filter-toggle">
        <%= link_to "Highlights",
                    events_path(filter: "sks", view: (@public_view == "list" ? @public_view : nil), event_date: @public_event_date&.iso8601, q: @public_query),
                    class: "status-chip #{'status-chip-active' if @public_filter == 'sks'}" %>
        <%= link_to "Alle Events",
                    events_path(filter: "all", view: (@public_view == "list" ? @public_view : nil), event_date: @public_event_date&.iso8601, q: @public_query),
                    class: "status-chip #{'status-chip-active' if @public_filter == 'all'}" %>
      </div>

      <div class="public-filter-toggle public-view-toggle" aria-label="Darstellung umschalten">
        <%= link_to events_path(filter: @public_filter, view: "grid", event_date: @public_event_date&.iso8601, q: @public_query),
                    class: "status-chip public-view-chip #{'status-chip-active' if @public_view == 'grid'}",
                    title: "Grid-Ansicht",
                    aria: { label: "Grid-Ansicht" } do %>
          <span class="public-view-icon public-view-icon-grid" aria-hidden="true">
            <span></span><span></span><span></span><span></span>
          </span>
        <% end %>
        <%= link_to events_path(filter: @public_filter, view: "list", event_date: @public_event_date&.iso8601, q: @public_query),
                    class: "status-chip public-view-chip #{'status-chip-active' if @public_view == 'list'}",
                    title: "Listen-Ansicht",
                    aria: { label: "Listen-Ansicht" } do %>
          <span class="public-view-icon public-view-icon-list" aria-hidden="true">
            <span></span><span></span><span></span>
          </span>
        <% end %>
      </div>

      <%= form_with url: events_path, method: :get, local: true, class: "public-search-filter" do %>
        <%= hidden_field_tag :filter, @public_filter %>
        <%= hidden_field_tag :view, (@public_view == "list" ? @public_view : nil) %>
        <%= text_field_tag :q,
                           @public_query,
                           class: "form-input public-search-input",
                           placeholder: "Suche",
                           aria: { label: "Events durchsuchen" } %>
      <% end %>
    </div>
  </div>

  <% if @public_view == "list" %>
    <section class="highlights-slider-section" data-controller="highlights-slider">
      <div class="highlights-slider-header">
        <h2>Highlights</h2>
        <div class="highlights-slider-nav">
          <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="previousButton" data-action="click->highlights-slider#previous" aria-label="Zurück">‹</button>
          <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="nextButton" data-action="click->highlights-slider#next" aria-label="Weiter">›</button>
        </div>
      </div>
      <div class="event-listing-grid" id="event-list-body" data-highlights-slider-target="track">
        <% @events.each do |event| %>
          <%= render "event_list_row",
                     event: event,
                     public_filter: @public_filter,
                     public_view: @public_view,
                     public_query: @public_query,
                     public_event_date: @public_event_date&.iso8601 %>
        <% end %>
      </div>
    </section>
  <% else %>
    <% if @page == 1 && @home_featured_events.present? %>
      <section class="home-featured-section"
               data-controller="highlights-slider"
               data-highlights-slider-autoplay-value="true"
               data-highlights-slider-interval-value="5000">
        <div class="home-featured-nav">
          <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="previousButton" data-action="click->highlights-slider#previous" aria-label="Zurück">‹</button>
          <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="nextButton" data-action="click->highlights-slider#next" aria-label="Weiter">›</button>
        </div>
        <div class="home-featured-track" data-highlights-slider-target="track">
          <% @home_featured_events.each_with_index do |event, index| %>
            <% tile_variant = effective_public_grid_variant_for(event, index) %>
            <% card_slot = card_slot_for_grid_variant(tile_variant) %>
            <%= render "home_feature_card",
                       event: event,
                       public_filter: @public_filter,
                       public_query: @public_query,
                       public_event_date: @public_event_date&.iso8601,
                       tile_variant: tile_variant,
                       card_slot: card_slot %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @page == 1 && @home_highlight_events.present? %>
      <section class="home-slider-section" data-controller="highlights-slider">
        <div class="home-slider-header">
          <h2>Highlights</h2>
          <div class="highlights-slider-nav">
            <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="previousButton" data-action="click->highlights-slider#previous" aria-label="Zurück">‹</button>
            <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="nextButton" data-action="click->highlights-slider#next" aria-label="Weiter">›</button>
          </div>
        </div>
        <div class="home-slider-track" data-highlights-slider-target="track">
          <% @home_highlight_events.each do |event| %>
            <%= render "home_slider_card",
                       event: event,
                       public_filter: @public_filter,
                       public_query: @public_query,
                       public_event_date: @public_event_date&.iso8601 %>
          <% end %>
        </div>
      </section>
    <% end %>

    <% if @page == 1 && @home_tagestipp_events.present? %>
      <section class="home-slider-section" data-controller="highlights-slider">
        <div class="home-slider-header">
          <h2>Tagestipp</h2>
          <div class="highlights-slider-nav">
            <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="previousButton" data-action="click->highlights-slider#previous" aria-label="Zurück">‹</button>
            <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="nextButton" data-action="click->highlights-slider#next" aria-label="Weiter">›</button>
          </div>
        </div>
        <div class="home-slider-track" data-highlights-slider-target="track">
          <% @home_tagestipp_events.each do |event| %>
            <%= render "home_slider_card",
                       event: event,
                       public_filter: @public_filter,
                       public_query: @public_query,
                       public_event_date: @public_event_date&.iso8601 %>
          <% end %>
        </div>
      </section>
    <% end %>

    <section class="home-slider-section" data-controller="highlights-slider">
      <div class="home-slider-header">
        <h2>Genres</h2>
        <div class="highlights-slider-nav">
          <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="previousButton" data-action="click->highlights-slider#previous" aria-label="Zurück">‹</button>
          <button type="button" class="highlights-slider-arrow" data-highlights-slider-target="nextButton" data-action="click->highlights-slider#next" aria-label="Weiter">›</button>
        </div>
      </div>
      <div class="genre-slider-track" data-highlights-slider-target="track">
        <% [
          [ "Pop", "genre-tile-pop" ],
          [ "Rock", "genre-tile-rock" ],
          [ "Hiphop", "genre-tile-hiphop" ],
          [ "Rap", "genre-tile-rap" ],
          [ "Metal", "genre-tile-metal" ],
          [ "Elektro", "genre-tile-elektro" ],
          [ "Show", "genre-tile-show" ],
          [ "Punk", "genre-tile-punk" ],
          [ "Schlager", "genre-tile-schlager" ]
        ].each do |genre_name, genre_class| %>
          <article class="genre-tile <%= genre_class %>">
            <span><%= genre_name %></span>
          </article>
        <% end %>
      </div>
    </section>

  <% end %>

  <% if @public_view == "list" %>
    <%= render "pagination", next_page: @next_page, public_filter: @public_filter, public_view: @public_view, public_query: @public_query, public_event_date: @public_event_date&.iso8601 %>
  <% end %>

  <section class="newsletter-signup-section">
    <div class="newsletter-signup-copy">
      <p class="eyebrow">Newsletter</p>
      <h2>Nichts verpassen</h2>
      <p>Neue Konzerte, Highlights und Vorverkaeufe direkt in dein Postfach.</p>
    </div>

    <%= form_with model: NewsletterSubscriber.new, url: newsletter_subscribers_path, method: :post, local: true, class: "newsletter-signup-form" do |form| %>
      <%= hidden_field_tag :filter, @public_filter %>
      <%= hidden_field_tag :view, (@public_view == "list" ? @public_view : nil) %>
      <%= hidden_field_tag :q, @public_query %>
      <%= form.email_field :email,
                           class: "form-input newsletter-signup-input",
                           placeholder: "E-Mail-Adresse",
                           required: true,
                           autocomplete: "email" %>
      <%= form.submit "Newsletter abonnieren", class: "button newsletter-signup-button" %>
    <% end %>
  </section>
</section>
