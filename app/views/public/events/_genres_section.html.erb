<% browse_state = local_assigns.fetch(:browse_state) %>
<% selected_genre_tile = local_assigns[:selected_genre_tile] %>
<% selected_genre_events = local_assigns.fetch(:selected_genre_events, []) %>

<section class="home-slider-section">
  <div class="home-slider-header">
    <h2>Genres</h2>
  </div>
  <ul class="genre-grid" role="list" aria-label="Genres">
    <% public_event_genre_tiles.each do |tile| %>
      <% genre_active = selected_genre_tile&.fetch(:slug, nil) == tile.fetch(:slug) %>
      <li class="genre-grid-item">
        <%= link_to events_path(event_date: browse_state.event_date_param, genre: tile.fetch(:slug)),
                    class: "genre-tile genre-tile-link #{tile.fetch(:css_class)}#{' genre-tile-active' if genre_active}",
                    data: { turbo_frame: "genre-events-panel", turbo_action: "advance" },
                    aria: {
                      controls: "genre-events-panel",
                      expanded: genre_active
                    } do %>
          <span><%= tile.fetch(:name) %></span>
        <% end %>
      </li>
    <% end %>
  </ul>

  <%= render "genre_events_frame",
             browse_state: browse_state,
             selected_genre_tile: selected_genre_tile,
             selected_genre_events: selected_genre_events %>
</section>
