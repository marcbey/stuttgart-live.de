<section class="home-slider-section">
  <div class="home-slider-header">
    <h2>Genres</h2>
  </div>
  <div class="genre-grid" role="list" aria-label="Genres">
    <% public_event_genre_tiles.each do |genre_name, genre_class| %>
      <article class="genre-tile <%= genre_class %>" role="listitem">
        <span><%= genre_name %></span>
      </article>
    <% end %>
  </div>
</section>
