<% if presenter.show_ticket_cta? %>
  <section class="event-detail-cta event-detail-cta-card" aria-label="Ticketinformationen">
    <div class="event-detail-cta-layout <%= "event-detail-cta-layout-single" unless presenter.external_links.any? %>">
      <div class="event-detail-cta-copy">
        <div class="event-detail-cta-meta">
          <% if presenter.ticket_badge_text.present? %>
            <p class="event-detail-badge-inline"><%= presenter.ticket_badge_text %></p>
          <% end %>
          <% if presenter.ticket_price_text.present? %>
            <p class="event-detail-cta-price">Preis: <%= presenter.ticket_price_text %></p>
          <% end %>
          <%= link_to "Tickets sichern", presenter.ticket_url, target: "_blank", rel: "noopener", class: "button event-detail-cta-button" %>
        </div>
      </div>
      <% if presenter.external_links.any? %>
        <div class="event-detail-cta-actions">
          <div class="event-detail-links event-detail-cta-links" aria-label="Externe Links">
            <% presenter.external_links.each do |link| %>
              <%= link_to link.label, link.url, target: "_blank", rel: "noopener", title: link.url %>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </section>
<% end %>
