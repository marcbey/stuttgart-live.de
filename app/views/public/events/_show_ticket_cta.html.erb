<% if presenter.show_ticket_panel? %>
  <section class="event-detail-cta event-detail-cta-card" aria-label="Ticketinformationen">
    <div class="event-detail-cta-layout event-detail-cta-layout-single">
      <div class="event-detail-cta-copy">
        <div class="event-detail-cta-meta">
          <% if presenter.ticket_badge_text.present? %>
            <p class="event-detail-badge-inline"><%= presenter.ticket_badge_text %></p>
          <% end %>
          <% if presenter.ticket_price_text.present? %>
            <p class="event-detail-cta-price">Preis: <%= presenter.ticket_price_text %></p>
          <% end %>
          <% if presenter.show_ticket_link? %>
            <% ticket_cta_label = presenter.ticket_provider_label.present? ? "Tickets bei #{presenter.ticket_provider_label} sichern" : "Tickets sichern" %>
            <%= link_to ticket_cta_label, presenter.ticket_url, target: "_blank", rel: "noopener", class: "button event-detail-cta-button" %>
          <% elsif presenter.show_unavailable_note? %>
            <p class="event-detail-meta-strong event-detail-sold-out-note"><%= presenter.sold_out_note_text %></p>
          <% end %>
          <% if presenter.show_sks_sold_out_hint? %>
            <p class="event-detail-sold-out-hint"><%= presenter.sks_sold_out_hint_text %></p>
          <% end %>
        </div>
      </div>
    </div>
  </section>
<% end %>
