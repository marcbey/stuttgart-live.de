<%= turbo_stream.append "event-grid" do %>
  <%= render partial: "event_card",
             collection: @events,
             as: :event,
             locals: { public_filter: @public_filter, public_event_date: @public_event_date&.iso8601 } %>
<% end %>

<%= turbo_stream.replace "events-pagination" do %>
  <%= render "pagination", next_page: @next_page, public_filter: @public_filter, public_event_date: @public_event_date&.iso8601 %>
<% end %>
