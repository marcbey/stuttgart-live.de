<% title = local_assigns[:title] || group&.name %>
<% kicker = local_assigns[:kicker] %>
<% section_variant = local_assigns[:section_variant] %>
<% card_variant = local_assigns[:card_variant] %>
<% effective_series_ids = local_assigns[:effective_series_ids] || effective_public_event_series_ids(events) %>
<% show_series_badge = local_assigns.fetch(:show_series_badge, true) %>
<% hover_lift_cards = local_assigns.fetch(:hover_lift_cards, false) %>
<% header_variant = local_assigns.fetch(:header_variant, :genre) %>
<% strict_proxy = local_assigns.fetch(:strict_proxy, false) %>
<% nav_content = capture do %>
  <button type="button"
          class="slider-view-toggle"
          data-section-view-target="button"
          data-action="click->section-view#toggle"
          title="Listenansicht"
          aria-label="<%= list_aria_label %>"
          aria-pressed="false">
    <span class="slider-view-toggle-label" data-section-view-target="label">Listenansicht</span>
    <span class="slider-view-icon slider-view-icon-list public-view-icon public-view-icon-list" aria-hidden="true">
      <span></span><span></span><span></span>
    </span>
    <span class="slider-view-icon slider-view-icon-grid public-view-icon public-view-icon-grid" aria-hidden="true">
      <span></span><span></span><span></span><span></span>
    </span>
  </button>
<% end %>

<section class="<%= ["genre-lane-section", local_assigns.fetch(:tone_class, "genre-lane-section--tone-1"), ("genre-lane-section--#{section_variant}" if section_variant.present?), ("genre-lane-section--hover-lift" if hover_lift_cards)].compact.join(" ") %>"
         data-controller="highlights-slider section-view">
  <%= render "home_slider_header",
             title: title,
             title_url: local_assigns[:title_url],
             kicker: kicker,
             variant: header_variant,
             header_class: local_assigns[:header_class],
             nav_content: nav_content %>

  <div data-section-view-target="slider">
    <div class="highlights-slider-viewport">
      <button type="button"
              class="highlights-slider-arrow highlights-slider-arrow-overlay highlights-slider-arrow-prev genre-lane-arrow"
              data-highlights-slider-target="previousButton"
              data-action="click->highlights-slider#previous"
              aria-label="Zurück">
        ‹
      </button>
      <div class="genre-lane-track" data-highlights-slider-target="track">
        <% events.each do |event| %>
          <%= render "genre_lane_card",
                     event: event,
                     browse_state: browse_state,
                     card_variant: card_variant,
                     strict_proxy: strict_proxy,
                     effective_series_ids: effective_series_ids,
                     show_series_badge: show_series_badge %>
        <% end %>
      </div>
      <button type="button"
              class="highlights-slider-arrow highlights-slider-arrow-overlay highlights-slider-arrow-next genre-lane-arrow"
              data-highlights-slider-target="nextButton"
              data-action="click->highlights-slider#next"
              aria-label="Weiter">
        ›
      </button>
    </div>
  </div>

  <div class="section-slider-list genre-lane-list" data-section-view-target="list" hidden>
    <%= render "event_rows",
               events: events,
               browse_state: browse_state,
               effective_series_ids: effective_series_ids,
               strict_proxy: strict_proxy %>
  </div>
</section>
