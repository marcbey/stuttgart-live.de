<% content_for :title, presenter.page_title %>
<% content_for :head do %>
  <%= tag.meta property: "og:title", content: presenter.meta_title %>
  <%= tag.meta property: "og:description", content: presenter.meta_description %>
  <%= tag.meta property: "og:type", content: "website" %>
  <%= tag.meta property: "og:image", content: presenter.og_image_url if presenter.og_image_url.present? %>
  <%= tag.meta name: "twitter:card", content: "summary_large_image" %>
  <%= tag.meta name: "twitter:title", content: presenter.meta_title %>
  <%= tag.meta name: "twitter:description", content: presenter.meta_description %>
  <%= tag.link rel: "canonical", href: presenter.canonical_url %>
<% end %>
