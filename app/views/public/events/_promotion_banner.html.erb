<article class="promotion-banner">
  <% if authenticated? && current_user.blog_access? %>
    <div class="promotion-banner-admin-controls">
      <%= link_to "Bearbeiten",
                  edit_backend_blog_post_path(blog_post),
                  class: "event-card-admin-link event-card-admin-link-attention",
                  data: { turbo: false } %>
    </div>
  <% end %>
  <%= link_to news_path(blog_post.slug), class: "promotion-banner-link" do %>
    <div class="promotion-banner-media">
      <%= image_tag blog_post.promotion_banner_image, alt: blog_post.title, class: "promotion-banner-image" %>
    </div>

    <div class="promotion-banner-copy">
      <p class="promotion-banner-kicker">Promotion</p>
      <h2><%= blog_post.title %></h2>
      <span class="promotion-banner-cta">Zum Beitrag</span>
    </div>
  <% end %>
</article>
