<%= render "public/events/promotion_banner_component",
           article_classes: "promotion-banner promotion-banner-poster promotion-banner-news",
           article_style: "--promotion-banner-background: #{blog_post.promotion_banner_background_color_value}",
           admin_link_path: (authenticated? && current_user.blog_access? ? edit_backend_blog_post_path(blog_post) : nil),
           admin_link_label: "Edit",
           href: news_path(blog_post.slug),
           link_classes: "promotion-banner-link promotion-banner-link-#{blog_post.promotion_banner_text_color_scheme}",
           link_style: "background: var(--promotion-banner-background)",
           image_source: optimized_blog_post_image_source(blog_post, :promotion_banner_image, strict_proxy: true),
           image_alt: blog_post.title,
           image_style: blog_post_cropped_image_style(blog_post, :promotion_banner_image, frame_ratio: 16.0 / 9.0),
           image_loading: "eager",
           image_fetchpriority: "high",
           image_decoding: "async",
           credit: blog_post_image_copyright(blog_post, :promotion_banner_image),
           kicker_text: blog_post.promotion_banner_kicker_text_value,
           heading: blog_post.title,
           subheading: nil,
           cta_text: blog_post.promotion_banner_cta_text_value %>
