<article class="promotion-banner">
  <% if authenticated? && current_user.blog_access? %>
    <div class="promotion-banner-admin-controls">
      <%= link_to "Bearbeiten",
                  edit_backend_blog_post_path(blog_post),
                  class: "event-card-admin-link event-card-admin-link-attention",
                  data: { turbo: false } %>
    </div>
  <% end %>
  <%= link_to news_path(blog_post.slug), class: "promotion-banner-link" do %>
    <div class="promotion-banner-media">
      <%= image_tag optimized_blog_post_image_representation(blog_post, :promotion_banner_image),
                    alt: blog_post.title,
                    class: "promotion-banner-image",
                    style: blog_post_cropped_image_style(blog_post, :promotion_banner_image, frame_ratio: 16.0 / 9.0) %>
      <% if blog_post_image_copyright(blog_post, :promotion_banner_image).present? %>
        <p class="promotion-banner-credit"><%= blog_post_image_copyright(blog_post, :promotion_banner_image) %></p>
      <% end %>
    </div>

    <div class="promotion-banner-copy">
      <p class="promotion-banner-kicker"><%= blog_post.promotion_banner_kicker_text_value %></p>
      <h2><%= blog_post.title %></h2>
      <span class="promotion-banner-cta"><%= blog_post.promotion_banner_cta_text_value %></span>
    </div>
  <% end %>
</article>
