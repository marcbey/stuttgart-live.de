<% presenters = Array(local_assigns.fetch(:presenters, [])) %>
<% if presenters.any? %>
  <div class="event-detail-organizer-presenters" aria-label="Präsentatoren">
    <h3 class="event-detail-organizer-sidebar-heading">Diese Veranstaltung wird präsentiert von:</h3>
    <div class="event-detail-organizer-partner-grid" role="list">
      <% presenters.each do |item| %>
        <% if item.external_url.present? %>
          <%= link_to item.external_url,
                      class: "event-detail-organizer-partner",
                      role: "listitem",
                      target: "_blank",
                      rel: "noopener",
                      aria: { label: item.name } do %>
            <%= image_tag item.logo_source, alt: item.name, class: "event-detail-organizer-partner-image" %>
          <% end %>
        <% else %>
          <div class="event-detail-organizer-partner"
               role="listitem"
               aria-label="<%= item.name %>">
            <%= image_tag item.logo_source, alt: item.name, class: "event-detail-organizer-partner-image" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>
