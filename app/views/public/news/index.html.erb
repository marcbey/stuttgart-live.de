<% content_for :title, "Stuttgart Live - News" %>
<% newsletter_signup = newsletter_signup_config("news_index", return_to: request.fullpath) %>
<% content_for :page_newsletter, "" if @blog_posts.size > 4 %>
<section class="news-shell news-index-shell">
  <header class="news-hero news-index-hero">
    <p class="news-kicker">Redaktion</p>
    <h1>Aktuelle News</h1>
  </header>

  <% if @blog_posts.any? %>
    <div class="news-grid news-index-grid">
      <% @blog_posts.each_with_index do |blog_post, index| %>
        <article class="news-card news-index-card <%= 'news-index-card-no-image' unless blog_post.cover_image.attached? %>">
          <%= link_to news_path(blog_post.slug), class: "news-index-card-link" do %>
            <% if blog_post.cover_image.attached? %>
              <div class="news-card-media news-index-card-media">
                <%= image_tag optimized_blog_post_image_representation(blog_post, :cover_image),
                              alt: blog_post.title,
                              class: "news-list-item-image",
                              style: blog_post_image_style(blog_post, :cover_image) %>
              </div>
            <% end %>

            <div class="news-card-body news-index-card-body">
              <span class="news-index-accent" aria-hidden="true"></span>
              <p class="news-card-meta">
                <span><%= l(blog_post.published_at.to_date, format: "%d.%m.%Y") %></span>
              </p>
              <h2><%= blog_post.title %></h2>
              <p class="news-index-card-teaser"><%= blog_post.teaser %></p>
            </div>
          <% end %>
        </article>

        <% if index == 3 && @blog_posts.size > 4 %>
          <div class="news-index-newsletter-slot">
            <%= render "public/events/newsletter_signup",
                       subscriber: NewsletterSubscriber.new,
                       signup: newsletter_signup %>
          </div>
        <% end %>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">Keine passenden News gefunden.</div>
  <% end %>
</section>
