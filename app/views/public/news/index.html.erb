<% content_for :title, "Stuttgart Live - News" %>

<section class="news-shell news-index-shell">
  <header class="news-hero news-index-hero">
    <p class="news-kicker">Redaktion</p>
    <h1>Freshly Squeezed News</h1>
    <%= form_with model: NewsletterSubscriber.new,
                  url: newsletter_subscribers_path,
                  method: :post,
                  local: true,
                  class: "newsletter-signup-form news-index-subscribe-form" do |form| %>
      <%= hidden_field_tag :return_to, news_index_path %>
      <%= hidden_field_tag :source, "news_index" %>
      <%= form.email_field :email,
                           autocomplete: "email",
                           placeholder: "E-Mail-Adresse fuer News-Updates",
                           required: true,
                           class: "form-input newsletter-signup-input" %>
      <%= form.submit "News abonnieren", class: "button newsletter-signup-button" %>
    <% end %>
  </header>

  <% if @blog_posts.any? %>
    <div class="news-grid news-index-grid">
      <% @blog_posts.each do |blog_post| %>
        <article class="news-card news-index-card <%= 'news-index-card-no-image' unless blog_post.cover_image.attached? %>">
          <% if blog_post.cover_image.attached? %>
            <%= link_to news_path(blog_post.slug), class: "news-card-media news-index-card-media" do %>
              <%= image_tag blog_post.cover_image, alt: blog_post.title, class: "news-list-item-image" %>
            <% end %>
          <% end %>

          <div class="news-card-body news-index-card-body">
            <span class="news-index-accent" aria-hidden="true"></span>
            <p class="news-card-meta">
              <span><%= l(blog_post.published_at.to_date, format: "%d.%m.%Y") %></span>
            </p>
            <h2><%= link_to blog_post.title, news_path(blog_post.slug) %></h2>
            <p class="news-index-card-teaser"><%= blog_post.teaser %></p>
          </div>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">Keine passenden News gefunden.</div>
  <% end %>
</section>
