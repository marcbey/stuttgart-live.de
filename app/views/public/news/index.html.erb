<% content_for :title, "Stuttgart Live - News" %>
<section class="news-shell news-index-shell">
  <header class="news-hero news-index-hero">
    <p class="news-kicker">Redaktion</p>
    <h1>Aktuelle News</h1>
  </header>

  <% if @blog_posts.any? %>
    <div class="news-grid news-index-grid">
      <% @blog_posts.each_with_index do |blog_post, index| %>
        <article class="news-card news-index-card">
          <%= link_to news_path(blog_post.slug), class: "news-index-card-link" do %>
            <div class="news-card-body news-index-card-body">
              <span class="news-index-accent" aria-hidden="true"></span>
              <p class="news-card-meta">
                <span><%= l(blog_post.published_at.to_date, format: "%d.%m.%Y") %></span>
              </p>
              <h2><%= blog_post.title %></h2>
              <p class="news-index-card-teaser"><%= blog_post.teaser %></p>
            </div>
          <% end %>
        </article>

        <% if index == 4 %>
          <article class="news-card news-index-card news-index-card-newsletter">
            <%= link_to news_index_path(anchor: "site-footer"),
                        class: "news-index-card-link news-index-newsletter-card-link",
                        data: { turbo: false } do %>
              <div class="news-index-newsletter-promo">
                <h2 class="news-index-newsletter-title">Nichts verpassen</h2>
                <p class="news-index-newsletter-copy">Konzerte, Highlights und Vorverkaeufe. Direkt im Postfach.</p>
                <span class="news-index-newsletter-jump">Zum Newsletter</span>
              </div>
            <% end %>
          </article>
        <% end %>
      <% end %>

      <% if @blog_posts.size < 5 %>
        <article class="news-card news-index-card news-index-card-newsletter">
          <%= link_to news_index_path(anchor: "site-footer"),
                      class: "news-index-card-link news-index-newsletter-card-link",
                      data: { turbo: false } do %>
            <div class="news-index-newsletter-promo">
              <h2 class="news-index-newsletter-title">Nichts verpassen</h2>
              <p class="news-index-newsletter-copy">Konzerte, Highlights und Vorverkaeufe. Direkt im Postfach.</p>
              <span class="news-index-newsletter-jump">Zum Newsletter</span>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state">Keine passenden News gefunden.</div>
  <% end %>
</section>
