<% content_for :title, "#{@blog_post.title} | Stuttgart Live" %>

<article class="event-detail news-detail">
  <div class="event-detail-topbar">
    <p class="event-detail-back"><%= link_to "← alle news", news_index_path %></p>
    <% if authenticated? && current_user.blog_access? %>
      <div class="event-detail-topbar-actions">
        <%= link_to "Bearbeiten",
                    edit_backend_blog_post_path(@blog_post),
                    class: "event-card-admin-link event-card-admin-link-attention event-detail-edit-link",
                    data: { turbo: false } %>
      </div>
    <% end %>
  </div>

  <header class="event-detail-header news-detail-header <%= 'news-detail-header-with-image' if @blog_post.cover_image.attached? %>">
    <h1 class="news-detail-heading"><%= @blog_post.title %></h1>

    <div class="news-detail-header-copy">
      <p class="event-detail-title"><%= @blog_post.teaser %></p>
      <p class="event-detail-meta event-detail-meta-primary">
        <span class="event-detail-meta-strong">News</span>
        <span class="event-detail-meta-strong"><%= l(@blog_post.published_at.to_date, format: "%d.%m.%Y") %></span>
        <span class="event-detail-meta-strong"><%= @blog_post.display_author_name %></span>
      </p>
    </div>

    <% if @blog_post.cover_image.attached? %>
      <div class="event-detail-image-wrap">
        <%= image_tag @blog_post.cover_image, alt: @blog_post.title, class: "event-detail-image" %>
      </div>
    <% end %>
  </header>

  <section class="event-detail-copy news-detail-copy">
    <%= @blog_post.body %>
  </section>

  <% if @blog_post.youtube_video_urls.any? %>
    <section class="event-detail-video">
      <h2>Videos</h2>
      <div class="news-video-stack">
        <% @blog_post.youtube_video_urls.each do |youtube_url| %>
          <%= render "shared/consent_video_embed",
                     title: "#{@blog_post.title} auf YouTube",
                     url: youtube_url %>
        <% end %>
      </div>
    </section>
  <% end %>
</article>
