<% presenter = public_news_show_presenter(@blog_post) %>
<%= render "show_meta", presenter: presenter %>

<article class="event-detail news-detail">
  <div class="event-detail-topbar">
    <p class="event-detail-back"><%= link_to "← alle news", presenter.back_path %></p>
    <% if authenticated? && current_user.blog_access? %>
      <div class="event-detail-topbar-actions">
        <%= link_to "Edit",
                    edit_backend_blog_post_path(@blog_post),
                    class: "button button-secondary button-compact event-detail-edit-link public-edit-link",
                    data: { turbo: false } %>
      </div>
    <% end %>
  </div>

  <%= render "show_hero", presenter: presenter %>

  <div class="event-detail-body">
    <div class="event-detail-main">
      <section class="event-detail-panel event-detail-copy event-detail-copy-primary news-detail-copy">
        <%= presenter.body %>
      </section>

      <% if presenter.has_video_block? %>
        <%= render "show_media", presenter: presenter %>
      <% end %>
    </div>
  </div>
</article>
