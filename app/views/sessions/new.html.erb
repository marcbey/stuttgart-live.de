<% content_for :title, "Login" %>

<section class="backend-shell">
  <div class="editor-panel" style="max-width: 520px; margin: 2rem auto;">
    <header>
      <p class="eyebrow eyebrow-logo"><%= brand_logo_tag(class_name: "brand-logo brand-logo-eyebrow") %></p>
      <h1 style="margin: 0.4rem 0 0; text-transform: uppercase;">Login Redaktion</h1>
    </header>

    <%= form_with url: session_path, class: "editor-form" do |form| %>
      <div>
        <%= form.label :email_address, "E-Mail", class: "form-label" %>
        <%= form.email_field :email_address,
                             required: true,
                             autofocus: true,
                             autocomplete: "username",
                             placeholder: "name@example.com",
                             value: params[:email_address],
                             class: "form-input" %>
      </div>

      <div>
        <%= form.label :password, "Passwort", class: "form-label" %>
        <%= form.password_field :password,
                                required: true,
                                autocomplete: "current-password",
                                placeholder: "Passwort",
                                maxlength: 72,
                                class: "form-input" %>
      </div>

      <div class="editor-footer">
        <%= form.submit "Einloggen", class: "button" %>
        <%= link_to "Passwort vergessen", new_password_path, class: "button button-secondary" %>
      </div>
    <% end %>
  </div>
</section>
