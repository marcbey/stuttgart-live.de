<% content_for :title, "Login" %>

<section class="public-shell auth-shell">
  <div class="auth-card">
    <header class="auth-card-header">
      <p class="news-kicker">Redaktion</p>
      <h1>Login</h1>
      <p class="auth-card-lead">Zugang fuerr Redaktion, Pflege und interne Arbeitsbereiche.</p>
    </header>

    <%= form_with url: session_path, class: "editor-form auth-form" do |form| %>
      <div>
        <%= form.label :email_address, "E-Mail", class: "form-label" %>
        <%= form.email_field :email_address,
                             required: true,
                             autofocus: true,
                             autocomplete: "username",
                             placeholder: "name@example.com",
                             value: params[:email_address],
                             class: "form-input" %>
      </div>

      <div>
        <%= form.label :password, "Passwort", class: "form-label" %>
        <%= form.password_field :password,
                                required: true,
                                autocomplete: "current-password",
                                placeholder: "Passwort",
                                maxlength: 72,
                                class: "form-input" %>
      </div>

      <div class="auth-actions">
        <%= form.submit "Einloggen", class: "button" %>
        <%= link_to "Passwort vergessen", new_password_path, class: "button button-secondary" %>
      </div>
    <% end %>
  </div>
</section>
