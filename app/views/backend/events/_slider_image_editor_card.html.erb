<% optimized_image_source = optimized_event_image_source(image) %>
<% editor_form_id = local_assigns.fetch(:editor_form_id, dom_id(event, :editor_form)) %>

<li id="<%= dom_id(image, :slider_card) %>" class="slider-image-editor-card">
  <div class="action-cell slider-image-editor-thumb">
    <%= link_to optimized_image_source, target: "_blank", rel: "noopener" do %>
      <%= image_tag optimized_image_source, alt: image.alt_text.presence || "#{event.artist_name} - #{event.title}", style: "width:56px;height:56px;object-fit:cover;border:1px solid #ddd;" %>
    <% end %>
  </div>

  <div class="slider-image-editor-meta">
    <div class="slider-image-meta-form">
      <%= text_field_tag "event_image_updates[#{image.id}][alt_text]",
                         image.alt_text,
                         placeholder: "Alt-Text (optional)",
                         class: "form-input",
                         form: editor_form_id %>
      <%= text_field_tag "event_image_updates[#{image.id}][sub_text]",
                         image.sub_text,
                         placeholder: "Sub-Text (optional)",
                         class: "form-input",
                         form: editor_form_id %>
    </div>

    <div class="slider-image-meta-actions">
      <%= button_to "Delete Image",
                    backend_event_event_image_path(event, image, status: editor_status),
                    method: :delete,
                    class: "button button-ghost button-compact",
                    form: { data: { turbo_stream: true } } %>
    </div>
  </div>
</li>
