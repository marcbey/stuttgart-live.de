<% meta_form_id = dom_id(image, :meta) %>

<li id="<%= dom_id(image, :slider_card) %>" class="slider-image-editor-card">
  <div class="action-cell slider-image-editor-thumb">
    <%= link_to url_for(image.file), target: "_blank", rel: "noopener" do %>
      <%= image_tag image.file, alt: image.alt_text.presence || "#{event.artist_name} - #{event.title}", style: "width:56px;height:56px;object-fit:cover;border:1px solid #ddd;" %>
    <% end %>
  </div>

  <div class="slider-image-editor-meta">
    <%= form_with model: [ :backend, event, image ],
                  id: meta_form_id,
                  method: :patch,
                  class: "slider-image-meta-form",
                  data: { turbo_stream: true } do |form| %>
      <%= hidden_field_tag :status, editor_status %>
      <%= form.text_field :alt_text, placeholder: "Alt-Text (optional)", class: "form-input" %>
      <%= form.text_field :sub_text, placeholder: "Sub-Text (optional)", class: "form-input" %>
    <% end %>

    <div class="slider-image-meta-actions">
      <%= button_tag "Save Meta",
                     type: :submit,
                     form: meta_form_id,
                     class: "button button-ghost button-compact" %>
      <%= button_to "Delete Image",
                    backend_event_event_image_path(event, image, status: editor_status),
                    method: :delete,
                    class: "button button-ghost button-compact",
                    form: { data: { turbo_stream: true } } %>
    </div>
  </div>
</li>
