<% editor_form_id = local_assigns.fetch(:editor_form_id, dom_id(event, :editor_form)) %>

<div class="backend-section-stack">
  <section class="backend-section backend-section-compact editor-subsection">
    <div class="backend-section-header">
      <h3>Highlights-Teaser</h3>
    </div>
    <div class="backend-section-body">
      <label class="form-checkbox">
        <%= hidden_field_tag "event[highlighted]", "0", form: editor_form_id, id: nil %>
        <%= check_box_tag "event[highlighted]", "1", event.highlighted?, form: editor_form_id %>
        <span>Im Highlights-Teaser anzeigen</span>
      </label>
      <p class="form-hint">Zeigt das Event auf der Startseite unter „Highlights“ an, auch ohne SKS Promoter-ID.</p>
    </div>
  </section>

  <section class="backend-section backend-section-compact editor-subsection">
    <div class="backend-section-header">
      <h3>Promotion Banner</h3>
    </div>
    <div class="backend-section-body">
      <label class="form-checkbox form-checkbox-after-textarea">
        <%= hidden_field_tag "event[promotion_banner]", "0", form: editor_form_id, id: nil %>
        <%= check_box_tag "event[promotion_banner]",
                          "1",
                          event.promotion_banner?,
                          form: editor_form_id %>
        <span>Als Promotion Banner markieren</span>
      </label>
      <p class="form-hint">Es kann immer nur ein Event gleichzeitig als Promotion Banner aktiv sein. Auf der Startseite wird der Banner nur angezeigt, wenn auch ein Eventbild vorhanden ist.</p>

      <div class="editor-grid promotion-banner-settings-grid">
        <div>
          <%= label_tag "event_promotion_banner_kicker_text", "Kicker", class: "form-label" %>
          <%= text_field_tag "event[promotion_banner_kicker_text]",
                             event.promotion_banner_kicker_text,
                             id: "event_promotion_banner_kicker_text",
                             class: "form-input",
                             maxlength: 80,
                             placeholder: Event::DEFAULT_PROMOTION_BANNER_KICKER_TEXT,
                             form: editor_form_id %>
        </div>

        <div>
          <%= label_tag "event_promotion_banner_cta_text", "CTA-Text", class: "form-label" %>
          <%= text_field_tag "event[promotion_banner_cta_text]",
                             event.promotion_banner_cta_text,
                             id: "event_promotion_banner_cta_text",
                             class: "form-input",
                             maxlength: 80,
                             placeholder: Event::DEFAULT_PROMOTION_BANNER_CTA_TEXT,
                             form: editor_form_id %>
        </div>

        <div data-controller="promotion-banner-color"
             data-promotion-banner-color-default-color-value="<%= event.promotion_banner_background_color_value %>">
          <%= label_tag "event_promotion_banner_background_color", "Hintergrundfarbe", class: "form-label" %>
          <div class="promotion-banner-color-inputs">
            <%= text_field_tag "event[promotion_banner_background_color]",
                               event.promotion_banner_background_color,
                               id: "event_promotion_banner_background_color",
                               class: "form-input",
                               inputmode: "text",
                               maxlength: 7,
                               placeholder: Event::DEFAULT_PROMOTION_BANNER_BACKGROUND_COLOR,
                               form: editor_form_id,
                               data: {
                                 action: "input->promotion-banner-color#syncFromHex blur->promotion-banner-color#normalizeHex",
                                 promotion_banner_color_target: "hex"
                               } %>
            <%= color_field_tag "event_promotion_banner_background_color_picker",
                                event.promotion_banner_background_color_value,
                                id: "event_promotion_banner_background_color_picker",
                                class: "promotion-banner-color-picker",
                                form: editor_form_id,
                                data: {
                                  action: "input->promotion-banner-color#syncFromPicker change->promotion-banner-color#syncFromPicker",
                                  promotion_banner_color_target: "picker"
                                } %>
            <button type="button"
                    class="promotion-banner-color-eyedropper"
                    hidden
                    title="Farbe aus dem Browserfenster aufnehmen"
                    aria-label="Farbe aus dem Browserfenster aufnehmen"
                    data-action="click->promotion-banner-color#pickFromScreen"
                    data-promotion-banner-color-target="eyedropper">
              Pipette
            </button>
          </div>
          <p class="form-hint">Optional. Leer nutzt <%= Event::DEFAULT_PROMOTION_BANNER_BACKGROUND_COLOR %>.</p>
        </div>
      </div>

      <p class="form-hint">Leer gelassene Texte fallen automatisch auf die Standardwerte zurück.</p>

      <%= fields_for :event, event do |form| %>
        <%= render "backend/shared/promotion_banner_image_editor",
                   form: form,
                   form_id: editor_form_id,
                   title: "Promotion-Banner-Bild",
                   description: "Wird auf der Startseite unter den Highlights in voller Breite angezeigt.",
                   section_classes: "promotion-banner-image-section",
                   image_blob: event.promotion_banner_image_blob_for_editor,
                   signed_input_name: "event_promotion_banner_image[promotion_banner_image_signed_id]",
                   signed_input_value: event.pending_promotion_banner_image_blob&.signed_id,
                   remove_input_name: "event_promotion_banner_image[remove_promotion_banner_image]",
                   remove_value: (event.remove_promotion_banner_image? ? "1" : "0"),
                   upload_input_id: "#{editor_form_id}_promotion_banner_image_upload",
                   copyright_attribute: :promotion_banner_image_copyright,
                   copyright_value: event.promotion_banner_image_copyright,
                   focus_x_attribute: :promotion_banner_image_focus_x,
                   focus_y_attribute: :promotion_banner_image_focus_y,
                   zoom_attribute: :promotion_banner_image_zoom,
                   focus_x_value: event.promotion_banner_image_focus_x_value,
                   focus_y_value: event.promotion_banner_image_focus_y_value,
                   zoom_value: event.promotion_banner_image_zoom_value,
                   image_alt: "#{event.artist_name} Promotion Banner",
                   preview_variant: "promotion-banner" %>
      <% end %>
    </div>
  </section>
</div>
