<% payload_presenter = event_payload_presenter(event) %>
<% payload_sources = payload_presenter.payload_sources %>

<section class="offer-section payload-section">
  <h3>Payload-Daten</h3>
  <% if payload_sources.any? %>
    <div class="payload-list">
      <% payload_sources.each do |payload_source| %>
        <details class="payload-entry">
          <summary>
            <strong><%= payload_source.source %></strong>
            <% if payload_source.external_event_id.present? %>
              <span>· ID <%= payload_source.external_event_id %></span>
            <% end %>
          </summary>

          <details class="payload-block">
            <summary>dump_payload</summary>
            <pre class="payload-json"><%= payload_source.formatted_dump_payload %></pre>
          </details>

          <details class="payload-block">
            <summary>detail_payload</summary>
            <pre class="payload-json"><%= payload_source.formatted_detail_payload %></pre>
          </details>
        </details>
      <% end %>
    </div>
  <% else %>
    <p>Keine Payload-Daten vorhanden.</p>
  <% end %>
</section>
