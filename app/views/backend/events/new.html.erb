<% content_for :title, "Neues Event" %>

<section class="backend-shell">
  <header class="backend-topbar">
    <div>
      <h1>Manuelles Event anlegen</h1>
    </div>
    <div class="backend-topbar-actions">
      <%= link_to "Zur Inbox", backend_events_path, class: "button button-secondary" %>
    </div>
  </header>

  <% hero_signed_ids = Array(@manual_image_form_values[:detail_hero_signed_ids]).reject(&:blank?) %>
  <% slider_signed_ids = Array(@manual_image_form_values[:slider_signed_ids]).reject(&:blank?) %>

  <div class="editor-panel">
    <%= form_with model: @event,
                  url: backend_events_path,
                  method: :post,
                  class: "editor-form",
                  html: { multipart: true },
                  data: {
                    controller: "event-image-preupload",
                    action: "submit->event-image-preupload#beforeSubmit",
                    event_image_preupload_direct_upload_url_value: rails_direct_uploads_path
                  } do |form| %>
      <%= render "backend/events/form_fields",
                 form: form,
                 event: @event,
                 all_genres: @all_genres,
                 selected_genre_ids: @selected_genre_ids,
                 editable_promoter_id: true,
                 manual_ticket_url: @manual_ticket_url %>

      <section class="offer-section event-image-section">
        <h3>Eventbild</h3>
        <div class="event-image-upload-grid">
          <div class="event-image-upload-form">
            <h4>Eventbild hochladen</h4>
            <p>Wird vorab hochgeladen und direkt im Formular angezeigt.</p>
            <%= file_field_tag "event_image[detail_hero_files][]",
                               accept: "image/*",
                               class: "form-input",
                               data: {
                                 event_image_preupload_target: "heroInput",
                                 action: "change->event-image-preupload#selectHero"
                               } %>
            <%= text_field_tag "event_image[detail_hero_sub_text]",
                               @manual_image_form_values[:detail_hero_sub_text],
                               placeholder: "Copyright unter dem Bild (optional)",
                               class: "form-input" %>
            <div class="preuploaded-image-list" data-event-image-preupload-target="heroPreview">
              <% hero_signed_ids.each do |signed_id| %>
                <% blob = preuploaded_blob_from_signed_id(signed_id) %>
                <% next if blob.blank? %>
                <%= render "backend/events/preuploaded_image_preview",
                           kind: "hero",
                           blob: blob,
                           signed_id: signed_id,
                           field_name: "event_image[detail_hero_signed_ids][]" %>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <section class="offer-section">
        <h3>Slider-Bilder</h3>
        <div class="event-image-upload-grid">
          <div class="event-image-upload-form">
            <h4>Slider-Bilder hochladen</h4>
            <p>Werden vorab hochgeladen und direkt im Formular angezeigt. Weitere Auswahl ergänzt die Vorschau.</p>
            <%= file_field_tag "event_image[slider_files][]",
                               multiple: true,
                               accept: "image/*",
                               class: "form-input",
                               data: {
                                 event_image_preupload_target: "sliderInput",
                                 action: "change->event-image-preupload#selectSlider"
                               } %>
            <%= text_field_tag "event_image[slider_alt_text]",
                               @manual_image_form_values[:slider_alt_text],
                               placeholder: "Alt-Text (optional)",
                               class: "form-input" %>
            <%= text_field_tag "event_image[slider_sub_text]",
                               @manual_image_form_values[:slider_sub_text],
                               placeholder: "Sub-Text unter dem Bild (optional)",
                               class: "form-input" %>
            <div class="preuploaded-image-list" data-event-image-preupload-target="sliderPreview">
              <% slider_signed_ids.each do |signed_id| %>
                <% blob = preuploaded_blob_from_signed_id(signed_id) %>
                <% next if blob.blank? %>
                <%= render "backend/events/preuploaded_image_preview",
                           kind: "slider",
                           blob: blob,
                           signed_id: signed_id,
                           field_name: "event_image[slider_signed_ids][]" %>
              <% end %>
            </div>
          </div>
        </div>
      </section>

      <p class="preuploaded-image-live-region" data-event-image-preupload-target="status" role="status" aria-live="polite"></p>

      <div class="editor-footer">
        <%= form.submit "Event erstellen", class: "button", data: { event_image_preupload_target: "submitButton" } %>
      </div>
    <% end %>
  </div>
</section>
