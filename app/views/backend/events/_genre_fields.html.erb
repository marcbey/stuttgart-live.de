<% selected_genre_ids = Array(local_assigns.fetch(:selected_genre_ids, event.genre_ids)).map(&:to_i) %>
<% editor_form_id = local_assigns.fetch(:editor_form_id, dom_id(event, :editor_form)) %>

<section class="backend-section backend-section-compact editor-subsection editor-genre-section">
  <div class="backend-section-header">
    <h3>Genres</h3>
  </div>
  <div class="backend-section-body">
    <%= label_tag "event_genre_ids", "Genres", class: "form-label sr-only" %>
    <%= hidden_field_tag "event[genre_ids][]", "", form: editor_form_id, id: nil %>
    <div class="genre-checks">
      <% all_genres.each do |genre| %>
        <label>
          <%= check_box_tag "event[genre_ids][]", genre.id, selected_genre_ids.include?(genre.id), form: editor_form_id %>
          <span><%= genre.name %></span>
        </label>
      <% end %>
    </div>
  </div>
</section>
