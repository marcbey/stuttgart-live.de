<section class="offer-section backend-section llm-enrichment-section">
  <% editor_form_id = local_assigns.fetch(:editor_form_id, dom_id(event, :editor_form)) %>
  <% llm_run_hint = event_llm_last_successful_run_hint(event) %>
  <% allow_run = local_assigns.fetch(:allow_run, event.persisted?) %>
  <% empty_state_message = local_assigns.fetch(:empty_state_message, "Für dieses Event gibt es noch kein LLM-Enrichment. Der manuelle Lauf legt beim Abschluss ein neues Enrichment an.") %>
  <div class="backend-section-header backend-section-header-with-actions">
    <div>
      <h3>LLM-Enrichment</h3>
    </div>
    <% if allow_run %>
      <%= turbo_stream_from [ :backend, :event_llm_enrichment, event.id ] %>
      <%= render "backend/events/llm_enrichment_run_controls",
                 event: event,
                 filter_status: filter_status %>
    <% end %>
  </div>

  <p class="form-hint">
    <% if allow_run %>
      Dieser Lauf verarbeitet nur dieses Event, überschreibt ein vorhandenes Enrichment und erscheint unter den LLM-Enrichment Jobs.
      <% if llm_run_hint.present? %>
        <br>
        <%= llm_run_hint %>
      <% end %>
    <% else %>
      Dieses Panel folgt derselben Struktur wie im Edit-Editor. LLM-Enrichment ist für neue Events erst verfügbar, sobald das Event gespeichert wurde.
    <% end %>
  </p>

  <% if llm_enrichment.present? %>
    <%= fields_for :event, event do |event_fields| %>
      <%= event_fields.fields_for :llm_enrichment, llm_enrichment do |form| %>
        <%= form.hidden_field :id, form: editor_form_id %>

        <div class="backend-section-stack">
          <section class="backend-section backend-section-compact">
            <div class="backend-section-header">
              <h3>Metadaten</h3>
            </div>
            <div class="backend-section-body">
              <div class="editor-grid">
                <div>
                  <%= form.label :venue, "Venue", class: "form-label" %>
                  <%= form.text_field :venue, class: "form-input", form: editor_form_id %>
                </div>
                <div>
                  <%= form.label :genre_list, "Genres", class: "form-label" %>
                  <%= form.text_area :genre_list, rows: 4, class: "form-textarea", form: editor_form_id %>
                  <p class="form-hint">Ein Genre pro Zeile oder durch Komma getrennt.</p>
                </div>
              </div>
            </div>
          </section>

          <section class="backend-section backend-section-compact">
            <div class="backend-section-header">
              <h3>Beschreibungen</h3>
            </div>
            <div class="backend-section-body llm-enrichment-copy-grid">
              <div>
                <%= form.label :event_description, "Event-Beschreibung", class: "form-label" %>
                <%= form.text_area :event_description, rows: 6, class: "form-textarea", form: editor_form_id %>
              </div>
            </div>
          </section>

          <section class="backend-section backend-section-compact">
            <div class="backend-section-header">
              <h3>Venue-Daten</h3>
            </div>
            <div class="backend-section-body">
              <div class="editor-grid">
                <div>
                  <%= llm_enrichment_link_label_row(form, :venue_external_url, "Venue-Link") %>
                  <%= form.url_field :venue_external_url, class: "form-input", form: editor_form_id %>
                </div>
                <div>
                  <%= form.label :venue_address, "Venue-Adresse", class: "form-label" %>
                  <%= form.text_field :venue_address, class: "form-input", form: editor_form_id %>
                </div>
              </div>
            </div>
          </section>

          <section class="backend-section backend-section-compact">
            <div class="backend-section-header">
              <h3>Links</h3>
            </div>
            <div class="backend-section-body">
              <div class="editor-grid">
                <div>
                  <%= llm_enrichment_link_label_row(form, :youtube_link, "YouTube-Link") %>
                  <%= form.url_field :youtube_link, class: "form-input", form: editor_form_id %>
                </div>
                <div>
                  <%= llm_enrichment_link_label_row(form, :instagram_link, "Instagram-Link") %>
                  <%= form.url_field :instagram_link, class: "form-input", form: editor_form_id %>
                </div>
                <div>
                  <%= llm_enrichment_link_label_row(form, :homepage_link, "Homepage-Link") %>
                  <%= form.url_field :homepage_link, class: "form-input", form: editor_form_id %>
                </div>
                <div>
                  <%= llm_enrichment_link_label_row(form, :facebook_link, "Facebook-Link") %>
                  <%= form.url_field :facebook_link, class: "form-input", form: editor_form_id %>
                </div>
              </div>
            </div>
          </section>
        </div>
      <% end %>
    <% end %>

    <div class="backend-section-header llm-enrichment-raw-response">
      <h3>Raw Response</h3>
      <% if (llm_job_run_hint = event_llm_last_successful_job_run_hint(event)).present? %>
        <p class="form-hint"><%= llm_job_run_hint %></p>
      <% end %>
    </div>
    <div class="backend-section-body">
      <% if (raw_response = event_llm_raw_response(event)).present? %>
        <pre class="payload-json llm-enrichment-raw-response-pre"><%= raw_response %></pre>
      <% else %>
        <p class="form-hint">Keine Raw Response für dieses Enrichment vorhanden.</p>
      <% end %>
    </div>
  <% else %>
    <section class="backend-section backend-section-compact">
      <div class="backend-section-body">
        <p class="form-hint"><%= empty_state_message %></p>
      </div>
    </section>
  <% end %>
</section>
