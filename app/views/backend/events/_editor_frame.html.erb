<%= turbo_frame_tag "event_editor" do %>
  <% if event.present? %>
    <%= render "backend/events/editor_panel",
               event: event,
               all_genres: all_genres,
               all_presenters: all_presenters,
               next_event_enabled: next_event_enabled,
               filter_status: filter_status,
               active_editor_tab: local_assigns[:active_editor_tab] %>
  <% else %>
    <div class="empty-state">Keine Events zur aktuellen Filterung.</div>
  <% end %>
<% end %>
