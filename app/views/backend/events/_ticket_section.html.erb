<% editor_form_id = local_assigns.fetch(:editor_form_id, dom_id(event, :editor_form)) %>
<% editor_offer = event.editor_ticket_offer %>
<% read_only_import_offer = editor_offer.present? && editor_offer.source.to_s != "manual" %>
<% display_ticket_url = local_assigns[:manual_ticket_url].nil? ? event_display_ticket_url(event) : local_assigns[:manual_ticket_url] %>
<% display_ticket_sold_out = local_assigns[:manual_ticket_sold_out].nil? ? event_display_ticket_sold_out(event) : local_assigns[:manual_ticket_sold_out] %>
<% source_label = event_editor_ticket_offer_source(event) %>

<section class="backend-section backend-section-form">
  <div class="backend-section-header">
    <h3>Ticket</h3>
  </div>
  <div class="backend-section-body">
    <div class="editor-grid">
      <div>
        <label class="form-label" for="<%= dom_id(event, :ticket_sold_out) %>">Ticket Verfügbarkeit</label>
        <% if read_only_import_offer %>
          <p><%= event_display_ticket_availability_label(event) %></p>
        <% else %>
          <%= hidden_field_tag "event[ticket_sold_out]", "0", form: editor_form_id, id: nil %>
          <label class="form-checkbox">
            <%= check_box_tag "event[ticket_sold_out]",
                              "1",
                              display_ticket_sold_out,
                              id: dom_id(event, :ticket_sold_out),
                              form: editor_form_id %>
            <span>Ausverkauft</span>
          </label>
        <% end %>
      </div>

      <div>
        <%= external_link_label_row(
          label_html: label_tag(dom_id(event, :ticket_url), "Ticket-URL", class: "form-label"),
          url: display_ticket_url,
          text: "Ticket-URL"
        ) %>
        <% if read_only_import_offer %>
          <%= url_field_tag "event[ticket_url]",
                            event_display_ticket_url(event),
                            id: dom_id(event, :ticket_url),
                            form: editor_form_id,
                            class: "form-input",
                            data: { source_locked: true } %>
        <% else %>
          <%= url_field_tag "event[ticket_url]",
                            display_ticket_url,
                            id: dom_id(event, :ticket_url),
                            form: editor_form_id,
                            class: "form-input" %>
        <% end %>
        <% if source_label.present? %>
          <p class="form-hint">Quelle: <%= source_label %></p>
        <% end %>
      </div>

      <div class="editor-grid-span-full">
        <label class="form-label" for="<%= dom_id(event, :ticket_special_note) %>">Ticket Sonderlocke</label>
        <%= text_field_tag "event[ticket_special_note]",
                           event.ticket_special_note,
                           id: dom_id(event, :ticket_special_note),
                           form: editor_form_id,
                           class: "form-input" %>
        <p class="form-hint">Wird bei ausverkauften oder abgesagten Events auf der Event-Detailseite statt des Ticket-Links angezeigt.</p>
      </div>
    </div>

  </div>
</section>
