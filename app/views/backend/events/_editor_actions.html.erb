<div class="editor-actions-row">
  <label class="check-inline">
    <%= check_box_tag "next_event_toggle", "1", next_event_enabled, data: { next_event_target: "toggle", action: "change->next-event#toggleChanged" } %>
    <span>auto-next</span>
  </label>
  <% if event.persisted? %>
    <button type="submit" form="<%= dom_id(event, :editor_form) %>" class="button button-save-primary button-compact">Save</button>
    <% unless event.published? %>
      <button type="submit" form="<%= dom_id(event, :editor_form) %>" name="save_and_publish" value="1" class="button button-compact">Publish</button>
    <% end %>
    <%= button_to "Facebook Publish",
                  quick_publish_backend_event_event_social_posts_path(event),
                  method: :post,
                  params: { platform: "facebook", inbox_status: filter_status },
                  class: "button button-secondary button-compact",
                  form: { data: { turbo_frame: "_top" } } %>
    <%= button_to "Instagram Publish",
                  quick_publish_backend_event_event_social_posts_path(event),
                  method: :post,
                  params: { platform: "instagram", inbox_status: filter_status },
                  class: "button button-secondary button-compact",
                  form: { data: { turbo_frame: "_top" } } %>
    <% if event.published? %>
      <%= button_to "Unpublish",
                    unpublish_backend_event_path(event),
                    method: :patch,
                    params: (filter_status.present? ? { inbox_status: filter_status } : {}),
                    class: "button button-secondary button-compact",
                    form: { data: { turbo_stream: true } } %>
    <% end %>
    <%= link_to "Open",
                event_path(event.slug),
                class: "button button-secondary button-compact",
                target: "_blank",
                rel: "noreferrer" %>
  <% else %>
    <button type="submit" form="<%= dom_id(event, :editor_form) %>" class="button button-save-primary button-compact">Save</button>
    <%= link_to "Cancel",
                backend_events_path(status: filter_status.presence),
                class: "button button-secondary button-compact",
                data: { turbo_frame: "_top" } %>
  <% end %>
</div>
