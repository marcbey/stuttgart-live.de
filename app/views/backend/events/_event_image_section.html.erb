<% event_image = event.event_images.detail_hero.ordered.first %>

<section id="<%= dom_id(event, :event_image_section) %>" class="offer-section event-image-section">
  <h3>Eventbild</h3>

  <% if event_image.present? %>
    <% optimized_event_image_source = optimized_event_image_source(event_image) %>
    <% editor_form_id = dom_id(event, :editor_form) %>
    <% event_image_sub_text_upload_id = dom_id(event_image, :upload_sub_text) %>
    <% selected_grid_variant = event_image.grid_variant.presence || EventImage::GRID_VARIANT_1X1 %>

    <div class="event-image-crop-shell">
      <div class="event-image-crop-editor" data-controller="event-image-crop-preview">
        <%= render "backend/events/event_image_crop_hidden_fields",
                   editor_form_id: editor_form_id,
                   event_image: event_image,
                   selected_grid_variant: selected_grid_variant %>
        <%= render "backend/events/event_image_crop_preview",
                   event: event,
                   optimized_event_image_source: optimized_event_image_source,
                   selected_grid_variant: selected_grid_variant %>
        <%= render "backend/events/event_image_crop_sidebar",
                   editor_form_id: editor_form_id,
                   editor_status: editor_status,
                   event: event,
                   event_image: event_image,
                   event_image_sub_text_upload_id: event_image_sub_text_upload_id,
                   selected_grid_variant: selected_grid_variant %>
      </div>
    </div>
  <% else %>
    <p>Noch kein Eventbild vorhanden.</p>

    <div class="event-image-upload-grid">
      <%= form_with url: backend_event_event_images_path(event),
                    method: :post,
                    class: "event-image-upload-form",
                    html: { multipart: true },
                    data: {
                      turbo_stream: true,
                      controller: "event-image-editor-upload",
                      action: "submit->event-image-editor-upload#beforeSubmit",
                      event_image_editor_upload_direct_upload_url_value: rails_direct_uploads_path,
                      event_image_editor_upload_signed_field_name_value: "event_image[signed_ids][]",
                      event_image_editor_upload_replace_existing_value: true
                    } do %>
        <%= hidden_field_tag :status, editor_status %>
        <%= hidden_field_tag "event_image[purpose]", EventImage::PURPOSE_DETAIL_HERO %>
        <h4>Eventbild hochladen</h4>
        <p>Wird direkt nach der Auswahl hochgeladen und angezeigt.</p>
        <%= file_field_tag "event_image[files][]",
                           accept: "image/*",
                           class: "event-image-inline-file-input",
                           id: dom_id(event, :empty_event_image_upload),
                           data: {
                             event_image_editor_upload_target: "input",
                             action: "change->event-image-editor-upload#select"
                           } %>
        <%= text_field_tag "event_image[sub_text]", nil, placeholder: "Copyright unter dem Bild (optional)", class: "form-input" %>
        <button type="button"
                class="button button-secondary button-compact"
                onclick="document.getElementById('<%= dom_id(event, :empty_event_image_upload) %>')?.click();">
          Bild auswählen
        </button>
        <div class="preuploaded-image-list" data-event-image-editor-upload-target="preview"></div>
        <p class="preuploaded-image-live-region" data-event-image-editor-upload-target="status" role="status" aria-live="polite"></p>
      <% end %>
    </div>
  <% end %>
</section>
