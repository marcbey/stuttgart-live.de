<section class="offer-section">
  <h3>Ticket-Angebote</h3>
  <% ticket_offers = if event.association(:event_offers).loaded?
                       event.event_offers.sort_by { |offer| [offer.priority_rank.to_i, offer.id.to_i] }
                     else
                       event.event_offers.ordered.to_a
                     end %>
  <% if ticket_offers.any? %>
    <ul>
      <% ticket_offers.each do |offer| %>
        <li>
          <span>
            <%= offer.source %>
            <% if offer.ticket_price_text.present? %>
              · Preis: <%= offer.ticket_price_text %>
            <% end %>
          </span>
          <% if offer.resolved_ticket_url.present? %>
            <%= link_to "Ticket", offer.resolved_ticket_url, target: "_blank", rel: "noopener" %>
          <% else %>
            <span>kein Link</span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p>Keine Angebote vorhanden.</p>
  <% end %>
</section>
