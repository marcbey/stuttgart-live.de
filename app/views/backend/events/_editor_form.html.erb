<%= form_with model: event,
              url: backend_event_path(event),
              method: :patch,
              class: "editor-form",
              data: { turbo_stream: true },
              html: { id: dom_id(event, :editor_form) } do |form| %>
  <%= hidden_field_tag :next_event_enabled, (next_event_enabled ? "1" : "0"), data: { next_event_target: "preference" } %>
  <%= hidden_field_tag :inbox_status, filter_status if filter_status.present? %>
  <%= hidden_field_tag :editor_tab,
                       local_assigns.fetch(:active_editor_tab, "event"),
                       data: { event_editor_tabs_target: "stateInput" } %>
  <%= hidden_field_tag "event[promotion_banner]",
                       (event.promotion_banner? ? "1" : "0"),
                       id: nil,
                       data: { event_editor_settings_target: "mirror", event_editor_settings_key: "promotion_banner" } %>
  <%= hidden_field_tag "event[promotion_banner_kicker_text]",
                       event.promotion_banner_kicker_text,
                       id: nil,
                       data: { event_editor_settings_target: "mirror", event_editor_settings_key: "promotion_banner_kicker_text" } %>
  <%= hidden_field_tag "event[promotion_banner_cta_text]",
                       event.promotion_banner_cta_text,
                       id: nil,
                       data: { event_editor_settings_target: "mirror", event_editor_settings_key: "promotion_banner_cta_text" } %>
  <%= render "backend/events/form_fields",
             form: form,
             event: event,
             all_genres: all_genres,
             editable_promoter_id: true,
             show_settings_section: false %>
<% end %>
