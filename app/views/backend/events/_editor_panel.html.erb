<% next_event_enabled = local_assigns.fetch(:next_event_enabled, true) %>
<% filter_status = local_assigns[:filter_status] %>
<% payload_sources = event_source_payloads(event) %>
<% display_promoter_id = event_display_promoter_id(event) %>
<% editor_status = filter_status.presence || event.status %>

<div class="editor-panel" id="event_editor">
  <header class="editor-header">
    <div>
      <p class="eyebrow">Event #<%= event.id %></p>
      <h2><%= event.artist_name.presence || "Unbenannt" %></h2>
      <p><%= event.title %></p>
    </div>
    <div class="editor-header-badges">
      <span class="<%= event_status_badge_class(event.status) %>"><%= event_status_label(event.status) %></span>
      <% if event.primary_source.present? %>
        <span class="status-badge status-badge-default"><%= event.primary_source %></span>
      <% end %>
      <%= link_to "Frontend",
                  event_path(event.slug),
                  class: "status-badge status-badge-default status-badge-link",
                  target: "_blank",
                  rel: "noopener" %>
    </div>
  </header>

  <%= form_with model: event,
                url: backend_event_path(event),
                method: :patch,
                class: "editor-form",
                html: { id: dom_id(event, :editor_form) } do |form| %>
    <%= hidden_field_tag :next_event_enabled, (next_event_enabled ? "1" : "0"), data: { next_event_target: "preference" } %>
    <%= hidden_field_tag :inbox_status, filter_status if filter_status.present? %>
    <div class="editor-grid">
      <div>
        <%= form.label :artist_name, "Artist", class: "form-label" %>
        <%= form.text_field :artist_name, class: "form-input", readonly: true, title: "Wird beim Merge aus dem Import aktualisiert." %>
      </div>
      <div>
        <%= form.label :title, "Titel", class: "form-label" %>
        <%= form.text_field :title, class: "form-input", readonly: true, title: "Wird beim Merge aus dem Import aktualisiert." %>
      </div>
      <div>
        <%= form.label :start_at, "Beginn", class: "form-label" %>
        <%= form.datetime_local_field :start_at,
                                      value: event.start_at&.strftime("%Y-%m-%dT%H:%M"),
                                      class: "form-input",
                                      readonly: true,
                                      title: "Wird beim Merge aus dem Import aktualisiert." %>
      </div>
      <div>
        <%= form.label :doors_at, "Einlass", class: "form-label" %>
        <div class="filter-date-wrap">
          <%= form.datetime_local_field :doors_at,
                                        value: event.doors_at&.strftime("%Y-%m-%dT%H:%M"),
                                        class: "form-input editor-datetime-input-with-clear",
                                        onfocus: "if(this.value) return; const startInput=this.form?.querySelector(\"input[name='event[start_at]']\"); if(!startInput||!startInput.value) return; const startDate=new Date(startInput.value); if(Number.isNaN(startDate.getTime())) return; startDate.setHours(startDate.getHours()-1); const pad=(num)=>String(num).padStart(2,'0'); const formatted=`${startDate.getFullYear()}-${pad(startDate.getMonth()+1)}-${pad(startDate.getDate())}T${pad(startDate.getHours())}:${pad(startDate.getMinutes())}`; this.value=formatted; this.dispatchEvent(new Event('input',{ bubbles: true })); this.dispatchEvent(new Event('change',{ bubbles: true }));" %>
          <%= button_tag "×",
                         type: "button",
                         class: "filter-date-clear filter-date-clear-visible editor-datetime-clear",
                         aria: { label: "Einlass löschen" },
                         onclick: "this.previousElementSibling.value=''; this.previousElementSibling.dispatchEvent(new Event('input', { bubbles: true })); this.previousElementSibling.dispatchEvent(new Event('change', { bubbles: true }));" %>
        </div>
      </div>
      <div>
        <%= form.label :status, "Status", class: "form-label" %>
        <%= form.select :status,
                        Event::STATUSES.reject { |status| status == "imported" }.map { |status| [event_status_select_label(status), status] },
                        {},
                        class: "form-input" %>
      </div>
      <div>
        <%= form.label :city, "Stadt", class: "form-label" %>
        <%= form.text_field :city, class: "form-input", readonly: true, title: "Wird beim Merge aus dem Import aktualisiert." %>
      </div>
      <div>
        <%= form.label :venue, "Venue", class: "form-label" %>
        <%= form.text_field :venue, class: "form-input", readonly: true, title: "Wird beim Merge aus dem Import aktualisiert." %>
      </div>
      <div>
        <label class="form-label" for="<%= dom_id(event, :promoter_id_display) %>">Promoter-ID</label>
        <input id="<%= dom_id(event, :promoter_id_display) %>"
               class="form-input"
               type="text"
               value="<%= display_promoter_id.presence || "-" %>"
               readonly>
      </div>
      <div>
        <%= form.label :badge_text, "Banderole", class: "form-label" %>
        <%= form.text_field :badge_text, class: "form-input" %>
      </div>
      <div>
        <%= form.label :youtube_url, "YouTube URL", class: "form-label" %>
        <%= form.url_field :youtube_url, class: "form-input" %>
      </div>
    </div>

    <div>
      <%= form.label :event_info, "Beschreibung", class: "form-label" %>
      <%= form.text_area :event_info, rows: 5, class: "form-textarea" %>
    </div>

    <div>
      <%= form.label :editor_notes, "Redaktionsnotiz", class: "form-label" %>
      <%= form.text_area :editor_notes, rows: 3, class: "form-textarea" %>
    </div>

    <div class="editor-footer">
      <div class="completeness-bar">
        <strong><%= event.completeness_score %>%</strong>
        <% if event.completeness_flags.any? %>
          <span><%= event.completeness_flags.join(", ") %></span>
        <% else %>
          <span>vollständig</span>
        <% end %>
      </div>
    </div>
  <% end %>

  <section class="offer-section">
    <h3>Ticket-Angebote</h3>
    <% if event.event_offers.any? %>
      <ul>
        <% event.event_offers.ordered.each do |offer| %>
          <li>
            <span>
              <%= offer.source %>
              <% if offer.ticket_price_text.present? %>
                · Preis: <%= offer.ticket_price_text %>
              <% end %>
            </span>
            <% if offer.resolved_ticket_url.present? %>
              <%= link_to "Ticket", offer.resolved_ticket_url, target: "_blank", rel: "noopener" %>
            <% else %>
              <span>kein Link</span>
            <% end %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>Keine Angebote vorhanden.</p>
    <% end %>
  </section>

  <section class="offer-section">
    <h3>Redaktionsbilder</h3>
    <div class="event-image-upload-grid">
      <%= form_with url: backend_event_event_images_path(event),
                    method: :post,
                    class: "event-image-upload-form",
                    html: { multipart: true },
                    data: { turbo: false } do %>
        <%= hidden_field_tag :status, editor_status %>
        <%= hidden_field_tag "event_image[purpose]", EventImage::PURPOSE_SLIDER %>
        <h4>Slider-Bilder</h4>
        <p>Unbegrenzt, Reihenfolge ohne Bedeutung.</p>
        <%= file_field_tag "event_image[files][]", multiple: true, accept: "image/*", required: true, class: "form-input" %>
        <%= text_field_tag "event_image[alt_text]", nil, placeholder: "Alt-Text (optional)", class: "form-input" %>
        <%= text_field_tag "event_image[sub_text]", nil, placeholder: "Sub-Text unter dem Bild (optional)", class: "form-input" %>
        <%= button_tag "Slider-Bilder hochladen", type: :submit, class: "button button-secondary" %>
      <% end %>

      <%= form_with url: backend_event_event_images_path(event),
                    method: :post,
                    class: "event-image-upload-form",
                    html: { multipart: true },
                    data: { turbo: false } do %>
        <%= hidden_field_tag :status, editor_status %>
        <%= hidden_field_tag "event_image[purpose]", EventImage::PURPOSE_DETAIL_HERO %>
        <h4>Detail-Header</h4>
        <p>Überschreibt XML-Hero, immer genau ein Bild.</p>
        <%= file_field_tag "event_image[files][]", accept: "image/*", required: true, class: "form-input" %>
        <%= text_field_tag "event_image[alt_text]", nil, placeholder: "Alt-Text (optional)", class: "form-input" %>
        <%= text_field_tag "event_image[sub_text]", nil, placeholder: "Sub-Text (optional)", class: "form-input" %>
        <%= button_tag "Header-Bild hochladen", type: :submit, class: "button button-secondary" %>
      <% end %>

      <%= form_with url: backend_event_event_images_path(event),
                    method: :post,
                    class: "event-image-upload-form",
                    html: { multipart: true },
                    data: { turbo: false } do %>
        <%= hidden_field_tag :status, editor_status %>
        <%= hidden_field_tag "event_image[purpose]", EventImage::PURPOSE_GRID_TILE %>
        <h4>Events-Grid Kachel</h4>
        <p>Feste Zuordnung je Variante (1x1, 2x1, 1x2, 2x2).</p>
        <%= select_tag "event_image[grid_variant]",
                       options_for_select(EventImage::GRID_VARIANTS),
                       class: "form-input" %>
        <%= file_field_tag "event_image[files][]", accept: "image/*", required: true, class: "form-input" %>
        <%= text_field_tag "event_image[alt_text]", nil, placeholder: "Alt-Text (optional)", class: "form-input" %>
        <%= text_field_tag "event_image[sub_text]", nil, placeholder: "Sub-Text (optional)", class: "form-input" %>
        <%= button_tag "Grid-Bild hochladen", type: :submit, class: "button button-secondary" %>
      <% end %>
    </div>

    <% if event.event_images.any? %>
      <ul>
        <% event.event_images.ordered.each do |image| %>
          <li>
            <span><%= image.label %></span>
            <div class="action-cell">
              <%= image_tag image.file, alt: image.alt_text.presence || "#{event.artist_name} - #{event.title}", style: "width:56px;height:56px;object-fit:cover;border:1px solid #ddd;" %>
              <%= link_to "Öffnen", url_for(image.file), target: "_blank", rel: "noopener" %>
            </div>

            <%= form_with model: [ :backend, event, image ],
                          method: :patch,
                          class: "event-image-meta-form",
                          data: { turbo: false } do |form| %>
              <%= hidden_field_tag :status, editor_status %>
              <%= form.text_field :alt_text, placeholder: "Alt-Text (optional)", class: "form-input" %>
              <%= form.text_field :sub_text, placeholder: "Sub-Text (optional)", class: "form-input" %>
              <% if image.grid_tile? %>
                <div class="event-image-crop-editor" data-controller="event-image-crop-preview">
                  <div class="event-image-crop-preview">
                    <div class="event-image-crop-frame">
                      <%= image_tag image.file,
                                    alt: image.alt_text.presence || "#{event.artist_name} - #{event.title}",
                                    class: "event-image-crop-preview-image",
                                    style: event_card_image_style(image),
                                    data: { event_image_crop_preview_target: "previewImage" } %>
                    </div>
                    <p>Kartenausschnitt-Vorschau (gleiches Format wie die Event-Karten).</p>
                  </div>

                  <div class="event-image-crop-controls">
                    <label class="form-label" for="<%= dom_id(image, :card_focus_x) %>">Ausschnitt horizontal <span data-event-image-crop-preview-target="focusXOutput"><%= image.card_focus_x_value.round %>%</span></label>
                    <%= form.range_field :card_focus_x,
                                         min: 0,
                                         max: 100,
                                         step: 1,
                                         id: dom_id(image, :card_focus_x),
                                         class: "form-range",
                                         data: { event_image_crop_preview_target: "focusX", action: "input->event-image-crop-preview#update" } %>

                    <label class="form-label" for="<%= dom_id(image, :card_focus_y) %>">Ausschnitt vertikal <span data-event-image-crop-preview-target="focusYOutput"><%= image.card_focus_y_value.round %>%</span></label>
                    <%= form.range_field :card_focus_y,
                                         min: 0,
                                         max: 100,
                                         step: 1,
                                         id: dom_id(image, :card_focus_y),
                                         class: "form-range",
                                         data: { event_image_crop_preview_target: "focusY", action: "input->event-image-crop-preview#update" } %>

                    <label class="form-label" for="<%= dom_id(image, :card_zoom) %>">Zoom <span data-event-image-crop-preview-target="zoomOutput"><%= image.card_zoom_value.round %>%</span></label>
                    <%= form.range_field :card_zoom,
                                         min: 100,
                                         max: 300,
                                         step: 5,
                                         id: dom_id(image, :card_zoom),
                                         class: "form-range",
                                         data: { event_image_crop_preview_target: "zoom", action: "input->event-image-crop-preview#update" } %>
                  </div>
                </div>
              <% end %>
              <%= form.submit "Meta speichern", class: "button button-ghost" %>
            <% end %>

            <%= button_to "Bild löschen",
                          backend_event_event_image_path(event, image, status: editor_status),
                          method: :delete,
                          class: "button button-ghost",
                          data: { turbo: false } %>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>Keine Redaktionsbilder vorhanden.</p>
    <% end %>
  </section>

  <section class="offer-section">
    <h3>Import-Bilder (XML)</h3>
    <% if event.import_event_images.any? %>
      <ul>
        <% event.import_event_images.ordered.each do |image| %>
          <li>
            <span><%= [ image.source, image.image_type, image.role, image.aspect_hint ].reject(&:blank?).join(" · ") %></span>
            <span class="action-cell">
              <%= image_tag image.image_url, alt: "#{event.artist_name} - #{event.title}", style: "width:56px;height:56px;object-fit:cover;border:1px solid #ddd;" %>
              <%= link_to "Öffnen", image.image_url, target: "_blank", rel: "noopener" %>
            </span>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p>Keine Bilder für dieses Event vorhanden.</p>
    <% end %>
  </section>

  <section class="offer-section payload-section">
    <h3>Payload-Daten</h3>
    <% if payload_sources.any? %>
      <div class="payload-list">
        <% payload_sources.each do |payload_source| %>
          <details class="payload-entry">
            <summary>
              <strong><%= payload_source[:source] %></strong>
              <% if payload_source[:external_event_id].present? %>
                <span>· ID <%= payload_source[:external_event_id] %></span>
              <% end %>
            </summary>

            <details class="payload-block">
              <summary>dump_payload</summary>
              <pre class="payload-json"><%= pretty_json_payload(payload_source[:dump_payload]) %></pre>
            </details>

            <details class="payload-block">
              <summary>detail_payload</summary>
              <pre class="payload-json"><%= pretty_json_payload(payload_source[:detail_payload]) %></pre>
            </details>
          </details>
        <% end %>
      </div>
    <% else %>
      <p>Keine Payload-Daten vorhanden.</p>
    <% end %>
  </section>

  <div class="editor-actions-row">
    <button type="submit" form="<%= dom_id(event, :editor_form) %>" class="button">Speichern</button>
    <% unless event.published? %>
      <button type="submit" form="<%= dom_id(event, :editor_form) %>" name="save_and_publish" value="1" class="button">Speichern & Publizieren</button>
    <% end %>
    <%= button_to "Depublizieren", unpublish_backend_event_path(event), method: :patch, class: "button button-secondary" %>
    <label class="check-inline">
      <%= check_box_tag "next_event_toggle", "1", next_event_enabled, data: { next_event_target: "toggle", action: "change->next-event#toggleChanged" } %>
      <span>nächsten Event anzeigen</span>
    </label>
  </div>
</div>
