<% inbox_status = local_assigns[:filter_status] %>
<% connection_resolver = Meta::ConnectionResolver.new %>
<% instagram_access_status = Meta::AccessStatus.new(platform: "instagram").call %>
<% facebook_access_status = Meta::AccessStatus.new(platform: "facebook").call %>
<% facebook_page_target = connection_resolver.facebook_connection&.selected_facebook_page_target %>

<div class="backend-section-stack">
  <section class="backend-section backend-section-compact">
    <div class="backend-section-header">
      <div>
        <h3>Social Publishing</h3>
        <p>Instagram-Draft bearbeiten und getrennt auf Instagram oder Facebook veröffentlichen.</p>
      </div>
    </div>

    <div class="backend-section-body">
      <div class="flash <%= instagram_access_status.error? && facebook_access_status.error? ? "flash-alert" : "flash-notice" %>">
        <div class="social-post-health-header">
          <strong>Meta-Verbindungen</strong>
          <span class="<%= meta_access_status_badge_class(instagram_access_status) %>">Instagram: <%= meta_access_status_label(instagram_access_status) %></span>
          <span class="<%= meta_access_status_badge_class(facebook_access_status) %>">Facebook: <%= meta_access_status_label(facebook_access_status) %></span>
        </div>
        <div><%= [ instagram_access_status.summary, facebook_access_status.summary ].join(" · ") %></div>
        <% if facebook_access_status.page_name.present? || instagram_access_status.instagram_username.present? %>
          <div class="form-hint">
            <% parts = [] %>
            <% parts << "Seite: #{facebook_access_status.page_name}" if facebook_access_status.page_name.present? %>
            <% parts << "Instagram: @#{instagram_access_status.instagram_username}" if instagram_access_status.instagram_username.present? %>
            <%= parts.join(" · ") %>
          </div>
        <% end %>
        <% if facebook_page_target.present? %>
          <div class="form-hint">Direktes Facebook-Publishing ist aktiv für <strong><%= facebook_page_target.display_name %></strong>.</div>
        <% else %>
          <div class="form-hint">Es ist aktuell keine Facebook-Seite für direktes Facebook-Publishing ausgewählt.</div>
        <% end %>
        <div class="social-post-action-row">
          <%= link_to "Instagram verbinden",
                      start_instagram_backend_meta_connection_path,
                      class: "button button-save-primary button-compact",
                      data: { turbo: false } %>
          <%= link_to "Facebook verbinden",
                      start_facebook_backend_meta_connection_path,
                      class: "button button-secondary button-compact",
                      data: { turbo: false } %>
        </div>
      </div>
    </div>

    <div class="backend-section-body social-post-platform-grid">
      <% social_post = event.instagram_social_post %>
      <% facebook_post = event.social_post_for("facebook") %>
      <% editable = social_post&.caption_editable? %>
      <% caption_form_id = social_post.present? ? dom_id(social_post, :caption_form) : nil %>

      <article class="social-post-card">
        <div class="backend-section-header backend-section-header-with-actions social-post-card-header">
          <div>
            <h3>Instagram</h3>
            <% unless social_post.present? %>
              <p>Für Instagram existiert noch kein Draft.</p>
            <% end %>
          </div>
          <% if social_post.present? && !social_post.draft? %>
            <div class="backend-section-header-actions">
              <span class="<%= event_social_post_status_badge_class(social_post) %>"><%= event_social_post_status_label(social_post) %></span>
            </div>
          <% elsif social_post.blank? %>
            <div class="backend-section-header-actions">
              <%= button_to "Instagram-Draft erzeugen",
                            backend_event_event_social_posts_path(event),
                            method: :post,
                            params: { inbox_status: inbox_status },
                            form: { data: { turbo_frame: "_top" } },
                            class: "button button-save-primary button-compact" %>
            </div>
          <% end %>
        </div>

        <% if social_post.present? %>
          <% if social_post.error_message.present? %>
            <div class="flash flash-alert">
              <strong>Letzter Fehler:</strong>
              <div><%= social_post.error_message %></div>
            </div>
          <% end %>

          <div class="social-post-card-body">
            <div class="social-post-preview">
              <% if social_post.publish_image_instagram_url.present? %>
                <img src="<%= social_post.publish_image_instagram_url %>"
                     alt="Instagram Vorschau"
                     class="social-post-preview-image">
              <% else %>
                <div class="social-post-preview-empty">Kein öffentlich erreichbares Bild verfügbar.</div>
              <% end %>
            </div>

            <div class="social-post-form-column">
              <%= form_with model: [ :backend, event, social_post ],
                            method: :patch,
                            id: caption_form_id,
                            class: "social-post-caption-form",
                            data: { turbo_frame: "_top" } do |form| %>
                <%= hidden_field_tag :inbox_status, inbox_status if inbox_status.present? %>

                <div class="social-post-form-field">
                  <%= form.label :card_artist_name, "Bildtext Artist", class: "form-label" %>
                  <%= form.text_field :card_artist_name,
                                      class: "form-input",
                                      disabled: !editable %>
                </div>

                <div class="social-post-form-field">
                  <%= form.label :card_meta_line, "Bildtext Datum & Venue", class: "form-label" %>
                  <%= form.text_field :card_meta_line,
                                      class: "form-input",
                                      disabled: !editable %>
                </div>

                <div class="social-post-form-field">
                  <%= form.label :caption, "Caption", class: "form-label" %>
                  <%= form.text_area :caption,
                                     rows: 8,
                                     class: "form-textarea",
                                     disabled: !editable %>
                  <% unless editable %>
                    <p class="form-hint">Zum Bearbeiten zuerst einen neuen Instagram-Draft erzeugen.</p>
                  <% end %>
                </div>
              <% end %>

              <div class="social-post-action-row">
                <% if editable %>
                  <%= button_tag "Caption speichern",
                                 type: :submit,
                                 form: caption_form_id,
                                 class: "button button-secondary button-compact" %>
                <% end %>
                <% unless social_post.publishing? %>
                  <%= button_to(social_post.published? ? "Instagram erneut veröffentlichen" : "Instagram veröffentlichen",
                                publish_backend_event_event_social_post_path(event, social_post),
                                method: :post,
                                params: { inbox_status: inbox_status, platform: "instagram" },
                                form: { data: { turbo_frame: "_top" }, class: "social-post-inline-action-form" },
                                class: "button button-save-primary button-compact") %>
                <% end %>
              </div>

              <div class="social-post-meta-list">
                <% if social_post.published_at.present? %>
                  <div>
                    <span class="form-label">Zuletzt gesendet</span>
                    <p><%= l(social_post.published_at, format: "%d.%m.%Y %H:%M") %><% if social_post.published_by&.name.present? %> · <%= social_post.published_by.name %><% end %></p>
                  </div>
                <% end %>
              </div>
            </div>
          </div>
        <% end %>
      </article>

      <article class="social-post-card">
        <div class="backend-section-header backend-section-header-with-actions social-post-card-header">
          <div>
            <h3>Facebook</h3>
            <% if facebook_page_target.present? %>
              <p>Zielseite: <strong><%= facebook_page_target.display_name %></strong></p>
            <% else %>
              <p>Direktes Facebook-Publishing ist nicht konfiguriert.</p>
            <% end %>
          </div>
          <% if facebook_post.present? %>
            <div class="backend-section-header-actions">
              <span class="<%= event_social_post_status_badge_class(facebook_post) %>"><%= event_social_post_status_label(facebook_post) %></span>
            </div>
          <% end %>
        </div>

        <div class="social-post-card-body">
          <div class="social-post-preview">
            <% preview_url = social_post&.publish_image_instagram_url.presence || facebook_post&.image_url %>
            <% if preview_url.present? %>
              <img src="<%= preview_url %>"
                   alt="Facebook Vorschau"
                   class="social-post-preview-image">
            <% else %>
              <div class="social-post-preview-empty">Kein Bild verfügbar.</div>
            <% end %>
          </div>

          <div class="social-post-form-column">
            <% if facebook_page_target.present? %>
              <div class="social-post-form-field">
                <label class="form-label">Publish-Modus</label>
                <p class="form-hint">Verwendet denselben Caption-Text und dasselbe Bild wie Instagram.</p>
              </div>
            <% else %>
              <div class="social-post-form-field">
                <label class="form-label">Status</label>
                <p class="form-hint">In Meta Publishing eine Facebook-Seite auswählen, um zusätzlich direkt auf Facebook zu veröffentlichen.</p>
              </div>
            <% end %>

            <% if facebook_post&.error_message.present? %>
              <div class="flash flash-alert">
                <strong>Letzter Fehler:</strong>
                <div><%= facebook_post.error_message %></div>
              </div>
            <% end %>

            <% if facebook_page_target.present? %>
              <div class="social-post-action-row">
                <% if facebook_post.present? && !facebook_post.publishing? %>
                  <%= button_to(facebook_post.published? ? "Facebook erneut veröffentlichen" : "Facebook veröffentlichen",
                                publish_backend_event_event_social_post_path(event, facebook_post),
                                method: :post,
                                params: { inbox_status: inbox_status, platform: "facebook" },
                                form: { data: { turbo_frame: "_top" }, class: "social-post-inline-action-form" },
                                class: "button button-save-primary button-compact") %>
                <% elsif social_post.present? %>
                  <%= button_to "Facebook veröffentlichen",
                                quick_publish_backend_event_event_social_posts_path(event),
                                method: :post,
                                params: { inbox_status: inbox_status, platform: "facebook" },
                                form: { data: { turbo_frame: "_top" }, class: "social-post-inline-action-form" },
                                class: "button button-save-primary button-compact" %>
                <% end %>
              </div>
            <% end %>

            <div class="social-post-meta-list">
              <% if facebook_post&.published_at.present? %>
                <div>
                  <span class="form-label">Zuletzt gesendet</span>
                  <p><%= l(facebook_post.published_at, format: "%d.%m.%Y %H:%M") %><% if facebook_post.published_by&.name.present? %> · <%= facebook_post.published_by.name %><% end %></p>
                </div>
              <% end %>
              <% if facebook_post&.published_post_url.present? %>
                <div>
                  <span class="form-label">Facebook-Post</span>
                  <p><%= link_to "Beitrag öffnen", facebook_post.published_post_url, target: "_blank", rel: "noopener" %></p>
                </div>
              <% end %>
              <% if facebook_post.present? && social_post.present? %>
                <div>
                  <span class="form-label">Content</span>
                  <p>Verwendet denselben Caption-Text und dasselbe Bild wie Instagram.</p>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      </article>
    </div>
  </section>
</div>
