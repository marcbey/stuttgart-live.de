<% inbox_status = local_assigns[:filter_status] %>

<div class="backend-section-stack">
  <section class="backend-section backend-section-compact">
    <div class="backend-section-header">
      <div>
        <h3>Social Publishing</h3>
        <p>Manuelle Drafts, Freigabe und Veröffentlichung für Facebook und Instagram.</p>
      </div>
    </div>

    <div class="backend-section-body social-post-platform-grid">
      <% EventSocialPost.platforms_for_select.each do |platform| %>
        <% social_post = event.social_post_for(platform) %>
        <% editable = social_post&.caption_editable? %>

        <article class="social-post-card">
          <div class="backend-section-header backend-section-header-with-actions">
            <div>
              <h3><%= event_social_post_platform_label(platform) %></h3>
              <% if social_post.present? %>
                <p>
                  <span class="<%= event_social_post_status_badge_class(social_post) %>"><%= event_social_post_status_label(social_post) %></span>
                </p>
              <% else %>
                <p>Für diese Plattform existiert noch kein Draft.</p>
              <% end %>
            </div>
            <div class="backend-section-header-actions">
              <% if social_post.present? %>
                <%= button_to "Draft neu erzeugen",
                              regenerate_backend_event_event_social_post_path(event, social_post),
                              method: :post,
                              params: { inbox_status: inbox_status },
                              form: { data: { turbo_frame: "_top" } },
                              class: "button button-secondary button-compact" %>
              <% else %>
                <%= button_to "Draft erzeugen",
                              backend_event_event_social_posts_path(event),
                              method: :post,
                              params: { platform:, inbox_status: inbox_status },
                              form: { data: { turbo_frame: "_top" } },
                              class: "button button-save-primary button-compact" %>
              <% end %>
            </div>
          </div>

          <% if social_post.present? %>
            <% if social_post.error_message.present? %>
              <div class="flash flash-alert">
                <strong>Letzter Fehler:</strong>
                <div><%= social_post.error_message %></div>
              </div>
            <% end %>

            <div class="social-post-card-body">
              <div class="social-post-preview">
                <% if social_post.image_url.present? %>
                  <img src="<%= social_post.image_url %>"
                       alt="<%= event_social_post_platform_label(platform) %> Vorschau"
                       class="social-post-preview-image">
                <% else %>
                  <div class="social-post-preview-empty">Kein öffentlich erreichbares Bild verfügbar.</div>
                <% end %>
              </div>

              <div class="social-post-form-column">
                <%= form_with model: [ :backend, event, social_post ],
                              method: :patch,
                              class: "social-post-caption-form",
                              data: { turbo_frame: "_top" } do |form| %>
                  <%= hidden_field_tag :inbox_status, inbox_status if inbox_status.present? %>

                  <div>
                    <%= form.label :caption, "Caption", class: "form-label" %>
                    <%= form.text_area :caption,
                                       rows: 8,
                                       class: "form-textarea",
                                       disabled: !editable %>
                    <% unless editable %>
                      <p class="form-hint">Zum Bearbeiten zuerst einen neuen Draft erzeugen.</p>
                    <% end %>
                  </div>

                  <div class="social-post-meta-list">
                    <div>
                      <span class="form-label">Event-Link</span>
                      <% if social_post.target_url.present? %>
                        <%= link_to social_post.target_url, social_post.target_url, target: "_blank", rel: "noreferrer", class: "social-post-link" %>
                      <% else %>
                        <p class="form-hint">Kein öffentlicher Event-Link verfügbar.</p>
                      <% end %>
                    </div>

                    <div>
                      <span class="form-label">Bild-Link</span>
                      <% if social_post.image_url.present? %>
                        <%= link_to social_post.image_url, social_post.image_url, target: "_blank", rel: "noreferrer", class: "social-post-link" %>
                      <% else %>
                        <p class="form-hint">Kein öffentlicher Bild-Link verfügbar.</p>
                      <% end %>
                    </div>

                    <% if social_post.remote_media_id.present? %>
                      <div>
                        <span class="form-label">Remote Media ID</span>
                        <p><code><%= social_post.remote_media_id %></code></p>
                      </div>
                    <% end %>

                    <% if social_post.remote_post_id.present? %>
                      <div>
                        <span class="form-label">Remote Post ID</span>
                        <p><code><%= social_post.remote_post_id %></code></p>
                      </div>
                    <% end %>
                  </div>

                  <% if editable %>
                    <div class="social-post-action-row">
                      <%= form.submit "Caption speichern", class: "button button-secondary button-compact" %>
                    </div>
                  <% end %>
                <% end %>

                <div class="social-post-action-row">
                  <% unless social_post.published? %>
                    <%= button_to "Freigeben",
                                  approve_backend_event_event_social_post_path(event, social_post),
                                  method: :patch,
                                  params: { inbox_status: inbox_status },
                                  form: { data: { turbo_frame: "_top" } },
                                  class: "button button-secondary button-compact" %>
                  <% end %>

                  <% if social_post.approved? || social_post.failed? %>
                    <%= button_to "Veröffentlichen",
                                  publish_backend_event_event_social_post_path(event, social_post),
                                  method: :post,
                                  params: { inbox_status: inbox_status },
                                  form: { data: { turbo_frame: "_top" } },
                                  class: "button button-save-primary button-compact" %>
                  <% end %>
                </div>

                <div class="social-post-meta-list">
                  <% if social_post.approved_at.present? %>
                    <div>
                      <span class="form-label">Freigegeben</span>
                      <p><%= l(social_post.approved_at, format: "%d.%m.%Y %H:%M") %><% if social_post.approved_by&.name.present? %> · <%= social_post.approved_by.name %><% end %></p>
                    </div>
                  <% end %>

                  <% if social_post.published_at.present? %>
                    <div>
                      <span class="form-label">Veröffentlicht</span>
                      <p><%= l(social_post.published_at, format: "%d.%m.%Y %H:%M") %><% if social_post.published_by&.name.present? %> · <%= social_post.published_by.name %><% end %></p>
                    </div>
                  <% end %>
                </div>
              </div>
            </div>
          <% end %>
        </article>
      <% end %>
    </div>
  </section>
</div>
