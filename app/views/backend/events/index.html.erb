<% content_for :title, "Redaktion" %>
<% selected_event_context = if @selected_event.present?
                              [
                                @selected_event.artist_name.to_s.strip.presence,
                                @selected_event.title.to_s.strip.presence,
                                l(@selected_event.start_at, format: "%d.%m.%Y %H:%M")
                              ].compact.join(" · ")
                            end %>

<section class="backend-shell"
         data-controller="keyboard-shortcuts next-event"
         data-action="turbo:frame-load@document->next-event#syncActiveFromEditor turbo:submit-end@document->next-event#syncActiveAfterSubmit"
         data-next-event-enabled-value="<%= @next_event_enabled %>"
         data-next-event-preference-url-value="<%= next_event_preference_backend_events_path %>">
  <header class="backend-topbar backend-topbar-sticky">
    <div class="backend-topbar-title">
      <h1>Event-Inbox</h1>
      <span id="event_topbar_context"
            class="backend-topbar-context"
            data-next-event-target="selectedContext"><%= render "backend/events/topbar_context", event: @selected_event if @selected_event.present? %></span>
    </div>
    <div class="backend-topbar-controls">
      <%= render "backend/events/topbar_editor_actions",
                 event: @selected_event,
                 next_event_enabled: @next_event_enabled,
                 filter_status: @filters[:status] %>
      <div class="backend-topbar-actions">
        <%= link_to "New", new_backend_event_path, class: "button button-secondary button-compact" %>
      </div>
    </div>
  </header>

  <div class="backend-split">
    <aside class="backend-list-column">
      <div class="backend-status-row">
        <% @status_filters.each do |status| %>
          <% label = event_status_filter_label(status) %>
          <%= link_to backend_events_path(status: status), class: "status-chip #{'status-chip-active' if @filters[:status] == status}" do %>
            <span><%= label %></span>
          <% end %>
        <% end %>
      </div>

      <%= form_with url: apply_filters_backend_events_path,
                    method: :post,
                    class: "filter-form",
                    data: { controller: "merge-change-filter" } do |form| %>
        <%= form.hidden_field :status, value: @filters[:status] %>
        <div class="filter-grid">
          <div class="filter-search-field">
            <%= form.label :query, "Suche", class: "form-label" %>
            <div class="filter-date-wrap">
              <%= form.text_field :query,
                                  value: @filters[:query],
                                  placeholder: "Band, Venue, Stadt",
                                  class: "form-input filter-input-with-clear",
                                  data: { action: "keydown.enter->merge-change-filter#submitOnEnter" },
                                  oninput: "this.nextElementSibling.classList.toggle('filter-date-clear-visible', this.value.length > 0)" %>
              <%= button_tag "×",
                             type: "button",
                             class: "filter-date-clear filter-input-clear #{'filter-date-clear-visible' if @filters[:query].present?}",
                             aria: { label: "Suche löschen" },
                             onclick: "this.previousElementSibling.value=''; this.classList.remove('filter-date-clear-visible'); this.form.requestSubmit();" %>
            </div>
          </div>
          <div>
            <%= form.label :promoter_id, "Promoter-ID", class: "form-label" %>
            <div class="filter-date-wrap">
              <%= form.text_field :promoter_id,
                                  value: @filters[:promoter_id],
                                  placeholder: "zB 10135",
                                  class: "form-input filter-input-with-clear",
                                  data: { action: "keydown.enter->merge-change-filter#submitOnEnter" },
                                  oninput: "this.nextElementSibling.classList.toggle('filter-date-clear-visible', this.value.length > 0)" %>
              <%= button_tag "×",
                             type: "button",
                             class: "filter-date-clear filter-input-clear #{'filter-date-clear-visible' if @filters[:promoter_id].present?}",
                             aria: { label: "Promoter-ID löschen" },
                             onclick: "this.previousElementSibling.value=''; this.classList.remove('filter-date-clear-visible'); this.form.requestSubmit();" %>
            </div>
          </div>
          <div class="filter-merge-row">
            <div class="filter-merge-field">
              <%= form.label :merge_scope, "Import-Änderungen", class: "form-label" %>
              <%= form.select :merge_scope,
                              options_for_select([
                                ["Alle", "all"],
                                ["Letzter Merge", "last_merge"]
                              ], @filters[:merge_scope]),
                              {},
                              class: "form-input",
                              data: {
                                merge_change_filter_target: "scope",
                                action: "change->merge-change-filter#submit"
                              } %>
            </div>
            <div class="filter-merge-field">
              <%= form.label :merge_change_type, "Änderungstyp", class: "form-label" %>
              <%= form.select :merge_change_type,
                              options_for_select([
                                ["Alle", "all"],
                                ["Neu", "created"],
                                ["Aktualisiert", "updated"]
                              ], @filters[:merge_change_type]),
                              {},
                              class: "form-input",
                              disabled: @filters[:merge_scope] != "last_merge",
                              data: {
                                merge_change_filter_target: "changeType",
                                action: "change->merge-change-filter#submit"
                              } %>
            </div>
          </div>
          <div class="filter-date-row">
            <div class="filter-date-field">
              <%= form.label :starts_after, "Ab", class: "form-label" %>
              <div class="filter-date-wrap">
                <%= form.date_field :starts_after,
                                    value: @filters[:starts_after],
                                    class: "form-input filter-date-input",
                                    data: { action: "change->merge-change-filter#submit" },
                                    oninput: "this.nextElementSibling.classList.toggle('filter-date-clear-visible', this.value.length > 0)" %>
                <%= button_tag "×",
                               type: "button",
                               class: "filter-date-clear #{'filter-date-clear-visible' if @filters[:starts_after].present?}",
                               aria: { label: "Ab-Datum löschen" },
                               onclick: "this.previousElementSibling.value=''; this.form.requestSubmit();" %>
              </div>
            </div>

            <div class="filter-date-field">
              <%= form.label :starts_before, "Bis", class: "form-label" %>
              <div class="filter-date-wrap">
                <%= form.date_field :starts_before,
                                    value: @filters[:starts_before],
                                    class: "form-input filter-date-input",
                                    data: { action: "change->merge-change-filter#submit" },
                                    oninput: "this.nextElementSibling.classList.toggle('filter-date-clear-visible', this.value.length > 0)" %>
                <%= button_tag "×",
                               type: "button",
                               class: "filter-date-clear #{'filter-date-clear-visible' if @filters[:starts_before].present?}",
                               aria: { label: "Bis-Datum löschen" },
                               onclick: "this.previousElementSibling.value=''; this.form.requestSubmit();" %>
              </div>
            </div>
          </div>
        </div>
      <% end %>

      <%= render "events_list",
                 events: @events,
                 selected_event: @selected_event,
                 status: @filters[:status],
                 merge_run_id: @selected_merge_run_id,
                 filtered_events_count: @filtered_events_count %>
    </aside>

    <section class="backend-editor-column">
      <%= turbo_frame_tag "event_editor" do %>
        <% if @selected_event.present? %>
          <%= render "editor_panel", event: @selected_event, all_genres: @all_genres, next_event_enabled: @next_event_enabled, filter_status: @filters[:status] %>
        <% else %>
          <div class="empty-state">Keine Events zur aktuellen Filterung.</div>
        <% end %>
      <% end %>
    </section>
  </div>
</section>
