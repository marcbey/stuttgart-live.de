<% content_for :title, "Redaktion" %>

<section class="backend-shell"
         data-controller="keyboard-shortcuts next-event"
         data-action="turbo:frame-load@document->next-event#syncActiveFromEditor turbo:submit-end@document->next-event#syncActiveAfterSubmit"
         data-next-event-enabled-value="<%= @next_event_enabled %>"
         data-next-event-preference-url-value="<%= next_event_preference_backend_events_path %>">
  <header class="backend-topbar">
    <div>
      <h1>Event-Inbox</h1>
    </div>
    <div class="backend-topbar-actions-wrap">
      <div class="backend-topbar-actions">
        <%= link_to "Neues Event", new_backend_event_path, class: "button button-secondary" %>
        <%= button_to "Import-Merge synchronisieren", sync_imported_events_backend_events_path(status: @filters[:status]), method: :post, class: "button" %>
        <%= link_to "Importer", backend_import_sources_path, class: "button button-ghost" %>
      </div>
      <div id="flash-messages" class="backend-inline-flash">
        <%= render "layouts/flash_messages" %>
      </div>
    </div>
  </header>

  <div class="backend-split">
    <aside class="backend-list-column">
      <div class="backend-status-row">
        <% Event::STATUSES.reject { |status| status == "imported" }.each do |status| %>
          <%= link_to backend_events_path(status: status), class: "status-chip #{'status-chip-active' if @filters[:status] == status}" do %>
            <span><%= event_status_label(status) %></span>
            <strong><%= @status_counts.fetch(status, 0) %></strong>
          <% end %>
        <% end %>
      </div>

      <%= form_with url: apply_filters_backend_events_path, method: :post, class: "filter-form" do |form| %>
        <%= form.hidden_field :status, value: @filters[:status] %>
        <div class="filter-grid">
          <div>
            <%= form.label :query, "Suche", class: "form-label" %>
            <%= form.text_field :query, value: @filters[:query], placeholder: "Band, Venue, Stadt", class: "form-input" %>
          </div>
          <div>
            <%= form.label :starts_after, "Ab", class: "form-label" %>
            <%= form.date_field :starts_after, value: @filters[:starts_after], class: "form-input" %>
          </div>
          <div>
            <%= form.label :starts_before, "Bis", class: "form-label" %>
            <%= form.date_field :starts_before, value: @filters[:starts_before], class: "form-input" %>
          </div>
        </div>
        <div class="editor-actions-row">
          <%= form.submit "Filtern", class: "button button-secondary" %>
          <%= link_to "Filter entfernen", apply_filters_backend_events_path(status: @filters[:status], clear_filters: "1"), data: { turbo_method: :post }, class: "button button-ghost" %>
        </div>
      <% end %>

      <%= render "events_list", events: @events, selected_event: @selected_event, status: @filters[:status] %>
    </aside>

    <section class="backend-editor-column">
      <%= turbo_frame_tag "event_editor" do %>
        <% if @selected_event.present? %>
          <%= render "editor_panel", event: @selected_event, all_genres: @all_genres, next_event_enabled: @next_event_enabled, filter_status: @filters[:status] %>
        <% else %>
          <div class="empty-state">Keine Events zur aktuellen Filterung.</div>
        <% end %>
      <% end %>
    </section>
  </div>
</section>
