<div id="events_list">
  <%= form_with url: bulk_backend_events_path(status: status), method: :patch, class: "bulk-form", data: { controller: "bulk-select" } do |form| %>
    <div class="bulk-actions">
      <%= form.select :bulk_action,
                      options_for_select([
                        ["Auswählen...", ""],
                        ["Publizieren", "publish"],
                        ["Depublizieren", "unpublish"],
                        ["Als vollständig markieren", "mark_complete"],
                        ["Als unvollständig markieren", "mark_incomplete"],
                        ["Ablehnen", "reject"]
                      ]),
                      {},
                      class: "form-input" %>
      <button type="button"
              class="button button-secondary"
              data-bulk-select-target="toggleButton"
              data-action="click->bulk-select#toggleAll">
        Alle markieren
      </button>
      <%= form.submit "Bulk anwenden", class: "button" %>
    </div>

    <ul class="event-list">
      <% events.each do |event| %>
        <li class="event-list-item <%= 'event-list-item-active' if selected_event&.id == event.id %>">
          <%= check_box_tag "event_ids[]",
                            event.id,
                            false,
                            class: "event-checkbox",
                            data: { bulk_select_target: "item", action: "change->bulk-select#syncToggleLabel" } %>
          <%= link_to backend_event_path(event, status: status),
                      data: {
                        turbo_frame: "event_editor",
                        action: "click->next-event#eventLinkClicked",
                        next_event_event_id: event.id
                      },
                      class: "event-link" do %>
            <div class="event-list-main">
              <strong><%= event.artist_name %></strong>
              <span><%= event.title %></span>
              <small><%= l(event.start_at.to_date, format: "%d.%m.%Y") %> · <%= event.venue %></small>
            </div>
            <span class="<%= event_status_badge_class(event.status) %>"><%= event_status_label(event.status) %></span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% end %>
</div>
