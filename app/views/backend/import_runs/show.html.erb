<% content_for :title, "Importer Job ##{@import_run.id}" %>

<section class="backend-shell">
  <header class="backend-topbar">
    <div>
      <h1>Importer Job #<%= @import_run.id %></h1>
      <p>
        Typ: <strong><%= import_run_type_label(@import_run) %></strong>
        · Quelle: <strong><%= @import_run.import_source.name %></strong>
      </p>
    </div>
    <div class="backend-topbar-actions">
      <%= link_to "Zurück", backend_import_sources_path(section: params[:section]), class: "button button-secondary button-compact" %>
    </div>
  </header>

  <section class="import-run-section backend-section backend-table-section">
    <h2>Run Daten</h2>
    <p>Retries genutzt: <strong><%= import_run_retries_label(@import_run) %></strong></p>
    <% if import_run_single_event_llm?(@import_run) %>
      <p>
        Lauf-Typ: <strong><%= import_run_single_event_label(@import_run) %></strong>
        <% if (context = import_run_single_event_context(@import_run)).present? %>
          · Zielkontext: <strong><%= context %></strong>
        <% end %>
      </p>
    <% end %>
    <div class="table-wrap">
      <% if raw_import_run?(@import_run) %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Run ID</th>
              <th>Gestartet</th>
              <th>Importer</th>
              <th>Status</th>
              <th><span title="<%= import_run_column_description(:raw_imports) %>">Raw Imports</span></th>
              <th><span title="<%= import_run_column_description(:filtered) %>">Filtered</span></th>
              <th><span title="<%= import_run_column_description(:inserts) %>">Inserts</span></th>
              <th>Failed</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code><%= @import_run.id %></code></td>
              <td><%= @import_run.started_at&.strftime("%d.%m.%Y %H:%M:%S") %></td>
              <td><%= import_run_type_label(@import_run) %></td>
              <td><%= import_run_status_label(@import_run) %></td>
              <td><%= import_run_raw_imports_label(@import_run) %></td>
              <td><%= import_run_filtered_label(@import_run) %></td>
              <td><%= import_run_inserts_label(@import_run) %></td>
              <td><%= @import_run.failed_count %></td>
            </tr>
          </tbody>
        </table>
      <% elsif merge_import_run?(@import_run) %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Run ID</th>
              <th>Gestartet</th>
              <th>Status</th>
              <th><span title="<%= import_run_column_description(:raw_imports) %>">Raw Imports</span></th>
              <th><span title="<%= import_run_column_description(:merge_groups) %>">Merge Groups</span></th>
              <th><span title="<%= import_run_column_description(:inserts) %>">Inserts</span></th>
              <th><span title="<%= import_run_column_description(:updates) %>">Updates</span></th>
              <th><span title="<%= import_run_column_description(:similarity_duplicates) %>">Similarity Duplicates</span></th>
              <th><span title="<%= import_run_column_description(:collapsed_records) %>">Collapsed Records</span></th>
              <th>Failed</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code><%= @import_run.id %></code></td>
              <td><%= @import_run.started_at&.strftime("%d.%m.%Y %H:%M:%S") %></td>
              <td><%= import_run_status_label(@import_run) %></td>
              <td><%= import_run_raw_imports_label(@import_run) %></td>
              <td><%= import_run_merge_groups_label(@import_run) %></td>
              <td><%= import_run_inserts_label(@import_run) %></td>
              <td><%= import_run_updates_label(@import_run) %></td>
              <td><%= import_run_duplicates_label(@import_run) %></td>
              <td><%= import_run_collapsed_records_label(@import_run) %></td>
              <td><%= @import_run.failed_count %></td>
            </tr>
          </tbody>
        </table>
      <% elsif llm_import_run?(@import_run) %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Run ID</th>
              <th>Gestartet</th>
              <th>Status</th>
              <th><span title="<%= import_run_column_description(:raw_imports) %>">Selected Events</span></th>
              <th><span title="<%= import_run_column_description(:filtered) %>">Skipped</span></th>
              <th><span title="<%= import_run_column_description(:inserts) %>">Enrichments</span></th>
              <th><span title="<%= import_run_column_description(:collapsed_records) %>">OpenAI Calls</span></th>
              <th>Failed</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code><%= @import_run.id %></code></td>
              <td><%= @import_run.started_at&.strftime("%d.%m.%Y %H:%M:%S") %></td>
              <td><%= import_run_status_label(@import_run) %></td>
              <td><%= import_run_raw_imports_label(@import_run) %></td>
              <td><%= import_run_filtered_label(@import_run) %></td>
              <td><%= import_run_inserts_label(@import_run) %></td>
              <td><%= import_run_collapsed_records_label(@import_run) %></td>
              <td><%= @import_run.failed_count %></td>
            </tr>
          </tbody>
        </table>
      <% elsif llm_genre_grouping_import_run?(@import_run) %>
        <table class="data-table">
          <thead>
            <tr>
              <th>Run ID</th>
              <th>Gestartet</th>
              <th>Status</th>
              <th><span title="<%= import_run_column_description(:raw_imports) %>">Genres</span></th>
              <th><span title="<%= import_run_column_description(:filtered) %>">Skipped</span></th>
              <th><span title="<%= import_run_column_description(:inserts) %>">Groups</span></th>
              <th><span title="<%= import_run_column_description(:collapsed_records) %>">Requests</span></th>
              <th>Failed</th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><code><%= @import_run.id %></code></td>
              <td><%= @import_run.started_at&.strftime("%d.%m.%Y %H:%M:%S") %></td>
              <td><%= import_run_status_label(@import_run) %></td>
              <td><%= import_run_raw_imports_label(@import_run) %></td>
              <td><%= import_run_filtered_label(@import_run) %></td>
              <td><%= import_run_inserts_label(@import_run) %></td>
              <td><%= import_run_collapsed_records_label(@import_run) %></td>
              <td><%= @import_run.failed_count %></td>
            </tr>
          </tbody>
        </table>
      <% end %>
    </div>
  </section>

  <% if @import_run.error_message.present? %>
    <section class="import-run-section backend-section">
      <div class="flash flash-alert" role="alert">
        <strong>Run-Fehler:</strong>
        <%= @import_run.error_message %>
      </div>
    </section>
  <% end %>

  <% if llm_genre_grouping_import_run?(@import_run) %>
    <% snapshot = @import_run.llm_genre_grouping_snapshot %>
    <% public_snapshot_id = AppSetting.public_genre_grouping_snapshot_id %>
    <section class="import-run-section backend-section backend-table-section">
      <h2>Gruppierungs-Snapshot</h2>
      <% if snapshot.present? %>
        <p>
          Snapshot-ID: <strong><%= snapshot.id %></strong>
          · Öffentlich ausgewählt: <strong><%= public_snapshot_id == snapshot.id ? "Ja" : "Nein" %></strong>
          <br>
          Snapshot-Key: <strong><%= snapshot.snapshot_key %></strong>
          · Modell: <strong><%= snapshot.model %></strong>
          · Zielgruppen: <strong><%= snapshot.requested_group_count %></strong>
          · Effektive Gruppen: <strong><%= snapshot.effective_group_count %></strong>
        </p>
        <div class="table-wrap">
          <table class="data-table">
            <thead>
              <tr>
                <th>Position</th>
                <th>Name</th>
                <th>Genres</th>
                <th>Genre-Anzahl</th>
              </tr>
            </thead>
            <tbody>
              <% snapshot.groups.each do |group| %>
                <tr>
                  <td><%= group.position %></td>
                  <td><%= group.name %></td>
                  <td><%= group.member_genres.join(", ") %></td>
                  <td><%= group.genre_count %></td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <p>Für diesen Lauf wurde kein Snapshot gespeichert.</p>
      <% end %>
    </section>
  <% end %>

  <% if llm_import_run?(@import_run) %>
    <section class="import-run-section backend-section backend-table-section">
      <h2>LLM-Enrichment Details (<%= @llm_enrichments.size %>)</h2>
      <% if @llm_enrichments.any? %>
        <% @llm_enrichments.each do |enrichment| %>
          <article class="import-run-llm-detail">
            <p>
              Event: <strong>#<%= enrichment.event_id %></strong>
              <% if enrichment.event.present? %>
                · <strong><%= [ enrichment.event.artist_name, enrichment.event.title ].compact.join(" · ") %></strong>
              <% end %>
            </p>

            <details class="import-run-llm-detail-disclosure">
              <summary>Gesendeter Prompt anzeigen</summary>
              <% prompt = enrichment.raw_response["llm_prompt"].to_s %>
              <% if prompt.present? %>
                <pre class="payload-json import-run-llm-detail-payload"><%= prompt %></pre>
              <% else %>
                <p>Für dieses Enrichment wurde kein gespeicherter Prompt gefunden.</p>
              <% end %>
            </details>

            <details class="import-run-llm-detail-disclosure">
              <summary>Raw Result anzeigen</summary>
              <% raw_result = enrichment.raw_response["llm_raw_result"] %>
              <% if raw_result.present? %>
                <pre class="payload-json import-run-llm-detail-payload"><%= import_run_json_payload(raw_result) %></pre>
              <% else %>
                <p>Für dieses Enrichment wurde kein gespeichertes Raw Result gefunden.</p>
              <% end %>
            </details>
          </article>
        <% end %>
      <% else %>
        <p>Für diesen LLM-Enrichment-Run wurden keine Enrichment-Details gespeichert.</p>
      <% end %>
    </section>
  <% end %>

  <section class="import-run-section backend-section backend-table-section">
    <h2>Errors (<%= @run_errors.size %>)</h2>
    <% if @run_errors.any? %>
      <div class="table-wrap">
        <table class="data-table">
          <thead>
            <tr>
              <th>Zeit</th>
              <th>Fehlerklasse</th>
              <th>External Event ID</th>
              <th>Nachricht</th>
              <th>Payload</th>
            </tr>
          </thead>
          <tbody>
            <% @run_errors.each do |run_error| %>
              <tr>
                <td><%= run_error.created_at&.strftime("%d.%m.%Y %H:%M:%S") %></td>
                <td><code><%= run_error.error_class.presence || "-" %></code></td>
                <td><code><%= run_error.external_event_id.presence || "-" %></code></td>
                <td><%= run_error.message %></td>
                <td>
                  <details>
                    <summary>anzeigen</summary>
                    <pre><%= import_run_json_payload(run_error.payload) %></pre>
                  </details>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% else %>
      <p>Keine Error Daten vorhanden.</p>
    <% end %>
  </section>

  <% if [ "easyticket", "eventim", "reservix" ].include?(@import_run.source_type) %>
    <% configured_cities = import_source_configured_cities(@import_run.import_source) %>
    <section class="import-run-section backend-section backend-table-section">
      <h2>Ortsliste konfiguriert (<%= configured_cities.size %>)</h2>
      <% if configured_cities.any? %>
        <div class="import-run-city-list">
          <% configured_cities.each do |city| %>
            <%= link_to city, remove_whitelist_city_backend_import_run_path(@import_run, city: city), data: { turbo_method: :post }, class: "button button-ghost button-compact" %>
          <% end %>
        </div>
      <% else %>
        <p>Keine Städte in der Ortsliste konfiguriert.</p>
      <% end %>
    </section>

    <% filtered_out_cities = import_run_filtered_out_cities(@import_run) %>
    <section class="import-run-section backend-section backend-table-section">
      <h2>Aussortierte Städte (<%= filtered_out_cities.size %>)</h2>
      <% if filtered_out_cities.any? %>
        <div class="import-run-city-list">
          <% filtered_out_cities.each do |city| %>
            <%= link_to city, add_filtered_city_backend_import_run_path(@import_run, city: city), data: { turbo_method: :post }, class: "button button-ghost button-compact" %>
          <% end %>
        </div>
      <% else %>
        <p>Keine aussortierten Städte erfasst.</p>
      <% end %>
    </section>
  <% end %>
</section>
