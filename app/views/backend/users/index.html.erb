<% content_for :title, "Benutzer" %>

<section class="backend-shell">
  <header class="backend-topbar">
    <div>
      <h1>Benutzerverwaltung</h1>
      <p>Nur Admins können Benutzer anlegen sowie Rollen und Passwörter ändern.</p>
    </div>
    <div class="backend-topbar-actions">
      <%= link_to "Eigenes Passwort", edit_backend_account_password_path, class: "button button-secondary button-compact" %>
      <%= link_to "Benutzer anlegen", new_backend_user_path, class: "button button-compact" %>
    </div>
  </header>

  <section class="backend-section backend-table-section">
    <div class="backend-section-header">
      <h3>Benutzer</h3>
    </div>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Name</th>
            <th>E-Mail</th>
            <th>Rolle</th>
            <th>Aktionen</th>
          </tr>
        </thead>
        <tbody>
          <% @users.each do |user| %>
            <tr>
              <td><%= user.name.presence || "-" %></td>
              <td><%= user.email_address %></td>
              <td><%= user.role %></td>
              <td class="action-cell">
                <%= link_to "Bearbeiten", edit_backend_user_path(user), class: "button button-ghost button-compact" %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>
</section>
