<% role_options = User::ROLES.map { |role| [role.humanize, role] } %>
<% role_locked = user == current_user %>

<div class="editor-panel">
  <% if user.errors.any? %>
    <div class="flash flash-alert">
      <strong>Bitte Eingaben prüfen.</strong>
      <ul>
        <% user.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [ :backend, user ], class: "editor-form" do |form| %>
    <div class="editor-grid">
      <div>
        <%= form.label :name, "Name", class: "form-label" %>
        <%= form.text_field :name, class: "form-input", maxlength: 120 %>
      </div>

      <div>
        <%= form.label :email_address, "E-Mail", class: "form-label" %>
        <%= form.email_field :email_address, required: true, autocomplete: "email", class: "form-input" %>
      </div>

      <div>
        <%= form.label :role, "Rolle", class: "form-label" %>
        <%= form.select :role, role_options, {}, class: "form-input", disabled: role_locked %>
        <% if role_locked %>
          <p>Die eigene Rolle kann nicht geaendert werden.</p>
        <% end %>
      </div>
    </div>

    <div class="editor-grid">
      <div>
        <%= form.label :password, user.persisted? ? "Neues Passwort" : "Passwort", class: "form-label" %>
        <%= form.password_field :password,
                                required: user.new_record?,
                                autocomplete: "new-password",
                                maxlength: 72,
                                class: "form-input" %>
      </div>

      <div>
        <%= form.label :password_confirmation, "Passwort bestätigen", class: "form-label" %>
        <%= form.password_field :password_confirmation,
                                required: user.new_record?,
                                autocomplete: "new-password",
                                maxlength: 72,
                                class: "form-input" %>
      </div>
    </div>

    <% if user.persisted? %>
      <p>Passwortfelder leer lassen, wenn das Passwort unveraendert bleiben soll.</p>
    <% end %>

    <div class="editor-footer">
      <%= form.submit submit_label, class: "button" %>
    </div>
  <% end %>
</div>
