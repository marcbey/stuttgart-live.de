<% content_for :title, "Einstellungen" %>

<section class="backend-shell">
  <header class="backend-topbar">
    <div>
      <h1>Einstellungen</h1>
    </div>
  </header>

  <div class="editor-panel backend-panel">
    <section class="settings-tabs"
             data-controller="settings-tabs"
             data-settings-tabs-section-url-template-value="<%= section_backend_settings_path(section: "__SECTION__") %>"
             data-settings-tabs-initial-section-value="<%= active_settings_section.fetch(:key) %>">
      <div class="settings-tabs-nav"
           role="tablist"
           aria-label="Einstellungsbereiche">
        <% settings_sections.each do |section| %>
          <% active = section.fetch(:key) == active_settings_section.fetch(:key) %>
          <%= link_to edit_backend_settings_path(section: section.fetch(:key)),
                      id: section.fetch(:tab_id),
                      class: ["settings-tabs-link", ("is-active" if active)].compact.join(" "),
                      role: "tab",
                      aria: {
                        selected: active,
                        controls: section.fetch(:panel_id)
                      },
                      tabindex: (active ? 0 : -1),
                      data: {
                        settings_tabs_target: "tab",
                        settings_tabs_section_key: section.fetch(:key),
                        action: "click->settings-tabs#activate keydown->settings-tabs#keydown"
                      } do %>
            <span><%= section.fetch(:label) %></span>
          <% end %>
        <% end %>
      </div>

      <div class="settings-tabs-panels backend-tabs-panels">
        <% settings_sections.each do |section| %>
          <% active = section.fetch(:key) == active_settings_section.fetch(:key) %>
          <div id="<%= section.fetch(:panel_id) %>"
               class="settings-tab-panel backend-tab-panel"
               role="tabpanel"
               aria-labelledby="<%= section.fetch(:tab_id) %>"
               tabindex="0"
               <%= "hidden" unless active %>
               data-settings-tabs-target="panel"
               data-settings-tabs-section-key="<%= section.fetch(:key) %>"
               data-loaded="<%= active %>">
            <% if active %>
              <%= render section.fetch(:partial),
                         section_key: section.fetch(:key),
                         section_definition: section,
                         settings_records: active_section_records %>
            <% end %>
          </div>
        <% end %>
      </div>
    </section>
  </div>
</section>
