<% instagram_connection = @instagram_connection %>
<% facebook_connection = @facebook_connection %>
<% instagram_status = @instagram_access_status %>
<% facebook_status = @facebook_access_status %>
<% page_targets = facebook_connection&.social_connection_targets&.facebook_pages&.order(:name, :external_id) || [] %>

<section class="backend-section backend-section-compact">
  <div class="backend-section-header">
    <div>
      <h2>Meta Publishing</h2>
      <p>Instagram und Facebook werden getrennt verbunden, geprüft und veröffentlicht.</p>
    </div>
  </div>

  <div class="backend-section-body social-post-platform-grid">
    <article class="social-post-card meta-platform-card meta-platform-card-instagram">
      <div class="backend-section-header backend-section-header-with-actions social-post-card-header">
        <div>
          <div class="social-post-card-title-row">
            <h3>Instagram</h3>
            <span class="<%= meta_access_status_badge_class(instagram_status) %>"><%= social_connection_status_label(instagram_status.connection_status) %></span>
          </div>
        </div>
        <div class="backend-section-header-actions">
          <%= link_to "Instagram verbinden",
                      start_instagram_backend_meta_connection_path,
                      class: "button button-save-primary button-compact",
                      data: { turbo: false } %>
        </div>
      </div>
      <div class="social-post-card-body">
        <div class="flash <%= instagram_status.error? ? "flash-alert" : "flash-notice" %>">
          <div><%= instagram_status.summary %></div>
          <% if instagram_status.details.any? %>
            <ul class="social-post-health-list">
              <% instagram_status.details.each do |detail| %>
                <li><%= detail %></li>
              <% end %>
            </ul>
          <% end %>
        </div>
        <div class="social-post-meta-list">
          <div>
            <span class="form-label">Auth-Modus</span>
            <p><code><%= instagram_connection&.auth_mode.presence || "instagram_login" %></code></p>
          </div>
          <% if instagram_status.instagram_username.present? %>
            <div>
              <span class="form-label">Instagram</span>
              <p>@<%= instagram_status.instagram_username %></p>
            </div>
          <% end %>
          <% if instagram_connection&.metadata&.dig("instagram_account_type").present? || instagram_connection&.selected_instagram_target&.metadata&.dig("account_type").present? %>
            <div>
              <span class="form-label">Account-Typ</span>
              <p><%= instagram_connection.metadata.dig("instagram_account_type").presence || instagram_connection.selected_instagram_target&.metadata&.dig("account_type") %></p>
            </div>
          <% end %>
          <% if instagram_connection&.connected_at.present? %>
            <div>
              <span class="form-label">Verbunden seit</span>
              <p><%= l(instagram_connection.connected_at, format: "%d.%m.%Y %H:%M") %></p>
            </div>
          <% end %>
          <% if instagram_status.expires_at.present? %>
            <div>
              <span class="form-label">Token gültig bis</span>
              <p><%= l(instagram_status.expires_at, format: "%d.%m.%Y %H:%M") %></p>
            </div>
          <% end %>
          <% if instagram_connection&.last_error.present? %>
            <div>
              <span class="form-label">Letzter Fehler</span>
              <p><%= instagram_connection.last_error %></p>
            </div>
          <% end %>
        </div>
      </div>
    </article>

    <article class="social-post-card meta-platform-card meta-platform-card-facebook">
      <div class="backend-section-header backend-section-header-with-actions social-post-card-header">
        <div>
          <div class="social-post-card-title-row">
            <h3>Facebook</h3>
            <span class="<%= meta_access_status_badge_class(facebook_status) %>"><%= social_connection_status_label(facebook_status.connection_status) %></span>
          </div>
        </div>
        <div class="backend-section-header-actions">
          <%= link_to "Facebook verbinden",
                      start_facebook_backend_meta_connection_path,
                      class: "button button-save-primary button-compact",
                      data: { turbo: false } %>
        </div>
      </div>
      <div class="social-post-card-body">
        <div class="flash <%= facebook_status.error? ? "flash-alert" : "flash-notice" %>">
          <div><%= facebook_status.summary %></div>
          <% if facebook_status.details.any? %>
            <ul class="social-post-health-list">
              <% facebook_status.details.each do |detail| %>
                <li><%= detail %></li>
              <% end %>
            </ul>
          <% end %>
        </div>
        <div class="social-post-meta-list">
          <div>
            <span class="form-label">Auth-Modus</span>
            <p><code><%= facebook_connection&.auth_mode.presence || "facebook_login_for_business" %></code></p>
          </div>
          <% if facebook_status.page_name.present? %>
            <div>
              <span class="form-label">Facebook-Seite</span>
              <p><%= facebook_status.page_name %></p>
            </div>
          <% end %>
          <% if facebook_connection&.connected_at.present? %>
            <div>
              <span class="form-label">Verbunden seit</span>
              <p><%= l(facebook_connection.connected_at, format: "%d.%m.%Y %H:%M") %></p>
            </div>
          <% end %>
          <% if facebook_status.expires_at.present? %>
            <div>
              <span class="form-label">Token gültig bis</span>
              <p><%= l(facebook_status.expires_at, format: "%d.%m.%Y %H:%M") %></p>
            </div>
          <% end %>
          <% if facebook_connection&.last_error.present? %>
            <div>
              <span class="form-label">Letzter Fehler</span>
              <p><%= facebook_connection.last_error %></p>
            </div>
          <% end %>
        </div>

        <% if page_targets.any? %>
          <div class="meta-page-target-section">
            <div>
              <h3>Facebook-Seitenauswahl</h3>
              <p class="form-hint">Für direktes Facebook-Publishing muss genau eine Facebook-Seite ausgewählt sein.</p>
            </div>

            <div class="meta-page-target-list">
              <% page_targets.each do |target| %>
                <div class="meta-page-target-row">
                  <div class="meta-page-target-main">
                    <div class="social-post-card-title-row">
                      <h4><%= target.display_name %></h4>
                      <span class="<%= target.selected? ? "status-badge status-badge-published" : "status-badge status-badge-default" %>">
                        <%= target.selected? ? "Ausgewählt" : "Verfügbar" %>
                      </span>
                    </div>

                    <div class="social-post-meta-list">
                      <div>
                        <span class="form-label">Page-ID</span>
                        <p><code><%= target.external_id %></code></p>
                      </div>
                      <% if target.metadata["instagram_account_id"].present? %>
                        <div>
                          <span class="form-label">Verknüpftes Instagram</span>
                          <p>@<%= target.metadata["instagram_username"].presence || target.metadata["instagram_account_id"] %></p>
                        </div>
                      <% end %>
                      <% if target.last_synced_at.present? %>
                        <div>
                          <span class="form-label">Zuletzt synchronisiert</span>
                          <p><%= l(target.last_synced_at, format: "%d.%m.%Y %H:%M") %></p>
                        </div>
                      <% end %>
                    </div>
                  </div>

                  <div class="backend-section-header-actions">
                    <% unless target.selected? %>
                      <%= button_to "Seite auswählen",
                                    select_target_backend_meta_connection_path(target_id: target.id),
                                    method: :patch,
                                    class: "button button-secondary button-compact" %>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      </div>
    </article>
  </div>
</section>
