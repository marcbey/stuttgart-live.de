<%= render "backend/settings/sections/section_errors", settings_records: settings_records %>

<section class="settings-group">
  <div class="settings-group-header">
    <h2>LLM-Enrichment</h2>
    <p>Modell und Prompt für die Anfrage an den Enrichment-Importer. <code>{{input_json}}</code> muss im Prompt enthalten bleiben.</p>
  </div>
  <div class="settings-group-body">
    <%= form_with model: @llm_enrichment_model_setting,
                  url: backend_settings_path(section: section_key),
                  method: :patch,
                  class: "editor-form" do |form| %>
      <%= form.label :llm_enrichment_model, "LLM-Modell", class: "form-label" %>
      <%= form.select :llm_enrichment_model,
                      options_for_select(AppSetting::AVAILABLE_LLM_ENRICHMENT_MODELS, @llm_enrichment_model_setting.llm_enrichment_model),
                      {},
                      class: "form-input",
                      aria: { describedby: "llm-enrichment-model-help" } %>
      <p id="llm-enrichment-model-help" class="form-hint">Dieses Modell wird für neue LLM-Enrichment-Läufe verwendet.</p>

      <%= form.label :llm_enrichment_prompt_template_text, "LLM-Enrichment Prompt", class: "form-label" %>
      <%= form.text_area :llm_enrichment_prompt_template_text,
                         value: @llm_enrichment_prompt_template_setting.llm_enrichment_prompt_template_text,
                         rows: 24,
                         class: "form-textarea",
                         aria: { describedby: "llm-enrichment-prompt-help" } %>
      <p id="llm-enrichment-prompt-help" class="form-hint">Dieses Template steuert den Prompt für den LLM-Enrichment-Importer. Der Platzhalter <code>{{input_json}}</code> muss enthalten bleiben und wird pro Event durch die Eventdaten ersetzt. Für die Linkauswahl müssen außerdem die Felder <code>homepage_link</code>, <code>instagram_link</code>, <code>facebook_link</code> und <code>youtube_link</code> über <code>search_results</code>/<code>candidates</code> berücksichtigt bleiben; <code>venue_external_url</code> muss als direktes Venue-Feld enthalten bleiben.</p>

      <%= form.label :llm_enrichment_temperature, "LLM-Temperature", class: "form-label" %>
      <%= form.number_field :llm_enrichment_temperature,
                            value: @llm_enrichment_temperature_setting.llm_enrichment_temperature,
                            min: 0,
                            max: 2,
                            step: 0.1,
                            class: "form-input",
                            placeholder: AppSetting::DEFAULT_LLM_ENRICHMENT_TEMPERATURE,
                            aria: { describedby: "llm-enrichment-temperature-help" } %>
      <p id="llm-enrichment-temperature-help" class="form-hint">Optionaler Wert zwischen 0 und 2. Projekt-Default für das LLM-Enrichment ist <%= AppSetting::DEFAULT_LLM_ENRICHMENT_TEMPERATURE %>. Der OpenAI-API-Default wäre nur ohne diesen Projektoverride <code>1</code>. Niedrige Werte liefern stabilere, konsistentere Ergebnisse; höhere Werte machen die Antworten variantenreicher, aber auch weniger vorhersehbar.</p>

      <%= form.label :llm_enrichment_web_search_provider, "Web Search Provider", class: "form-label" %>
      <%= form.select :llm_enrichment_web_search_provider,
                      options_for_select(
                        AppSetting::AVAILABLE_LLM_ENRICHMENT_WEB_SEARCH_PROVIDERS,
                        @llm_enrichment_web_search_provider_setting.llm_enrichment_web_search_provider
                      ),
                      {},
                      class: "form-input",
                      aria: { describedby: "llm-enrichment-web-search-provider-help" } %>
      <p id="llm-enrichment-web-search-provider-help" class="form-hint">Steuert die Websuche für <code>homepage_link</code>, <code>instagram_link</code>, <code>facebook_link</code> und <code>youtube_link</code>. Standard ist <code>serpapi</code>; optional kann <code>openwebninja</code> genutzt werden.</p>

      <div class="settings-group-footer">
        <%= form.submit "Save", class: "button button-save-primary button-compact" %>
      </div>
    <% end %>
  </div>
</section>
