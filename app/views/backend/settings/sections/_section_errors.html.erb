<% errors = settings_records.flat_map { |record| record.errors.full_messages }.uniq %>
<% if errors.any? %>
  <div class="flash flash-alert">
    <strong>Bitte Eingaben prüfen.</strong>
    <ul>
      <% errors.each do |message| %>
        <li><%= message %></li>
      <% end %>
    </ul>
  </div>
<% end %>
