<div id="pages_list">
  <p class="event-list-count"><strong><%= pages.count %></strong> gefilterte Seiten</p>

  <% if pages.any? %>
    <ul class="event-list" role="list">
      <% pages.each do |page| %>
        <li class="event-list-item page-list-item <%= 'event-list-item-active' if selected_page&.id == page.id %>">
          <%= link_to edit_backend_page_path(page, query: query_filter.presence),
                      data: {
                        turbo_frame: "page_editor",
                        action: "click->editor-inbox#itemLinkClicked",
                        editor_inbox_item_id: page.id
                      },
                      class: "event-link page-link" do %>
            <div class="event-list-main">
              <strong><%= page.title %></strong>
              <span>/<%= page.slug %></span>
              <small><%= truncate(page.intro.presence || page.body.to_plain_text, length: 105) %></small>
            </div>

            <span class="event-list-badges">
              <% if page.system_page? %>
                <span class="status-badge">System</span>
              <% end %>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <div class="empty-state">Keine Seiten zur aktuellen Filterung.</div>
  <% end %>
</div>
