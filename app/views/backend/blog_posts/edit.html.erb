<% content_for :title, @blog_post.title %>
<% form_id = dom_id(@blog_post, :editor_form) %>

<section class="backend-shell">
  <header class="backend-topbar backend-topbar-sticky">
    <div class="backend-topbar-title">
      <h1>Blog</h1>
      <span class="backend-topbar-context">
        <%= [ @blog_post.title, @blog_post.display_status, (@blog_post.published_at.present? ? l(@blog_post.published_at, format: "%d.%m.%Y %H:%M") : nil) ].compact.join(" · ") %>
      </span>
    </div>
    <div class="backend-topbar-controls">
      <%= render "editor_actions", blog_post: @blog_post, form_id: form_id %>
    </div>
  </header>

  <%= render "form", blog_post: @blog_post, form_id: form_id %>
</section>
