<% active_editor_tab = local_assigns.fetch(:active_editor_tab, "news") %>
<% news_tab_active = active_editor_tab == "news" %>
<% news_image_tab_active = active_editor_tab == "news_image" %>
<% settings_tab_active = active_editor_tab == "settings" %>

<section class="event-editor-tabs"
         data-controller="event-editor-tabs"
         data-event-editor-tabs-initial-tab-value="<%= active_editor_tab %>">
  <div class="settings-tabs-nav event-editor-tabs-nav" role="tablist" aria-label="News-Editor Ansichten">
    <button type="button"
            id="blog-editor-tab-news"
            class="settings-tabs-link<%= " is-active" if news_tab_active %>"
            role="tab"
            aria-controls="blog-editor-panel-news"
            aria-selected="<%= news_tab_active %>"
            tabindex="<%= news_tab_active ? 0 : -1 %>"
            data-event-editor-tabs-target="tab"
            data-event-editor-tabs-tab-key-param="news"
            data-action="click->event-editor-tabs#activate keydown->event-editor-tabs#keydown">
      News
    </button>
    <button type="button"
            id="blog-editor-tab-news-image"
            class="settings-tabs-link<%= " is-active" if news_image_tab_active %>"
            role="tab"
            aria-controls="blog-editor-panel-news-image"
            aria-selected="<%= news_image_tab_active %>"
            tabindex="<%= news_image_tab_active ? 0 : -1 %>"
            data-event-editor-tabs-target="tab"
            data-event-editor-tabs-tab-key-param="news_image"
            data-action="click->event-editor-tabs#activate keydown->event-editor-tabs#keydown">
      Newsbild
    </button>
    <button type="button"
            id="blog-editor-tab-settings"
            class="settings-tabs-link<%= " is-active" if settings_tab_active %>"
            role="tab"
            aria-controls="blog-editor-panel-settings"
            aria-selected="<%= settings_tab_active %>"
            tabindex="<%= settings_tab_active ? 0 : -1 %>"
            data-event-editor-tabs-target="tab"
            data-event-editor-tabs-tab-key-param="settings"
            data-action="click->event-editor-tabs#activate keydown->event-editor-tabs#keydown">
      Einstellungen
    </button>
  </div>

  <div class="settings-tabs-panels backend-tabs-panels">
    <section id="blog-editor-panel-news"
             class="settings-tab-panel backend-tab-panel<%= " is-active" if news_tab_active %>"
             role="tabpanel"
             aria-labelledby="blog-editor-tab-news"
             tabindex="0"
             <%= "hidden" unless news_tab_active %>
             data-event-editor-tabs-target="panel"
             data-event-editor-tabs-panel-key="news">
      <%= render "backend/blog_posts/editor_news_view",
                 blog_post: blog_post,
                 form_id: form_id,
                 status_filter: status_filter,
                 query_filter: query_filter,
                 active_editor_tab: active_editor_tab %>
    </section>

    <section id="blog-editor-panel-news-image"
             class="settings-tab-panel backend-tab-panel<%= " is-active" if news_image_tab_active %>"
             role="tabpanel"
             aria-labelledby="blog-editor-tab-news-image"
             tabindex="0"
             <%= "hidden" unless news_image_tab_active %>
             data-event-editor-tabs-target="panel"
             data-event-editor-tabs-panel-key="news_image">
      <%= fields_for :blog_post, blog_post do |form| %>
        <%= render "backend/blog_posts/image_editor",
                   form: form,
                   form_id: form_id,
                   blog_post: blog_post,
                   title: "Titelbild",
                   description: "Wird auf der News-Übersicht und im Beitrag verwendet.",
                   image_slot: :cover_image,
                   copyright_attribute: :cover_image_copyright,
                   image_alt: blog_post.title,
                   preview_variant: "blog-cover" %>
      <% end %>
    </section>

    <section id="blog-editor-panel-settings"
             class="settings-tab-panel backend-tab-panel<%= " is-active" if settings_tab_active %>"
             role="tabpanel"
             aria-labelledby="blog-editor-tab-settings"
             tabindex="0"
             <%= "hidden" unless settings_tab_active %>
             data-event-editor-tabs-target="panel"
             data-event-editor-tabs-panel-key="settings">
      <%= render "backend/blog_posts/settings_fields",
                 blog_post: blog_post,
                 form_id: form_id %>
    </section>
  </div>
</section>
