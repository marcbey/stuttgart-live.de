<div class="blog-editor-layout">
  <aside class="blog-editor-aside">
    <div class="blog-editor-note">
      <p>Autor: <strong><%= blog_post.display_author_name.presence || current_user.name.presence || current_user.email_address %></strong></p>
      <p>Slug: <code><%= blog_post.slug.presence || "wird automatisch erzeugt" %></code></p>
      <% if blog_post.published_at.present? %>
        <p>Veröffentlichung: <strong><%= l(blog_post.published_at, format: "%d.%m.%Y %H:%M") %></strong></p>
      <% else %>
        <p>Veröffentlichung: <strong>noch nicht gesetzt</strong></p>
      <% end %>
    </div>
  </aside>

  <div>
    <% if blog_post.errors.any? %>
      <div class="flash flash-alert">
        <strong>Bitte Eingaben prüfen.</strong>
        <ul>
          <% blog_post.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= form_with model: [ :backend, blog_post ], class: "editor-form", id: form_id do |form| %>
      <%= hidden_field_tag :status, (status_filter == "all" ? nil : status_filter) %>
      <%= hidden_field_tag :query, query_filter if query_filter.present? %>
      <div class="editor-grid">
        <div>
          <%= form.label :title, "Titel", class: "form-label" %>
          <%= form.text_field :title, class: "form-input", maxlength: 180, required: true %>
        </div>

        <div>
          <%= form.label :slug, "Slug", class: "form-label" %>
          <%= form.text_field :slug, class: "form-input", placeholder: "wird-aus-dem-titel-abgeleitet" %>
        </div>
      </div>

      <div>
        <%= form.label :author_name, "Autor / Byline", class: "form-label" %>
        <%= form.text_field :author_name, class: "form-input", placeholder: current_user.name.presence || current_user.email_address %>
      </div>

      <div>
        <%= form.label :teaser, "Teaser", class: "form-label" %>
        <%= form.text_area :teaser, rows: 4, class: "form-input form-textarea", maxlength: 320, required: true %>
      </div>

      <div class="editor-grid">
        <div>
          <%= form.label :published_at, "Veröffentlichungsdatum", class: "form-label" %>
          <%= form.datetime_local_field :published_at,
                                        value: blog_post.published_at&.in_time_zone&.strftime("%Y-%m-%dT%H:%M"),
                                        class: "form-input" %>
        </div>

        <div>
          <span class="form-label">Promotion Banner</span>
          <label class="blog-editor-checkbox">
            <%= form.check_box :promotion_banner %>
            <span>Als Promotion Banner markieren</span>
          </label>
          <p class="blog-editor-hint">Es kann immer nur ein Beitrag gleichzeitig als Promotion Banner aktiv sein.</p>
        </div>

        <div>
          <p class="blog-editor-hint">Das Promotion-Banner-Bild wird auf der Startseite direkt unter den Highlights verwendet.</p>
        </div>
      </div>

      <%= render "backend/blog_posts/image_editor",
                 form: form,
                 form_id: form_id,
                 blog_post: blog_post,
                 title: "Titelbild",
                 description: "Wird auf der News-Übersicht und im Beitrag verwendet.",
                 image_slot: :cover_image,
                 copyright_attribute: :cover_image_copyright,
                 image_alt: blog_post.title,
                 preview_variant: "blog-cover" %>

      <%= render "backend/blog_posts/image_editor",
                 form: form,
                 form_id: form_id,
                 blog_post: blog_post,
                 title: "Promotion-Banner-Bild",
                 description: "Wird auf der Startseite unter den Highlights in voller Breite angezeigt.",
                 image_slot: :promotion_banner_image,
                 copyright_attribute: :promotion_banner_image_copyright,
                 image_alt: "#{blog_post.title} Promotion Banner",
                 preview_variant: "blog-promotion-banner" %>

      <div>
        <%= form.label :body, "Inhalt", class: "form-label" %>
        <p class="blog-editor-hint">Bilder können direkt über die Toolbar in den Text eingefügt werden.</p>
        <%= form.rich_textarea :body, class: "blog-rich-text" %>
      </div>
    <% end %>
  </div>
</div>
