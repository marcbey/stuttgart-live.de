<% form_id = dom_id(blog_post, :editor_form) %>
<% active_editor_tab = local_assigns.fetch(:active_editor_tab, "news") %>

<div class="editor-panel backend-panel blog-editor-panel"
     id="blog_editor_panel"
     data-selected-item-id="<%= blog_post.id if blog_post.persisted? %>">
  <template class="editor-actions-template">
    <%= render "backend/blog_posts/editor_actions", blog_post: blog_post, form_id: form_id %>
  </template>

  <header class="editor-header">
    <div>
      <p class="eyebrow"><%= blog_post.persisted? ? "Beitrag ##{blog_post.id}" : "New" %></p>
      <h2><%= blog_post.title.presence || "Unbenannter Beitrag" %></h2>
      <p><%= blog_post.display_author_name.presence || current_user.name.presence || current_user.email_address %></p>
    </div>
    <div class="editor-header-badges">
      <span class="blog-post-status blog-post-status-<%= blog_post.status %>"><%= blog_post.display_status %></span>
      <% if blog_post.source_url.present? %>
        <%= link_to "Original",
                    blog_post.source_url,
                    class: "status-badge status-badge-default status-badge-link",
                    target: "_blank",
                    rel: "noopener" %>
      <% end %>
    </div>
  </header>

  <% if blog_post.errors.any? %>
    <div class="flash flash-alert">
      <strong>Bitte Eingaben prüfen.</strong>
      <ul>
        <% blog_post.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= render "backend/blog_posts/form",
             blog_post: blog_post,
             form_id: form_id,
             status_filter: status_filter,
             query_filter: query_filter,
             active_editor_tab: active_editor_tab %>
</div>
