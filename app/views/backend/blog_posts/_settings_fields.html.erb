<div class="backend-section-stack">
  <section class="backend-section backend-section-form blog-editor-section-promotion" aria-labelledby="promotion-banner-section-title">
    <div class="backend-section-header">
      <div>
        <h3 id="promotion-banner-section-title">Promotion Banner</h3>
        <p>Diese Inhalte erscheinen auf der Startseite direkt unter den Highlights.</p>
      </div>
    </div>

    <div class="backend-section-body">
      <div class="editor-grid blog-editor-section-grid">
        <div>
          <label class="blog-editor-checkbox">
            <%= hidden_field_tag "blog_post[promotion_banner]", "0", form: form_id, id: nil %>
            <%= check_box_tag "blog_post[promotion_banner]", "1", blog_post.promotion_banner?, form: form_id %>
            <span>Als Promotion Banner markieren</span>
          </label>
          <p class="blog-editor-hint">Es kann immer nur ein Beitrag gleichzeitig als Promotion Banner aktiv sein.</p>
        </div>

        <div>
          <%= label_tag "blog_post_promotion_banner_kicker_text", "Kicker", class: "form-label" %>
          <%= text_field_tag "blog_post[promotion_banner_kicker_text]",
                             blog_post.promotion_banner_kicker_text,
                             id: "blog_post_promotion_banner_kicker_text",
                             class: "form-input",
                             maxlength: 80,
                             placeholder: BlogPost::DEFAULT_PROMOTION_BANNER_KICKER_TEXT,
                             form: form_id %>
        </div>

        <div>
          <%= label_tag "blog_post_promotion_banner_cta_text", "CTA-Text", class: "form-label" %>
          <%= text_field_tag "blog_post[promotion_banner_cta_text]",
                             blog_post.promotion_banner_cta_text,
                             id: "blog_post_promotion_banner_cta_text",
                             class: "form-input",
                             maxlength: 80,
                             placeholder: BlogPost::DEFAULT_PROMOTION_BANNER_CTA_TEXT,
                             form: form_id %>
        </div>
      </div>

      <p class="blog-editor-hint">Leer gelassene Texte fallen automatisch auf die Standardwerte zurück.</p>

      <%= fields_for :blog_post, blog_post do |form| %>
        <%= render "backend/shared/promotion_banner_image_editor",
                   form: form,
                   form_id: form_id,
                   title: "Promotion-Banner-Bild",
                   description: "Wird auf der Startseite unter den Highlights in voller Breite angezeigt.",
                   section_classes: "blog-post-image-section promotion-banner-image-section",
                   image_blob: blog_post.promotion_banner_image_blob_for_editor,
                   signed_input_name: "blog_post_images[promotion_banner_image_signed_id]",
                   signed_input_value: blog_post.pending_promotion_banner_image_blob&.signed_id,
                   remove_input_name: "blog_post_images[remove_promotion_banner_image]",
                   remove_value: (blog_post.remove_promotion_banner_image? ? "1" : "0"),
                   upload_input_id: "#{form_id}_promotion_banner_image_upload",
                   copyright_attribute: :promotion_banner_image_copyright,
                   copyright_value: blog_post.promotion_banner_image_copyright,
                   focus_x_attribute: :promotion_banner_image_focus_x,
                   focus_y_attribute: :promotion_banner_image_focus_y,
                   zoom_attribute: :promotion_banner_image_zoom,
                   focus_x_value: blog_post.promotion_banner_image_focus_x_value,
                   focus_y_value: blog_post.promotion_banner_image_focus_y_value,
                   zoom_value: blog_post.promotion_banner_image_zoom_value,
                   image_alt: "#{blog_post.title} Promotion Banner",
                   preview_variant: "promotion-banner" %>
      <% end %>
    </div>
  </section>
</div>
