<% content_for :title, "News" %>

<section class="backend-shell backend-inbox-shell"
         data-controller="editor-inbox"
         data-action="turbo:frame-load@document->editor-inbox#syncActiveFromEditor turbo:submit-end@document->editor-inbox#syncActiveAfterSubmit">
  <header class="backend-topbar backend-topbar-sticky blog-topbar backend-inbox-topbar">
    <div class="backend-topbar-title">
      <h1>News-Inbox</h1>
    </div>

    <div class="backend-topbar-controls backend-inbox-topbar-controls">
      <div class="backend-inbox-control-rail">
        <%= render "topbar_editor_actions",
                   blog_post: @selected_blog_post,
                   status_filter: @status_filter,
                   query_filter: @query_filter %>

        <% unless @selected_blog_post.present? && !@selected_blog_post.persisted? %>
          <div class="backend-topbar-actions" data-editor-inbox-target="newAction">
            <%= link_to "New",
                        new_backend_blog_post_path(status: @status_filter, query: @query_filter.presence, editor_tab: (@active_editor_tab unless @active_editor_tab == "news")),
                        data: { turbo_frame: "blog_editor" },
                        class: "button button-secondary button-compact" %>
          </div>
        <% end %>
      </div>
    </div>
  </header>

  <div class="backend-split backend-inbox-split">
    <aside class="backend-list-column">
      <div class="backend-status-row">
        <% Backend::BlogPostsController::FILTERS.each do |filter| %>
          <% label = { "all" => "All", "draft" => "Drafts", "published" => "Published" }.fetch(filter) %>
          <%= link_to label,
                      backend_blog_posts_path(status: (filter == "all" ? nil : filter), query: @query_filter.presence),
                      class: "status-chip #{'status-chip-active' if @status_filter == filter}" %>
        <% end %>
      </div>

      <%= form_with url: backend_blog_posts_path,
                    method: :get,
                    class: "filter-form",
                    data: { turbo_frame: "_top" } do |form| %>
        <%= form.hidden_field :status, value: (@status_filter == "all" ? nil : @status_filter) %>
        <div class="filter-grid">
          <div class="filter-search-field filter-search-field-full">
            <%= form.label :query, "Suche", class: "form-label" %>
            <div class="filter-date-wrap">
              <%= form.text_field :query,
                                  value: @query_filter,
                                  placeholder: "Titel, Teaser, Slug",
                                  class: "form-input filter-input-with-clear",
                                  oninput: "this.nextElementSibling.classList.toggle('filter-date-clear-visible', this.value.length > 0)" %>
              <%= button_tag "×",
                             type: "button",
                             class: "filter-date-clear filter-input-clear #{'filter-date-clear-visible' if @query_filter.present?}",
                             aria: { label: "Suche löschen" },
                             onclick: "this.previousElementSibling.value=''; this.classList.remove('filter-date-clear-visible'); this.form.requestSubmit();" %>
            </div>
          </div>
        </div>
      <% end %>

      <%= render "blog_posts_list",
                 blog_posts: @blog_posts,
                 selected_blog_post: @selected_blog_post,
                 status_filter: @status_filter,
                 query_filter: @query_filter,
                 active_editor_tab: @active_editor_tab %>
    </aside>

    <section class="backend-editor-column backend-inbox-editor-column">
      <% if @selected_blog_post.present? %>
        <%= render "editor_frame",
                   blog_post: @selected_blog_post,
                   status_filter: @status_filter,
                   query_filter: @query_filter,
                   active_editor_tab: @active_editor_tab %>
      <% else %>
        <%= turbo_frame_tag "blog_editor" do %>
          <div class="empty-state">Keine Beiträge zur aktuellen Filterung.</div>
        <% end %>
      <% end %>
    </section>
  </div>
</section>
