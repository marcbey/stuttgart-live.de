<% content_for :title, "Präsentatoren" %>

<section class="backend-shell backend-inbox-shell"
         data-controller="editor-inbox"
         data-action="turbo:frame-load@document->editor-inbox#syncActiveFromEditor turbo:submit-end@document->editor-inbox#syncActiveAfterSubmit"
         data-editor-inbox-frame-id-value="presenter_editor"
         data-editor-inbox-item-selector-value=".presenter-list-item"
         data-editor-inbox-link-selector-value=".presenter-link">
  <header class="backend-topbar backend-topbar-sticky backend-inbox-topbar">
    <div class="backend-topbar-title">
      <h1>Präsentatoren</h1>
    </div>
    <div class="backend-topbar-controls backend-inbox-topbar-controls">
      <div class="backend-inbox-control-rail">
        <%= render "backend/presenters/topbar_editor_actions", presenter: @selected_presenter, query_filter: @query_filter, sort_filter: @sort_filter %>
        <% unless @selected_presenter.present? && !@selected_presenter.persisted? %>
          <div class="backend-topbar-actions" data-editor-inbox-target="newAction">
            <%= link_to "New",
                        new_backend_presenter_path(query: @query_filter.presence, sort: (@sort_filter unless @sort_filter == "alphabetical")),
                        data: { turbo_frame: "presenter_editor" },
                        class: "button button-secondary button-compact" %>
          </div>
        <% end %>
        <div class="backend-topbar-actions">
          <%= link_to "Import Logos", bulk_new_backend_presenters_path, class: "button button-secondary button-compact" %>
        </div>
      </div>
    </div>
  </header>

  <div class="backend-split backend-inbox-split">
    <aside class="backend-list-column">
      <%= form_with url: backend_presenters_path,
                    method: :get,
                    class: "filter-form",
                    data: {
                      controller: "live-search",
                      turbo_stream: true,
                      live_search_delay_value: 180
                    } do |form| %>
        <div class="filter-grid">
          <div class="filter-search-field filter-search-field-full">
            <%= form.label :query, "Suche", class: "form-label" %>
            <div class="filter-date-wrap">
              <%= form.text_field :query,
                                  value: @query_filter,
                                  placeholder: "Name, Beschreibung oder URL",
                                  class: "form-input filter-input-with-clear",
                                  autocomplete: "off",
                                  data: {
                                    live_search_target: "query",
                                    action: "input->live-search#queueSubmit keydown.enter->live-search#submitNow"
                                  } %>
              <%= button_tag "×",
                             type: "button",
                             class: "filter-date-clear filter-input-clear #{'filter-date-clear-visible' if @query_filter.present?}",
                             aria: { label: "Suche löschen" },
                             data: {
                               live_search_target: "clear",
                               action: "live-search#clear"
                             } %>
            </div>
          </div>
          <div class="filter-search-field filter-search-field-full">
            <%= form.label :sort, "Sortierung", class: "form-label" %>
            <%= form.select :sort,
                            options_for_select([
                              [ "Alphabetisch", "alphabetical" ],
                              [ "Anzahl Events", "total" ],
                              [ "Editiert am", "created_at" ]
                            ], @sort_filter),
                            {},
                            class: "form-input",
                            data: { action: "change->live-search#submitNow" } %>
          </div>
        </div>
      <% end %>

      <%= render "presenters_list",
                 presenters: @presenters,
                 selected_presenter: @selected_presenter,
                 query_filter: @query_filter,
                 sort_filter: @sort_filter %>
    </aside>

    <section class="backend-editor-column backend-inbox-editor-column">
      <%= render "editor_frame",
                 presenter: @selected_presenter,
                 linked_events: @selected_presenter_linked_events,
                 query_filter: @query_filter,
                 sort_filter: @sort_filter %>
    </section>
  </div>
</section>
