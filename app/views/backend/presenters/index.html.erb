<% content_for :title, "Präsentatoren" %>

<section class="backend-shell">
  <header class="backend-topbar">
    <div>
      <h1>Präsentatoren</h1>
      <p>Globale Präsentatoren für Events mit Logo und externer Verlinkung.</p>
    </div>
    <div class="backend-topbar-actions">
      <%= link_to "Präsentator anlegen", new_backend_presenter_path, class: "button button-compact" %>
      <%= link_to "Logos gesammelt importieren", bulk_new_backend_presenters_path, class: "button button-secondary button-compact" %>
    </div>
  </header>

  <section class="backend-section backend-table-section">
    <div class="backend-section-header">
      <h3>Alle Präsentatoren</h3>
    </div>
    <% if @presenters.any? %>
      <ul class="presenter-grid" role="list">
        <% @presenters.each do |presenter| %>
          <li class="presenter-card">
            <div class="presenter-card-logo">
              <% if presenter.logo.attached? %>
                <%= image_tag presenter.thumbnail_logo_variant, alt: presenter.name %>
              <% end %>
            </div>

            <div class="presenter-card-body">
              <div class="presenter-card-header">
                <div>
                  <h4><%= presenter.name %></h4>
                  <% if presenter.description.present? %>
                    <p class="presenter-card-copy"><%= truncate(presenter.description, length: 140) %></p>
                  <% end %>
                </div>
                <span class="presenter-card-count"><%= presenter.event_presenters.size %> Events</span>
              </div>

              <div class="presenter-card-meta">
                <span class="presenter-card-label">Externe URL</span>
                <% if presenter.external_url.present? %>
                  <%= link_to presenter.external_url,
                              presenter.external_url,
                              target: "_blank",
                              rel: "noopener",
                              class: "presenter-card-link" %>
                <% else %>
                  <span class="presenter-card-copy">Keine URL hinterlegt</span>
                <% end %>
              </div>
            </div>

            <div class="presenter-card-actions">
              <%= link_to "Bearbeiten", edit_backend_presenter_path(presenter), class: "button button-ghost button-compact" %>
              <%= button_to "Löschen",
                            backend_presenter_path(presenter),
                            method: :delete,
                            class: "button button-secondary button-compact",
                            form: {
                              data: {
                                turbo_confirm: "Presenter wirklich löschen?"
                              }
                            } %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="form-hint">Noch keine Präsentatoren angelegt.</p>
    <% end %>
  </section>
</section>
