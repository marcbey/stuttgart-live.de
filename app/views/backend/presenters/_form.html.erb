<% query_filter = local_assigns[:query_filter] %>
<% linked_events = local_assigns.fetch(:linked_events, []) %>

<div class="editor-panel backend-panel"
     id="presenter_editor_panel"
     data-selected-item-id="<%= presenter.id if presenter.persisted? %>">
  <template class="editor-actions-template">
    <%= render "backend/presenters/editor_actions", presenter: presenter, query_filter: query_filter %>
  </template>

  <% if presenter.errors.any? %>
    <div class="flash flash-alert">
      <strong>Bitte Eingaben prüfen.</strong>
      <ul>
        <% presenter.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [ :backend, presenter ],
                id: dom_id(presenter, :editor_form),
                class: "editor-form" do |form| %>
    <%= hidden_field_tag :query, query_filter if query_filter.present? %>
    <section class="backend-section backend-section-compact">
      <div class="backend-section-header">
        <h3>Stammdaten</h3>
      </div>
      <div class="backend-section-body">
        <div class="editor-grid">
          <div>
            <%= form.label :name, "Name", class: "form-label" %>
            <%= form.text_field :name, class: "form-input", required: true, maxlength: 180 %>
          </div>

          <div>
            <%= form.label :external_url, "Externe URL", class: "form-label" %>
            <%= form.url_field :external_url, class: "form-input", placeholder: "https://…" %>
            <p class="form-hint">Optional. Wenn gesetzt, muss die URL mit http:// oder https:// beginnen.</p>
          </div>

          <div class="editor-grid-span-full">
            <%= form.label :description, "Beschreibung", class: "form-label" %>
            <%= form.text_area :description, class: "form-input", rows: 5 %>
            <p class="form-hint">Optional. Wird in v1 nur im Backend gepflegt.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="backend-section backend-section-compact">
      <div class="backend-section-header">
        <h3>Logo</h3>
      </div>
      <div class="backend-section-body">
        <div class="editor-grid presenter-form-logo-grid">
          <div>
            <%= form.label :logo, "Logo hochladen", class: "form-label" %>
            <%= form.file_field :logo, class: "form-input", accept: "image/*" %>
            <p class="form-hint">Pflichtfeld. Ersetzt beim Bearbeiten das bestehende Logo.</p>
          </div>

          <div>
            <p class="form-label">Vorschau</p>
            <div class="presenter-form-logo-preview">
              <% if presenter.logo.attached? %>
                <%= image_tag presenter.detail_logo_variant, alt: presenter.name %>
              <% else %>
                <span>Noch kein Logo hochgeladen.</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <% if presenter.persisted? %>
      <section class="backend-section backend-section-compact">
        <div class="backend-section-header">
          <h3>Verknüpfte Events</h3>
        </div>
        <div class="backend-section-body">
          <% if linked_events.any? %>
            <ul class="presenter-linked-event-list" role="list">
              <% linked_events.each do |event| %>
                <li class="presenter-linked-event-item">
                  <%= link_to backend_events_path(status: event.status, event_id: event.id),
                              class: "presenter-linked-event-link",
                              data: { turbo_frame: "_top" } do %>
                    <div class="presenter-linked-event-main">
                      <strong><%= event.artist_name.presence || "Unbenanntes Event" %></strong>
                      <span><%= event.title.presence || "Ohne Titel" %></span>
                      <small>
                        <%= l(event.start_at.to_date, format: "%d.%m.%Y") if event.start_at.present? %>
                        <% if event.venue.present? %>
                          · <%= event.venue %>
                        <% end %>
                      </small>
                    </div>
                    <span class="presenter-linked-event-badges">
                      <span class="<%= event_display_status_badge_class(event) %>"><%= event_display_status_label(event) %></span>
                    </span>
                  <% end %>
                </li>
              <% end %>
            </ul>
          <% else %>
            <p class="form-hint">Diesem Präsentator sind noch keine Events zugeordnet.</p>
          <% end %>
        </div>
      </section>
    <% end %>

  <% end %>
</div>
