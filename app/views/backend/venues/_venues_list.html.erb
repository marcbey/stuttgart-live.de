<div id="venues_list">
  <p class="event-list-count"><strong><%= venues.size %></strong> gefilterte Venues</p>

  <% if query_filter.blank? %>
    <p class="form-hint">Suche nach Name, Adresse, Beschreibung oder URL, um Venues anzuzeigen.</p>
  <% elsif venues.any? %>
    <ul class="event-list" role="list">
      <% venues.each do |venue| %>
        <li class="event-list-item venue-list-item <%= 'event-list-item-active' if selected_venue&.id == venue.id %>">
          <%= link_to edit_backend_venue_path(venue, query: query_filter),
                      data: {
                        turbo_frame: "venue_editor",
                        action: "click->editor-inbox#itemLinkClicked",
                        editor_inbox_item_id: venue.id
                      },
                      class: "event-link venue-link" do %>
            <div class="event-list-main">
              <strong><%= venue.name %></strong>
              <span><%= truncate(venue.address.presence || venue.external_url.presence || "Keine Adresse oder URL", length: 105) %></span>
              <small>Venue ID: <%= venue.id %> · Gesamt: <%= venue.events_count %> · Kommend: <%= venue.upcoming_events_count %></small>
            </div>

            <span class="event-list-badges">
              <% if venue.logo.attached? %>
                <span class="status-badge">Logo</span>
              <% end %>
            </span>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="form-hint">Keine Venues für „<%= query_filter %>“ gefunden.</p>
  <% end %>
</div>
