<% query_filter = local_assigns[:query_filter] %>

<div class="editor-panel backend-panel"
     id="venue_editor_panel"
     data-selected-item-id="<%= venue.id if venue.persisted? %>">
  <template class="editor-actions-template">
    <%= render "backend/venues/editor_actions", venue: venue, query_filter: query_filter %>
  </template>

  <% if venue.errors.any? %>
    <div class="flash flash-alert">
      <strong>Bitte Eingaben prüfen.</strong>
      <ul>
        <% venue.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <%= form_with model: [ :backend, venue ],
                id: dom_id(venue, :editor_form),
                class: "editor-form" do |form| %>
    <%= hidden_field_tag :query, query_filter if query_filter.present? %>
    <section class="backend-section backend-section-compact">
      <div class="backend-section-header">
        <h3>Stammdaten</h3>
      </div>
      <div class="backend-section-body">
        <div class="editor-grid">
          <div>
            <%= form.label :name, "Name", class: "form-label" %>
            <%= form.text_field :name, class: "form-input", required: true, maxlength: 180 %>
          </div>

          <div>
            <%= form.label :external_url, "Externe URL", class: "form-label" %>
            <%= form.url_field :external_url, class: "form-input", placeholder: "https://…" %>
          </div>

          <div class="editor-grid-span-full">
            <%= form.label :address, "Adresse", class: "form-label" %>
            <%= form.text_area :address, class: "form-input", rows: 3 %>
            <p class="form-hint">Freitext, z. B. Straße, Hausnummer, PLZ und Ort.</p>
          </div>

          <div class="editor-grid-span-full">
            <%= form.label :description, "Beschreibung", class: "form-label" %>
            <% description_input_id = form.field_id(:description) %>
            <%= form.hidden_field :description, id: description_input_id %>
            <trix-editor input="<%= description_input_id %>" class="form-rich-text-editor backend-description-editor"></trix-editor>
            <p class="form-hint">Unterstützt u. a. fett und Links.</p>
          </div>
        </div>
      </div>
    </section>

    <section class="backend-section backend-section-compact">
      <div class="backend-section-header">
        <h3>Logo</h3>
      </div>
      <div class="backend-section-body">
        <div class="editor-grid presenter-form-logo-grid">
          <div>
            <%= form.label :logo, "Logo hochladen", class: "form-label" %>
            <%= form.file_field :logo, class: "form-input", accept: "image/*" %>
            <p class="form-hint">Optional. Ersetzt beim Bearbeiten das bestehende Logo.</p>
            <% if venue.logo.attached? %>
              <label class="form-hint">
                <%= form.check_box :remove_logo %>
                Logo löschen
              </label>
            <% end %>
          </div>

          <div>
            <p class="form-label">Vorschau</p>
            <div class="presenter-form-logo-preview">
              <% if venue.logo.attached? %>
                <%= image_tag venue.detail_logo_variant, alt: venue.name %>
              <% else %>
                <span>Noch kein Logo hochgeladen.</span>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </section>

    <% if venue.persisted? %>
      <section class="backend-section backend-section-compact">
        <div class="backend-section-header">
          <h3>Metadaten</h3>
        </div>
        <div class="backend-section-body">
          <div class="editor-grid">
            <div>
              <p class="form-label">Erstellt am</p>
              <p class="form-hint"><%= l(venue.created_at, format: "%d.%m.%Y %H:%M") %></p>
            </div>

            <div>
              <p class="form-label">Editiert am</p>
              <p class="form-hint"><%= l(venue.updated_at, format: "%d.%m.%Y %H:%M") %></p>
            </div>
          </div>
        </div>
      </section>
    <% end %>

  <% end %>
</div>
