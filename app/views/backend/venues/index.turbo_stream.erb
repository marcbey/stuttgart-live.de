<%= turbo_stream.update "flash-messages" do %>
  <%= render "layouts/flash_messages" %>
<% end %>

<%= turbo_stream.replace "venues_list" do %>
  <%= render "venues_list", venues: @venues, selected_venue: @selected_venue, query_filter: @query_filter %>
<% end %>

<%= turbo_stream.replace "venue_editor" do %>
  <%= render "editor_frame", venue: @selected_venue, query_filter: @query_filter %>
<% end %>
