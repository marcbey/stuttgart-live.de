<div class="backend-topbar-actions">
  <button type="submit"
          form="<%= dom_id(venue, :editor_form) %>"
          class="button button-save-primary button-compact">
    Save
  </button>

  <% unless venue.persisted? %>
    <%= link_to "Cancel",
                backend_venues_path(query: query_filter.presence),
                class: "button button-secondary button-compact",
                data: { turbo_frame: "_top" } %>
  <% end %>

  <% if venue.persisted? %>
    <%= link_to "Delete",
                backend_venue_path(venue, query: query_filter.presence),
                class: "button button-ghost button-compact",
                data: {
                  turbo_frame: "_top",
                  turbo_method: :delete,
                  turbo_confirm: "Venue wirklich löschen?"
                } %>
  <% end %>
</div>
