<div id="import-runs-table" class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>Gestartet</th>
        <th>Import Typ</th>
        <th>Status</th>
        <th>Fetched</th>
        <th>Filtered</th>
        <th>Upserts</th>
        <th>Failed</th>
        <th>Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% recent_runs.each do |run| %>
        <tr data-run-id="<%= run.id %>">
          <td><%= run.started_at&.strftime("%d.%m.%Y %H:%M:%S") %></td>
          <td><%= import_run_type_label(run) %></td>
          <td><%= import_run_status_label(run) %></td>
          <td><%= run.fetched_count %></td>
          <td><%= run.filtered_count %></td>
          <td><%= run.upserted_count %></td>
          <td><%= run.failed_count %></td>
          <td>
            <% if import_run_can_stop?(run) %>
              <%= button_to "Stoppen", import_run_stop_path(run), method: :post, class: "button button-secondary" %>
            <% elsif run.status == "running" %>
              Stop angefordert
            <% else %>
              -
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
