<div id="import-runs-table" class="table-wrap">
  <table class="data-table">
    <thead>
      <tr>
        <th>Gestartet</th>
        <th>Import Typ</th>
        <th>Status</th>
        <th><span title="<%= import_run_column_description(:raw_imports) %>">Raw Imports</span></th>
        <th><span title="<%= import_run_column_description(:merge_groups) %>">Merge Groups</span></th>
        <th><span title="<%= import_run_column_description(:filtered) %>">Filtered</span></th>
        <th><span title="<%= import_run_column_description(:inserts) %>">Inserts</span></th>
        <th><span title="<%= import_run_column_description(:updates) %>">Updates</span></th>
        <th><span title="<%= import_run_column_description(:similarity_duplicates) %>">Similarity Duplicates</span></th>
        <th><span title="<%= import_run_column_description(:collapsed_records) %>">Collapsed Records</span></th>
        <th>Failed</th>
        <th class="actions-column">Aktionen</th>
      </tr>
    </thead>
    <tbody>
      <% recent_runs.each do |run| %>
        <tr data-run-id="<%= run.id %>">
          <td><%= run.started_at&.strftime("%d.%m.%Y %H:%M:%S") %></td>
          <td><%= import_run_type_label(run) %></td>
          <td><%= import_run_status_label(run) %></td>
          <td><%= import_run_raw_imports_label(run) %></td>
          <td><%= import_run_merge_groups_label(run) %></td>
          <td><%= import_run_filtered_label(run) %></td>
          <td><%= import_run_inserts_label(run) %></td>
          <td><%= import_run_updates_label(run) %></td>
          <td><%= import_run_duplicates_label(run) %></td>
          <td><%= import_run_collapsed_records_label(run) %></td>
          <td><%= run.failed_count %></td>
          <td class="action-cell">
            <%= link_to "Details", backend_import_run_path(run), class: "button button-ghost button-compact" %>
            <% if import_run_can_stop?(run) %>
              <%= button_to "Stoppen", import_run_stop_path(run), method: :post, class: "button button-secondary button-compact" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
