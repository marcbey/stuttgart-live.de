<% content_for :title, "Importer" %>

<section class="backend-shell">
  <header class="backend-topbar">
    <div>
      <h1>Importer-Konfiguration</h1>
    </div>
  </header>

  <section class="import-sources-runs-section">
    <%= turbo_stream_from [ :backend, :import_runs ] %>
    <%= render "live_shell",
               sections: @overview_state.sections,
               active_section_key: @active_section.fetch(:key),
               overview_state: @overview_state,
               import_sources: @import_sources %>
  </section>
</section>
