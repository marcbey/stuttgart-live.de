<h1>Importer Backend</h1>

<% if notice.present? %>
  <p style="color: green;"><%= notice %></p>
<% end %>
<% if alert.present? %>
  <p style="color: red;"><%= alert %></p>
<% end %>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Typ</th>
      <th>Aktiv</th>
      <th>Ortsliste</th>
      <th>Aktionen</th>
    </tr>
  </thead>
  <tbody>
    <% @import_sources.each do |source| %>
      <tr>
        <td><%= source.name %></td>
        <td><code><%= source.source_type %></code></td>
        <td><%= source.active ? "Ja" : "Nein" %></td>
        <td>
          <%= source.configured_location_whitelist.join(", ") %>
        </td>
        <td>
          <%= link_to "Bearbeiten", edit_backend_import_source_path(source) %>
          <% if source.easyticket? %>
            <%= button_to "Easyticket jetzt importieren",
                          run_easyticket_backend_import_source_path(source),
                          method: :post %>
          <% end %>
        </td>
      </tr>
    <% end %>
  </tbody>
</table>

<h2>Letzte Easyticket-Importlaeufe</h2>
<%= turbo_stream_from [ :backend, :easyticket_import_runs ] %>
<%= render "recent_runs_table", recent_runs: @recent_runs %>
