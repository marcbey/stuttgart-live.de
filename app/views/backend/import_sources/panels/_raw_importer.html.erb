<section class="import-runs-panel backend-section backend-table-section">
  <div class="import-runs-group-header">
    <h3>Raw Importer</h3>
  </div>
  <p class="import-runs-note">
    Diese Jobs holen Rohdaten direkt von Easyticket, Eventim und Reservix ab und speichern jeden passenden Quelldatensatz als `RawEventImport`.
    Sie bilden die erste Stufe der Pipeline und liefern die nachvollziehbare Datengrundlage für den späteren Merge.
  </p>
  <p class="import-runs-note">Automatischer Lauf täglich um 03:05 Uhr (Europe/Berlin).</p>

  <div class="import-runs-block">
    <h4 class="import-runs-subheading">Scheduler</h4>
  </div>
  <div class="table-wrap">
    <table class="data-table">
      <thead>
        <tr>
          <th>Typ</th>
          <th>Aktiv</th>
          <th>Ortsliste</th>
          <th class="actions-column">Aktionen</th>
        </tr>
      </thead>
      <tbody>
        <% import_sources.each do |source| %>
          <tr>
            <td><code><%= source.source_type %></code></td>
            <td><%= source.active ? "Ja" : "Nein" %></td>
            <td><%= source.configured_location_whitelist.join(", ") %></td>
            <td class="action-cell">
              <% if source.easyticket? %>
                <%= button_to "Easyticket Import starten", run_easyticket_backend_import_source_path(source, section: section_key), method: :post, class: "button button-compact" %>
              <% elsif source.eventim? %>
                <%= button_to "Eventim Import starten", run_eventim_backend_import_source_path(source, section: section_key), method: :post, class: "button button-compact" %>
              <% elsif source.reservix? %>
                <%= button_to "Reservix Import starten", run_reservix_backend_import_source_path(source, section: section_key), method: :post, class: "button button-compact" %>
              <% end %>
              <%= link_to "Edit", edit_backend_import_source_path(source, section: section_key), class: "button button-ghost button-compact" %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <div class="import-runs-block">
    <h4 class="import-runs-subheading">Jobs</h4>
  </div>

  <% if runs.any? %>
    <div class="table-wrap">
      <table class="data-table">
        <thead>
          <tr>
            <th>Run ID</th>
            <th>Gestartet</th>
            <th>Importer</th>
            <th>Status</th>
            <th><span title="<%= import_run_column_description(:raw_imports) %>">Raw Imports</span></th>
            <th><span title="<%= import_run_column_description(:filtered) %>">Filtered</span></th>
            <th><span title="<%= import_run_column_description(:inserts) %>">Inserts</span></th>
            <th>Failed</th>
            <th class="actions-column">Aktionen</th>
          </tr>
        </thead>
        <tbody>
          <% runs.each do |run| %>
            <tr data-run-id="<%= run.id %>">
              <td><code><%= run.id %></code></td>
              <td><%= run.started_at&.strftime("%d.%m.%Y %H:%M:%S") %></td>
              <td><%= import_run_type_label(run) %></td>
              <td><%= import_run_status_label(run) %></td>
              <td><%= import_run_raw_imports_label(run) %></td>
              <td><%= import_run_filtered_label(run) %></td>
              <td><%= import_run_inserts_label(run) %></td>
              <td><%= run.failed_count %></td>
              <td class="action-cell">
                <%= link_to "Details", backend_import_run_path(run, section: section_key), class: "button button-ghost button-compact" %>
                <% if import_run_can_stop?(run, section: section_key) %>
                  <%= button_to import_run_stop_action_label(run), import_run_stop_path(run, section: section_key), method: :post, class: "button button-secondary button-compact" %>
                <% end %>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <p>Keine Raw Importer Jobs vorhanden.</p>
  <% end %>
</section>
