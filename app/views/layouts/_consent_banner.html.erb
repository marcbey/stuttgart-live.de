<section class="consent-banner" data-consent-target="banner" aria-label="Datenschutzeinstellungen">
  <div class="consent-banner-copy">
    <p class="eyebrow">Datenschutz</p>
    <h2>Deine Auswahl für Statistik und externe Medien</h2>
    <p>
      Wir nutzen optionale Dienste nur nach Deiner Einwilligung. Dazu zählen Google Analytics
      für Reichweitenmessung und eingebettete YouTube-Videos.
    </p>
  </div>

  <div class="consent-banner-actions">
    <button type="button" class="button button-secondary" data-action="click->consent#acceptEssential">
      Nur notwendige
    </button>
    <button type="button" class="button button-ghost" data-action="click->consent#openSettings">
      Auswahl anpassen
    </button>
    <button type="button" class="button button-save-primary" data-action="click->consent#acceptAll">
      Alles akzeptieren
    </button>
  </div>
</section>
