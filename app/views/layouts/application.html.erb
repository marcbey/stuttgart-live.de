<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <title><%= content_for(:title) || "Stuttgart Live" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Stuttgart Live">
    <meta name="mobile-web-app-capable" content="yes">
    <% if controller_path.start_with?("backend/") %>
      <meta name="turbo-cache-control" content="no-cache">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;500;700&family=Bebas+Neue&family=Oswald:wght@200;300;500;700&display=swap" rel="stylesheet">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <% if compiled_asset_exists?("application.css") %>
      <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <% end %>
    <% if compiled_asset_exists?("application.js") %>
      <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <% end %>
  </head>

  <% public_frontend = controller_path.start_with?("public/") %>
  <% public_homepage_chrome = public_frontend %>
  <% body_classes = [] %>
  <% body_classes << "page-public" if public_frontend %>
  <% body_classes << "page-public-events-index" if public_homepage_chrome %>

  <body
    class="<%= body_classes.join(" ") %>"
    <% body_controllers = [] %>
    <% unless controller_path.start_with?("backend/") %>
      <% body_controllers << "consent" %>
    <% end %>
    <% body_controllers << "scroll-top" %>
    data-controller="<%= body_controllers.join(" ") %>"
    <% if !controller_path.start_with?("backend/") && google_analytics_enabled? %>
      data-consent-measurement-id-value="<%= google_analytics_measurement_id %>"
    <% end %>>
    <% backend_context = controller_path.start_with?("backend/") %>
    <% nav_inner_classes = [ "app-nav-inner" ] %>
    <% nav_inner_classes << "app-nav-inner-backend" if backend_context %>
    <% nav_inner_classes << "app-nav-inner-homepage-poster" if public_homepage_chrome %>
    <% nav_browse_state = @browse_state || @header_browse_state %>
    <% public_events_search_visible = nav_browse_state.present? %>
    <% backend_nav_links = capture do %>
      <% if authenticated? %>
        <% if current_user.backend_access? %>
          <%= link_to "Events", backend_events_path, class: app_nav_link_class(active: backend_nav_active?), aria: { current: ("page" if backend_nav_active?) } %>
        <% end %>
        <% if current_user.blog_access? %>
          <%= link_to "News", backend_blog_posts_path, class: app_nav_link_class(active: blog_nav_active?), aria: { current: ("page" if blog_nav_active?) } %>
        <% end %>
        <% if current_user.backend_access? %>
          <%= link_to "Präsentatoren", backend_presenters_path, class: app_nav_link_class(active: presenter_nav_active?), aria: { current: ("page" if presenter_nav_active?) } %>
          <%= link_to "Venues", backend_venues_path, class: app_nav_link_class(active: venue_nav_active?), aria: { current: ("page" if venue_nav_active?) } %>
        <% end %>
        <% if current_user.admin? %>
          <%= link_to "Einstellungen", edit_backend_settings_path, class: app_nav_link_class(active: settings_nav_active?), aria: { current: ("page" if settings_nav_active?) } %>
          <%= link_to "Queue", backend_import_sources_path, class: app_nav_link_class(active: importer_nav_active?), aria: { current: ("page" if importer_nav_active?) } %>
          <%= link_to "Benutzer", backend_users_path, class: app_nav_link_class(active: controller_path == "backend/users"), aria: { current: ("page" if controller_path == "backend/users") } %>
        <% elsif current_user.backend_access? %>
          <%= link_to "Queue", backend_import_sources_path, class: app_nav_link_class(active: importer_nav_active?), aria: { current: ("page" if importer_nav_active?) } %>
        <% end %>
        <%= link_to "Passwort", edit_backend_account_password_path, class: app_nav_link_class(active: controller_path == "backend/account_passwords"), aria: { current: ("page" if controller_path == "backend/account_passwords") } %>
        <%= button_to "Logout",
                      session_path,
                      method: :delete,
                      class: app_nav_link_class,
                      form: { class: "app-nav-link-form" } %>
      <% else %>
        <%= link_to "Login", new_session_path, class: app_nav_link_class(active: controller_path == "sessions"), aria: { current: ("page" if controller_path == "sessions") } %>
      <% end %>
    <% end %>
    <a href="#main-content" class="skip-link">Zum Inhalt springen</a>
    <nav class="app-nav" data-controller="nav-offset mobile-nav<%= ' homepage-header-compact' if public_homepage_chrome %>">
      <div class="<%= nav_inner_classes.join(" ") %>">
        <%= link_to root_path, class: "app-brand" do %>
          <% if public_homepage_chrome || backend_context %>
            <span class="brand-wordmark brand-wordmark-poster" aria-label="Stuttgart Live">
              <span class="brand-wordmark-city"><span class="brand-wordmark-city-initial">S</span>TUTTGART</span><span class="brand-wordmark-live">LIVE</span>
            </span>
          <% else %>
            <span class="brand-wordmark" aria-label="Stuttgart Live">
              <span class="brand-wordmark-city">STUTTGART</span><span class="brand-wordmark-live">LIVE</span>
            </span>
          <% end %>
        <% end %>

        <% if public_homepage_chrome && public_events_search_visible %>
          <div class="app-nav-homepage-center">
            <div class="app-nav-search">
              <%= render "public/events/toolbar", browse_state: nav_browse_state %>
            </div>
            <div class="app-nav-hotline">
              <span class="app-nav-hotline-label">Tickethotline:</span>
              <a href="tel:+4971155066077" class="app-nav-hotline-link">0711 550 660 77</a>
            </div>
          </div>
        <% elsif public_events_search_visible %>
          <div class="app-nav-search">
            <%= render "public/events/toolbar", browse_state: nav_browse_state %>
          </div>
        <% end %>

        <button type="button"
                class="app-nav-toggle"
                data-action="click->mobile-nav#toggle"
                data-mobile-nav-target="button"
                aria-expanded="false"
                aria-controls="app-nav-menu"
                aria-label="Navigation öffnen">
          <span></span>
          <span></span>
          <span></span>
        </button>

        <div id="flash-messages" class="app-nav-flash">
          <%= render "layouts/flash_messages" %>
        </div>

        <div id="app-nav-menu" class="app-nav-meta" data-mobile-nav-target="panel">
          <div class="app-nav-links">
            <% if backend_context %>
              <div class="app-nav-links-group app-nav-links-group-separated">
                <%= backend_nav_links %>
              </div>
            <% else %>
              <div class="app-nav-links-group">
                <% if public_homepage_chrome %>
                  <div class="app-nav-poster-links-wrap">
                    <div class="app-nav-socials app-nav-socials-poster" aria-label="Soziale Medien">
                      <%= link_to "https://www.instagram.com/stuttgart.live.concert/",
                                  class: "app-nav-social-link",
                                  target: "_blank",
                                  rel: "noopener",
                                  title: "Instagram",
                                  aria: { label: "Instagram" } do %>
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
                          <circle cx="12" cy="12" r="4"></circle>
                          <circle cx="17.4" cy="6.7" r="1.2" class="app-nav-social-fill"></circle>
                        </svg>
                      <% end %>
                      <%= link_to "https://www.tiktok.com/@stuttgart.live.concert",
                                  class: "app-nav-social-link",
                                  target: "_blank",
                                  rel: "noopener",
                                  title: "TikTok",
                                  aria: { label: "TikTok" } do %>
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M14.2 4.2c.36 1.82 1.44 3.18 3.26 4.06.63.3 1.3.48 2.04.55v2.56a8.18 8.18 0 0 1-3.01-.67v5.06c0 3.1-2.48 5.53-5.74 5.53-3.05 0-5.56-2.3-5.56-5.27 0-3.1 2.72-5.5 5.91-5.22v2.66a2.67 2.67 0 0 0-3.21 2.56c0 1.47 1.2 2.66 2.72 2.66 1.66 0 2.74-1.26 2.74-3.02V4.2h2.85Z" class="app-nav-social-fill"></path>
                        </svg>
                      <% end %>
                      <%= link_to "https://www.facebook.com/stuttgartlive",
                                  class: "app-nav-social-link",
                                  target: "_blank",
                                  rel: "noopener",
                                  title: "Facebook",
                                  aria: { label: "Facebook" } do %>
                        <svg viewBox="0 0 24 24" aria-hidden="true">
                          <path d="M13.4 20.5v-7h2.3l.35-2.75H13.4V9c0-.8.22-1.35 1.37-1.35h1.46V5.2c-.25-.03-1.1-.1-2.1-.1-2.08 0-3.5 1.27-3.5 3.62v2.03H8.3v2.75h2.37v7h2.73Z" class="app-nav-social-fill"></path>
                        </svg>
                      <% end %>
                    </div>
                    <div class="app-nav-poster-links-stack">
                <% end %>
                <%= link_to "Events", root_path, class: app_nav_link_class(active: events_nav_active?), aria: { current: ("page" if events_nav_active?) } %>
                <%= link_to "News", news_index_path, class: app_nav_link_class(active: news_nav_active?), aria: { current: ("page" if news_nav_active?) } %>
                <% if public_homepage_chrome %>
                  <%= link_to "Tickets", root_path, class: app_nav_link_class(active: false) %>
                    </div>
                  </div>
                <% else %>
                  <%= link_to "Kontakt", contact_path, class: app_nav_link_class(active: contact_nav_active?), aria: { current: ("page" if contact_nav_active?) } %>
                  <div class="app-nav-socials" aria-label="Soziale Medien">
                    <%= link_to "https://www.instagram.com/stuttgart.live.concert/",
                                class: "app-nav-social-link",
                                target: "_blank",
                                rel: "noopener",
                                title: "Instagram",
                                aria: { label: "Instagram" } do %>
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
                        <circle cx="12" cy="12" r="4"></circle>
                        <circle cx="17.4" cy="6.7" r="1.2" class="app-nav-social-fill"></circle>
                      </svg>
                    <% end %>
                    <%= link_to "https://www.tiktok.com/@stuttgart.live.concert",
                                class: "app-nav-social-link",
                                target: "_blank",
                                rel: "noopener",
                                title: "TikTok",
                                aria: { label: "TikTok" } do %>
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M14.2 4.2c.36 1.82 1.44 3.18 3.26 4.06.63.3 1.3.48 2.04.55v2.56a8.18 8.18 0 0 1-3.01-.67v5.06c0 3.1-2.48 5.53-5.74 5.53-3.05 0-5.56-2.3-5.56-5.27 0-3.1 2.72-5.5 5.91-5.22v2.66a2.67 2.67 0 0 0-3.21 2.56c0 1.47 1.2 2.66 2.72 2.66 1.66 0 2.74-1.26 2.74-3.02V4.2h2.85Z" class="app-nav-social-fill"></path>
                      </svg>
                    <% end %>
                    <%= link_to "https://www.facebook.com/stuttgartlive",
                                class: "app-nav-social-link",
                                target: "_blank",
                                rel: "noopener",
                                title: "Facebook",
                                aria: { label: "Facebook" } do %>
                      <svg viewBox="0 0 24 24" aria-hidden="true">
                        <path d="M13.4 20.5v-7h2.3l.35-2.75H13.4V9c0-.8.22-1.35 1.37-1.35h1.46V5.2c-.25-.03-1.1-.1-2.1-.1-2.08 0-3.5 1.27-3.5 3.62v2.03H8.3v2.75h2.37v7h2.73Z" class="app-nav-social-fill"></path>
                      </svg>
                    <% end %>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
        </div>
      </div>
    </nav>

    <% if public_frontend && authenticated? %>
      <aside class="public-backend-float" aria-label="Backend-Navigation">
        <div class="public-backend-float-inner">
          <div class="app-nav-backend-menu"
               data-controller="backend-nav-menu">
            <button type="button"
                    class="app-nav-backend-toggle"
                    data-action="click->backend-nav-menu#toggle"
                    data-backend-nav-menu-target="button"
                    aria-expanded="false"
                    aria-controls="public-backend-menu"
                    aria-label="Backend-Menü öffnen">
              <span class="app-nav-backend-toggle-label">Backend</span>
              <span class="app-nav-backend-toggle-icon" aria-hidden="true">
                <span></span>
                <span></span>
                <span></span>
              </span>
            </button>

            <div id="public-backend-menu"
                 class="app-nav-backend-panel app-nav-links-group"
                 data-backend-nav-menu-target="panel"
                 hidden>
              <%= backend_nav_links %>
            </div>
          </div>
        </div>
      </aside>
    <% end %>

    <main id="main-content" tabindex="-1">
      <%= yield %>
    </main>

    <button type="button"
            class="scroll-top-button"
            data-scroll-top-target="button"
            data-action="click->scroll-top#scroll"
            aria-label="Nach oben scrollen"
            hidden>
      ↑
    </button>

    <% unless controller_path.start_with?("backend/") %>
      <%= render "layouts/consent_banner" %>
      <%= render "layouts/consent_dialog" %>
      <%= yield :page_newsletter %>
      <% unless content_for?(:page_newsletter) %>
        <%= render "public/events/newsletter_signup",
                   subscriber: NewsletterSubscriber.new,
                   signup: newsletter_signup_config("events_index", return_to: request.fullpath) %>
      <% end %>
      <%= yield :page_partner_strip %>

      <footer class="site-footer">
        <div class="site-footer-shell">
          <nav class="site-footer-nav" aria-label="Footer">
            <%= link_to "Datenschutz", datenschutz_path %>
            <%= link_to "Impressum", imprint_path %>
            <%= link_to "AGB", agb_path %>
            <%= link_to "Barrierefreiheit", barrierefreiheit_path %>
            <button type="button" class="site-footer-button" data-action="click->consent#openSettings">
              Datenschutzeinstellungen
            </button>
          </nav>
        </div>
      </footer>
    <% end %>
  </body>
</html>
