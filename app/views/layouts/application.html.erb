<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Stuttgart Live" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Stuttgart Live">
    <meta name="mobile-web-app-capable" content="yes">
    <% if controller_path.start_with?("backend/") %>
      <meta name="turbo-cache-control" content="no-cache">
    <% end %>
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Archivo+Narrow:wght@400;500;700&family=Bebas+Neue&family=Oswald:wght@200;300;500;700&display=swap" rel="stylesheet">

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <% if compiled_asset_exists?("application.css") %>
      <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <% end %>
    <% if compiled_asset_exists?("application.js") %>
      <%= javascript_include_tag "application", "data-turbo-track": "reload", type: "module" %>
    <% end %>
  </head>

  <body>
    <% nav_inner_classes = [ "app-nav-inner" ] %>
    <% nav_inner_classes << "app-nav-inner-backend" if controller_path.start_with?("backend/") %>
    <nav class="app-nav" data-controller="nav-offset">
      <div class="<%= nav_inner_classes.join(" ") %>">
        <%= link_to root_path, class: "app-brand" do %>
          <span class="brand-wordmark" aria-label="Stuttgart Live">
            <span class="brand-wordmark-city">STUTTGART</span><span class="brand-wordmark-live">LIVE</span>
          </span>
        <% end %>

        <div id="flash-messages" class="app-nav-flash">
          <%= render "layouts/flash_messages" %>
        </div>

        <div class="app-nav-meta">
          <div class="app-nav-links">
            <div class="app-nav-links-group">
              <%= link_to "Events", events_path, class: app_nav_link_class(active: events_nav_active?) %>
              <%= link_to "News", news_index_path, class: app_nav_link_class(active: news_nav_active?) %>
              <%= link_to "Kontakt", contact_path, class: app_nav_link_class(active: contact_nav_active?) %>
              <%= link_to "Impressum", imprint_path, class: app_nav_link_class(active: imprint_nav_active?) %>
              <div class="app-nav-socials" aria-label="Social Media">
                <%= link_to "https://www.instagram.com/stuttgartlive/",
                            class: "app-nav-social-link",
                            target: "_blank",
                            rel: "noopener",
                            title: "Instagram",
                            aria: { label: "Instagram" } do %>
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <rect x="3.5" y="3.5" width="17" height="17" rx="4.5"></rect>
                    <circle cx="12" cy="12" r="4"></circle>
                    <circle cx="17.4" cy="6.7" r="1.2" class="app-nav-social-fill"></circle>
                  </svg>
                <% end %>
                <%= link_to "https://www.facebook.com/stuttgartlive",
                            class: "app-nav-social-link",
                            target: "_blank",
                            rel: "noopener",
                            title: "Facebook",
                            aria: { label: "Facebook" } do %>
                  <svg viewBox="0 0 24 24" aria-hidden="true">
                    <path d="M13.4 20.5v-7h2.3l.35-2.75H13.4V9c0-.8.22-1.35 1.37-1.35h1.46V5.2c-.25-.03-1.1-.1-2.1-.1-2.08 0-3.5 1.27-3.5 3.62v2.03H8.3v2.75h2.37v7h2.73Z" class="app-nav-social-fill"></path>
                  </svg>
                <% end %>
              </div>
            </div>

            <div class="app-nav-links-group app-nav-links-group-separated">
              <% if authenticated? %>
                <% if current_user.backend_access? %>
                  <%= link_to "Redaktion", backend_events_path, class: app_nav_link_class(active: backend_nav_active?) %>
                  <%= link_to "Importer", backend_import_sources_path, class: app_nav_link_class(active: importer_nav_active?) %>
                <% end %>
                <% if current_user.blog_access? %>
                  <%= link_to "Blog", backend_blog_posts_path, class: app_nav_link_class(active: blog_nav_active?) %>
                <% end %>
                <% if current_user.admin? %>
                  <%= link_to "Benutzer", backend_users_path, class: app_nav_link_class(active: controller_path == "backend/users") %>
                <% end %>
                <%= link_to "Passwort", edit_backend_account_password_path, class: app_nav_link_class(active: controller_path == "backend/account_passwords") %>
                <%= button_to "Logout",
                              session_path,
                              method: :delete,
                              class: app_nav_link_class(accent: true),
                              form: { class: "app-nav-link-form" } %>
              <% else %>
                <%= link_to "Login", new_session_path, class: app_nav_link_class(accent: true, active: controller_path == "sessions") %>
              <% end %>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <%= yield %>

    <% unless controller_path.start_with?("backend/") %>
      <footer class="site-footer">
        <div class="site-footer-shell">
          <nav class="site-footer-nav" aria-label="Footer">
            <%= link_to "Datenschutz", datenschutz_path %>
            <%= link_to "Impressum", imprint_path %>
            <%= link_to "AGB", agb_path %>
            <%= link_to "Kontakt", contact_path %>
            <%= link_to "Barrierefreiheit", barrierefreiheit_path %>
          </nav>
        </div>
      </footer>
    <% end %>
  </body>
</html>
