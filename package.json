{
  "name": "app",
  "private": true,
  "scripts": {
    "build": "esbuild app/javascript/public.js app/javascript/backend.js --bundle --minify --sourcemap --format=esm --outdir=app/assets/builds --public-path=/assets",
    "build:css:shared": "npx @tailwindcss/cli -i ./app/assets/stylesheets/shared.tailwind.css -o ./app/assets/builds/shared.css --minify",
    "build:css:frontend": "npx @tailwindcss/cli -i ./app/assets/stylesheets/frontend.tailwind.css -o ./app/assets/builds/frontend.css --minify",
    "build:css:backend": "npx @tailwindcss/cli -i ./app/assets/stylesheets/backend.tailwind.css -o ./app/assets/builds/backend.css --minify",
    "build:css": "npm run build:css:shared && npm run build:css:frontend && npm run build:css:backend",
    "build:css:watch": "sh -c 'npx @tailwindcss/cli -i ./app/assets/stylesheets/shared.tailwind.css -o ./app/assets/builds/shared.css --watch & npx @tailwindcss/cli -i ./app/assets/stylesheets/frontend.tailwind.css -o ./app/assets/builds/frontend.css --watch & npx @tailwindcss/cli -i ./app/assets/stylesheets/backend.tailwind.css -o ./app/assets/builds/backend.css --watch & wait'"
  },
  "devDependencies": {
    "@hotwired/stimulus": "^3.2.2",
    "@hotwired/turbo-rails": "^8.0.23",
    "@rails/actiontext": "^8.1.200",
    "@tailwindcss/cli": "^4.2.1",
    "esbuild": "^0.27.3",
    "tailwindcss": "^4.2.1",
    "trix": "^2.1.18"
  },
  "resolutions": {
    "picomatch": "^4.0.4"
  }
}
