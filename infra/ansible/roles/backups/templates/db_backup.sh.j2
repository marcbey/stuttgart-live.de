#!/usr/bin/env bash
set -euo pipefail

BACKUP_DIR="{{ backup_dir }}"
KEEP_DAYS="{{ backup_keep_days }}"
STAMP="$(date +%Y%m%d-%H%M%S)"

mkdir -p "$BACKUP_DIR"

{% for db_name in postgres_app_databases %}
sudo -u postgres pg_dump --format=custom --file "$BACKUP_DIR/{{ db_name }}-$STAMP.dump" "{{ db_name }}"
{% endfor %}

{% if backup_storage_enabled %}
mkdir -p "$BACKUP_DIR/storage"
rsync -a --delete "{{ backup_storage_source }}/" "$BACKUP_DIR/storage/"
{% endif %}

find "$BACKUP_DIR" -type f -mtime +"$KEEP_DAYS" -delete
